---
import Layout from '@/components/Layout.astro';
---
<Layout title="Train - Rucking Revolution" description="Training programs, workouts, and performance kit for rucking fitness.">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">TRAIN</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Build operational readiness with training programs, workouts, and performance kit. Everything you need to strengthen your body and mind for rucking.
        </p>
      </div>

      <section class="mb-12">
        <h2 class="text-2xl font-heading text-secondary mb-6">TRAINING RESOURCES</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <a href="/train/workouts" class="block p-6 border border-border card-border hover:border-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2">WORKOUTS</h3>
            <p class="text-muted-foreground text-sm">
              Generate workouts, access sample routines, and learn programming principles.
            </p>
          </a>
          <a href="/train/performance-kit" class="block p-6 border border-border card-border hover:border-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2">PERFORMANCE KIT</h3>
            <p class="text-muted-foreground text-sm">
              Exercise pages for mobility band, release ball, and ankle wrap techniques.
            </p>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
