---
import Layout from '@/components/Layout.astro';
import { workouts } from '@/data/workouts.ts';

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-800',
  intermediate: 'bg-yellow-100 text-yellow-800',
  advanced: 'bg-red-100 text-red-800',
};

const sortedWorkouts = [...workouts].sort((a, b) => {
  if (a.difficulty === 'beginner' && b.difficulty !== 'beginner') return -1;
  if (b.difficulty === 'beginner' && a.difficulty !== 'beginner') return 1;
  if (a.difficulty === 'intermediate' && b.difficulty === 'advanced') return -1;
  if (b.difficulty === 'intermediate' && a.difficulty === 'advanced') return 1;
  return 0;
});
---

<Layout title="All Workouts - Rucking Revolution" description="Browse all pre-designed workouts for rucking fitness.">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">ALL WORKOUTS</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Browse our complete collection of {workouts.length} pre-designed workouts for different goals and experience levels.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {sortedWorkouts.map((workout) => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 class="text-xl font-bold mb-2">{workout.title}</h3>
              <p class="text-gray-600 mb-4">{workout.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class={`text-xs px-2 py-1 rounded ${difficultyColors[workout.difficulty]}`}>{workout.difficulty}</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.duration} min</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.load}kg</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.distance}km</span>
              </div>
              <a 
                href={`/train/workouts/${workout.slug}`}
                class="block w-full text-center bg-red-800 text-white px-4 py-2 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus:ring-offset-2 transition-colors"
              >
                View Details
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a 
          href="/train"
          class="text-red-800 hover:text-red-900 font-medium"
        >
          ← Back to Training
        </a>
      </div>
    </div>
  </div>
</Layout>
