---
import Layout from '@/components/Layout.astro';
import { workouts, type Workout } from '@/data/workouts.ts';

export function getStaticPaths() {
  return workouts.map((workout) => ({
    params: { slug: workout.slug },
    props: { workout },
  }));
}

interface Props {
  workout: Workout;
}

const { workout } = Astro.props;

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-800',
  intermediate: 'bg-yellow-100 text-yellow-800',
  advanced: 'bg-red-100 text-red-800',
};
---

<Layout 
  title={`${workout.title} - Rucking Revolution`}
  description={workout.description}
>
  <div class="bg-surface py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class={`px-3 py-1 rounded-full text-sm font-medium ${difficultyColors[workout.difficulty] || ''}`}>
            {workout.difficulty.charAt(0).toUpperCase() + workout.difficulty.slice(1)}
          </span>
          <span class="label-mono">{workout.duration} MIN</span>
          <span class="label-mono">{workout.load} KG</span>
          <span class="label-mono">{workout.distance} KM</span>
        </div>
        <h1 class="text-4xl font-heading text-secondary mb-4">{workout.title.toUpperCase()}</h1>
        <p class="text-lg font-serif text-muted-foreground">{workout.description}</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-panel p-4 rounded-lg">
          <h3 class="label-mono mb-1">DURATION</h3>
          <p class="text-2xl font-heading text-secondary">{workout.duration} min</p>
        </div>
        <div class="bg-panel p-4 rounded-lg">
          <h3 class="label-mono mb-1">DISTANCE</h3>
          <p class="text-2xl font-heading text-secondary">{workout.distance} km</p>
        </div>
        <div class="bg-panel p-4 rounded-lg">
          <h3 class="label-mono mb-1">LOAD</h3>
          <p class="text-2xl font-heading text-secondary">{workout.load} kg</p>
        </div>
      </div>

      <section class="mb-8">
        <h2 class="text-2xl font-heading text-secondary mb-4">TERRAIN</h2>
        <div class="flex flex-wrap gap-2">
          {workout.terrain.map((t) => (
            <span class="stamp stamp-primary">{t}</span>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-heading text-secondary mb-4">OBJECTIVES</h2>
        <ul class="list-disc list-inside space-y-2 text-muted-foreground">
          {workout.objectives.map((objective) => (
            <li>{objective}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-heading text-secondary mb-4">EQUIPMENT</h2>
        <ul class="list-disc list-inside space-y-2 text-muted-foreground">
          {workout.equipment.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      {workout.notes && (
        <section class="mb-8 bg-panel p-6 rounded-lg">
          <h2 class="text-2xl font-heading text-secondary mb-4">NOTES</h2>
          <p class="text-muted-foreground">{workout.notes}</p>
        </section>
      )}

      <section class="mb-8 pt-6 border-t border-border">
        <div class="flex gap-4">
          <a 
            href="/train/workouts"
            class="btn btn-utility"
          >
            ← Back to Workouts
          </a>
          <button 
            type="button"
            data-print-trigger="true"
            class="btn btn-primary"
          >
            Print Workout
          </button>
        </div>
      </section>
    </div>
  </div>
</Layout>
