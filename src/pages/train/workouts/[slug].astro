---
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';
import { workouts, type Workout } from '@/data/workouts.ts';

export function getStaticPaths() {
  return workouts.map((workout) => ({
    params: { slug: workout.slug },
    props: { workout },
  }));
}

interface Props {
  workout: Workout;
}

const { workout } = Astro.props;
---

<Layout 
  title={`${workout.title} - Rucking Revolution`}
  description={workout.description}
>
  <Container>
    <article class="max-w-4xl mx-auto">
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class={`px-3 py-1 rounded-full text-sm font-medium ${
            workout.difficulty === 'beginner' ? 'bg-green-100 text-green-800' :
            workout.difficulty === 'intermediate' ? 'bg-yellow-100 text-yellow-800' :
            'bg-red-100 text-red-800'
          }`}>
            {workout.difficulty.charAt(0).toUpperCase() + workout.difficulty.slice(1)}
          </span>
          <span class="text-gray-500">{workout.duration} min</span>
          <span class="text-gray-500">{workout.load} kg</span>
          <span class="text-gray-500">{workout.distance} km</span>
        </div>
        <h1 class="text-4xl font-bold mb-4">{workout.title}</h1>
        <p class="text-xl text-gray-600">{workout.description}</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        <div class="bg-gray-50 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-gray-500 mb-1">Duration</h3>
          <p class="text-2xl font-bold">{workout.duration} min</p>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-gray-500 mb-1">Distance</h3>
          <p class="text-2xl font-bold">{workout.distance} km</p>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-gray-500 mb-1">Load</h3>
          <p class="text-2xl font-bold">{workout.load} kg</p>
        </div>
      </div>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Terrain</h2>
        <div class="flex flex-wrap gap-2">
          {workout.terrain.map((t) => (
            <span class="px-3 py-1 bg-red-100 text-red-800 rounded-full text-sm font-medium">
              {t.charAt(0).toUpperCase() + t.slice(1)}
            </span>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Objectives</h2>
        <ul class="list-disc list-inside space-y-2 text-gray-700">
          {workout.objectives.map((objective) => (
            <li>{objective}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Equipment</h2>
        <ul class="list-disc list-inside space-y-2 text-gray-700">
          {workout.equipment.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      {workout.notes && (
        <section class="mb-8 bg-blue-50 p-6 rounded-lg">
          <h2 class="text-2xl font-bold mb-4">Notes</h2>
          <p class="text-gray-700">{workout.notes}</p>
        </section>
      )}

      <section class="mb-8">
        <div class="flex gap-4">
          <a 
            href="/train/workouts"
            class="inline-block px-6 py-3 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition-colors"
          >
            ← Back to Workouts
          </a>
          <button 
            onclick="window.print()"
            class="inline-block px-6 py-3 bg-red-800 text-white rounded-lg hover:bg-red-900 transition-colors"
          >
            Print Workout
          </button>
        </div>
      </section>
    </article>
  </Container>
</Layout>
