---
import Layout from '@/components/Layout.astro';
import { exercises } from '@/data/exercises.ts';

const exercise = exercises.find(ex => ex.slug === 'plank');
---
<Layout title={`${exercise?.title} - Performance Kit`} description={`Learn proper form for ${exercise?.title} with step-by-step instructions, common mistakes, and progressions`}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">{exercise?.title}</h1>
    
    {/* Purpose/Overview */}
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Purpose</h2>
      <p class="text-gray-700 mb-4">The plank is a fundamental core exercise that builds isometric strength in the abdominals, lower back, and shoulders while improving overall stability and posture.</p>
      <p class="text-gray-600">Primary muscles worked: {exercise?.targetMuscles.join(', ')}</p>
      <p class="text-gray-600">Equipment needed: {exercise?.equipment.join(', ')}</p>
      <p class="text-gray-600">Difficulty level: {exercise?.difficulty}</p>
    </section>
    
    {/* Step-by-step */}
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Step-by-Step Technique</h2>
      <ol class="list-decimal list-inside space-y-3 text-gray-700">
        {exercise?.steps.map((step, index) => (
          <li key={index} class="flex">
            <span class="flex-shrink-0 text-red-600">{index + 1}.</span>
            <span class="flex-grow">{step}</span>
          </li>
        ))}
      </ol>
    </section>
    
    {/* Common Mistakes */}
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Common Mistakes to Avoid</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-700">
        {exercise?.mistakes.map((mistake, index) => (
          <li key={index}>
            <span class="flex-shrink-0 text-red-600">•</span>
            <span class="flex-grow">{mistake}</span>
          </li>
        ))}
      </ul>
    </section>
    
    {/* Progressions */}
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Progressions</h2>
      <p class="text-gray-600 mb-2">Start with easier variations and gradually progress to more challenging ones as you build strength:</p>
      <ol class="list-decimal list-inside space-y-2 text-gray-700">
        {exercise?.progressions.map((progression, index) => (
          <li key={index}>
            <span class="flex-shrink-0 text-red-600">{index + 1}.</span>
            <span class="flex-grow">{progression}</span>
          </li>
        ))}
      </ol>
    </section>
    
    {/* Media */}
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Exercise Demonstration</h2>
      {exercise?.media.map((media, index) => (
        <div key={index} class="mb-6">
          {media.type === 'image' ? (
            <figure>
              <img src={media.src} alt={media.alt} class="rounded-lg shadow-md w-full h-auto" loading="lazy" />
              <figcaption class="mt-2 text-center text-sm text-gray-500">{media.alt}</figcaption>
            </figure>
          ) : (
            <div class="relative w-full h-0 pb-[56.25%] bg-gray-200 rounded-lg shadow-md">
              {/* Placeholder for video/GIF */}
              <div class="absolute inset-0 flex items-center justify-center text-secondary/70">
                Video placeholder - {media.alt}
              </div>
            </div>
          )}
        </div>
      ))}
    </section>
    
    {/* Progress Indicator */}
    <section class="mb-8 pt-6 border-t">
      <h2 class="text-xl font-semibold mb-4">Track Your Progress</h2>
      <div class="space-y-3">
        <div class="flex items-center">
          <span class="w-20">Sets:</span>
          <input type="number" min="1" value="3" class="w-20 px-2 py-1 border rounded" />
        </div>
        <div class="flex items-center">
          <span class="w-20">Duration:</span>
          <input type="number" min="10" value="30" class="w-20 px-2 py-1 border rounded" /> seconds
        </div>
        <div class="flex items-center">
          <span class="w-20">Rest:</span>
          <input type="number" min="0" value="60" class="w-20 px-2 py-1 border rounded" /> seconds
        </div>
      </div>
    </section>
  </div>
</Layout>
