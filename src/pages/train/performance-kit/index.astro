---
import Layout from '@/components/Layout.astro';
---
<Layout title="Performance Kit" description="Exercise pages for mobility band (upper/lower), release ball, ankle wrap technique">
  <h1 class="text-3xl font-bold mb-6">Performance Kit</h1>
  <p class="mb-6">Exercise pages for mobility band (upper/lower), release ball, ankle wrap technique</p>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <a href="/train/performance-kit/mobility-band/upper-body/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Mobility Band - Upper Body</h2>
      <p class="text-gray-600">Exercises for upper body strength and mobility using resistance bands</p>
    </a>
    <a href="/train/performance-kit/mobility-band/lower-body/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Mobility Band - Lower Body</h2>
      <p class="text-gray-600">Exercises for lower body strength and mobility using resistance bands</p>
    </a>
    <a href="/train/performance-kit/release-ball/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Release Ball</h2>
      <p class="text-gray-600">Myofascial release techniques using a lacrosse or massage ball</p>
    </a>
    <a href="/train/performance-kit/ankle-wrap/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Ankle Wrap</h2>
      <p class="text-gray-600">Stability and mobility exercises using ankle wraps or resistance bands</p>
    </a>
  </div>
</Layout>
