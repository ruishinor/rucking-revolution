---
import Layout from '@/components/Layout.astro';
---
<Layout title="Performance Kit" description="Exercise pages for mobility band (upper/lower), release ball, ankle wrap technique">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">PERFORMANCE KIT</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Exercise pages for mobility band (upper/lower), release ball, ankle wrap technique
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/train/performance-kit/mobility-band/upper-body/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary">
          <h2 class="text-xl font-heading text-secondary mb-2">MOBILITY BAND - UPPER BODY</h2>
          <p class="text-muted-foreground text-sm">Exercises for upper body strength and mobility using resistance bands</p>
        </a>
        <a href="/train/performance-kit/mobility-band/lower-body/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary">
          <h2 class="text-xl font-heading text-secondary mb-2">MOBILITY BAND - LOWER BODY</h2>
          <p class="text-muted-foreground text-sm">Exercises for lower body strength and mobility using resistance bands</p>
        </a>
        <a href="/train/performance-kit/release-ball/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary">
          <h2 class="text-xl font-heading text-secondary mb-2">RELEASE BALL</h2>
          <p class="text-muted-foreground text-sm">Myofascial release techniques using a lacrosse or massage ball</p>
        </a>
        <a href="/train/performance-kit/ankle-wrap/" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary">
          <h2 class="text-xl font-heading text-secondary mb-2">ANKLE WRAP</h2>
          <p class="text-muted-foreground text-sm">Stability and mobility exercises using ankle wraps or resistance bands</p>
        </a>
      </div>
    </div>
  </div>
</Layout>
