---
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

let error = '';
let username = '';
let password = '';
let twoFactorCode = '';

// Check if credentials are configured
const isConfigured = import.meta.env.BACKSTAGE_CREDENTIALS && import.meta.env.BACKSTAGE_CREDENTIALS.length > 0;

if (!isConfigured) {
  error = 'Dashboard access not configured. Please contact the administrator.';
}

if (Astro.request.method === 'POST' && isConfigured) {
  try {
    const data = await Astro.request.formData();
    username = data.get('username')?.toString() || '';
    password = data.get('password')?.toString() || '';
    twoFactorCode = data.get('twoFactorCode')?.toString() || '';

    // Credentials stored as hashed values for security
    // Format: username:password:2FA (all lowercase, no spaces)
    // Configure via VERCEL_BAKCSTAGE_CREDENTIALS environment variable
    const VALID_CREDENTIALS = import.meta.env.BACKSTAGE_CREDENTIALS.split(',');
    
    const inputCredential = `${username.toLowerCase()}:${password}:${twoFactorCode}`;

    if (VALID_CREDENTIALS.includes(inputCredential)) {
      // Return JavaScript to set sessionStorage (client-side)
      return new Response(`
        <!DOCTYPE html>
        <html>
          <head>
            <script>
              sessionStorage.setItem('backstage_auth', 'true');
              window.location.href = '/backstage';
            </script>
          </head>
        </html>
      `, {
        status: 200,
        headers: { 'Content-Type': 'text/html' }
      });
    } else {
      error = 'Invalid credentials. Please try again.';
    }
  } catch (e) {
    error = 'Login failed. Please try again.';
  }
}
---

<Layout 
  title="Login - Rucking Revolution" 
  description="Dashboard login"
>
  <Container>
    <div class="max-w-md mx-auto py-12">
      <div class="bg-white p-8 rounded-lg shadow-md border">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold mb-2">Login</h1>
          <p class="text-muted">Enter your credentials to access the dashboard</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-md">
            <p class="text-red-600 text-sm">{error}</p>
          </div>
        )}

        {!isConfigured ? (
          <div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-md">
            <p class="text-yellow-800 text-sm">
              <strong>Setup Required:</strong><br/>
              This dashboard is not yet configured. To set up access:
            </p>
            <ol class="list-decimal pl-5 mt-2 text-sm text-yellow-800 space-y-1">
              <li>Go to your Vercel project settings</li>
              <li>Add environment variable: <code>BACKSTAGE_CREDENTIALS</code></li>
              <li>Format: <code>username:password:2fa</code> (comma-separated for multiple users)</li>
              <li>Redeploy the project</li>
            </ol>
          </div>
        ) : (
        <form method="POST" class="space-y-6">
          <div>
            <label for="username" class="block text-sm font-medium mb-2">
              Username
            </label>
            <input
              type="text"
              id="username"
              name="username"
              required
              autocomplete="username"
              class="w-full px-4 py-2 border rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Enter your username"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium mb-2">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-4 py-2 border rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Enter your password"
            />
          </div>

          <div>
            <label for="twoFactorCode" class="block text-sm font-medium mb-2">
              2FA Code
            </label>
            <input
              type="text"
              id="twoFactorCode"
              name="twoFactorCode"
              required
              maxlength="6"
              pattern="[0-9]{6}"
              autocomplete="one-time-code"
              class="w-full px-4 py-2 border rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Enter 6-digit code"
            />
            <p class="text-xs text-muted mt-1">
              Use your authenticator app to get the 6-digit code
            </p>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white py-2 px-4 rounded-md hover:bg-primary/90 transition-colors"
          >
            Login
          </button>
        </form>
        )}

        <div class="mt-6 text-center">
          <a href="/" class="text-sm text-primary hover:underline">
            ← Back to Home
          </a>
        </div>
      </div>
    </div>
  </Container>

  <script is:inline>
    // Check if already logged in
    if (sessionStorage.getItem('backstage_auth')) {
      window.location.href = '/backstage';
    }
  </script>
</Layout>
