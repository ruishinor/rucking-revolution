---
export const prerender = false;

import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';
import { timingSafeEqual } from 'node:crypto';

const backstageEnabled =
  !import.meta.env.PROD || process.env.BACKSTAGE_ENABLED === 'true';

if (!backstageEnabled) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

const adminSecret = process.env.BACKSTAGE_SECRET;
// Prefer header-based secrets to avoid leaking secrets in query strings or logs.
// Accepts `Authorization: Bearer <secret>` or `x-vercel-protection-key` header.
const headerAuth = (Astro.request?.headers?.get('authorization') || Astro.request?.headers?.get('x-vercel-protection-key') || '')?.toString();
const providedSecret = (headerAuth.replace(/^Bearer\s+/i, '') || Astro.url.searchParams.get('access_key')) ?? '';

function secretsMatch(expected: string, provided: string): boolean {
  const expectedBuf = Buffer.from(expected);
  const providedBuf = Buffer.from(provided);
  
  // Always perform timing-safe comparison regardless of length
  const maxLen = Math.max(expectedBuf.length, providedBuf.length);
  const normalizedExpected = Buffer.alloc(maxLen);
  const normalizedProvided = Buffer.alloc(maxLen);
  
  expectedBuf.copy(normalizedExpected);
  providedBuf.copy(normalizedProvided);
  
  const match = timingSafeEqual(normalizedExpected, normalizedProvided);
  return match && expectedBuf.length === providedBuf.length;
}

if (adminSecret) {
  if (!providedSecret || !secretsMatch(adminSecret, providedSecret)) {
    return new Response(null, {
      status: 403,
      statusText: 'Forbidden'
    });
  }
} else if (import.meta.env.PROD) {
  return new Response(null, {
    status: 503,
    statusText: 'Service unavailable'
  });
}

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

const stats = {
  newsletterSubscribers: 0,
  contactMessages: 0,
  notifyMeRequests: 0,
  recentSignups: []
};
---

<Layout 
  title="Dashboard - Rucking Revolution" 
  description="Dashboard for managing newsletter subscribers and contact messages"
  currentPage="/backstage"
>
  <Container>
    <div class="max-w-6xl mx-auto py-12">
      <header class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Dashboard</h1>
        <p class="text-muted">
          Manage newsletter subscribers and view contact submissions.
        </p>
        <p class="text-sm text-muted mt-2">
          <em>This page is disabled by default in production. Re-enable it only behind separate access controls.</em>
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6">Overview</h2>
        <div class="grid gap-6 md:grid-cols-3">
          <div class="p-6 border rounded-lg bg-white">
            <div class="flex items-center justify-between mb-4">
              <div class="text-3xl" role="img" aria-label="Email">📧</div>
              <span class="text-3xl font-bold">{stats.newsletterSubscribers}</span>
            </div>
            <h3 class="font-semibold">Newsletter Subscribers</h3>
            <p class="text-sm text-muted">Active subscribers</p>
          </div>

          <div class="p-6 border rounded-lg bg-white">
            <div class="flex items-center justify-between mb-4">
              <div class="text-3xl" role="img" aria-label="Messages">💬</div>
              <span class="text-3xl font-bold">{stats.contactMessages}</span>
            </div>
            <h3 class="font-semibold">Contact Messages</h3>
            <p class="text-sm text-muted">Total submissions</p>
          </div>

          <div class="p-6 border rounded-lg bg-white">
            <div class="flex items-center justify-between mb-4">
              <div class="text-3xl" role="img" aria-label="Notifications">🔔</div>
              <span class="text-3xl font-bold">{stats.notifyMeRequests}</span>
            </div>
            <h3 class="font-semibold">Notify Me Requests</h3>
            <p class="text-sm text-muted">Interested in new products</p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6">Newsletter</h2>
        <div class="p-6 border rounded-lg bg-gray-50">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold mb-1">Send Newsletter</h3>
              <p class="text-sm text-muted">Compose and send to your subscriber list</p>
            </div>
            <button 
              type="button"
              class="px-6 py-2 bg-primary text-white rounded-md hover:bg-primary/90 transition-colors"
            >
              Compose Email
            </button>
          </div>
          <hr class="my-6" />
          <div class="text-sm text-muted">
            <p class="mb-2"><strong>Note:</strong> This is a placeholder dashboard.</p>
            <p>To enable full functionality, connect an email service like:</p>
            <ul class="list-disc pl-5 mt-2 space-y-1">
              <li><a href="https://convertkit.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">ConvertKit</a> - Recommended for newsletters</li>
              <li><a href="https://mailchimp.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Mailchimp</a> - Popular choice</li>
              <li><a href="https://buttondown.email" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Buttondown</a> - Simple & minimal</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6">Recent Contact Messages</h2>
        <div class="border rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-semibold">Date</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Name</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Email</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Subject</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-muted">
                  No contact messages yet. They will appear here when users submit the contact form.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6">Notify Me Requests</h2>
        <div class="border rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-semibold">Date</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Email</th>
                <th class="px-4 py-3 text-left text-sm font-semibold">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <tr>
                <td colspan="3" class="px-4 py-8 text-center text-muted">
                  No notify requests yet. They will appear here when users click "Notify Me" on Coming Soon products.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold mb-6">Quick Links</h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
          <a href="/newsletter" class="p-4 border rounded-lg hover:bg-gray-50 transition-colors">
            <span class="font-semibold">Newsletter Signup →</span>
          </a>
          <a href="/contact" class="p-4 border rounded-lg hover:bg-gray-50 transition-colors">
            <span class="font-semibold">Contact Page →</span>
          </a>
          <a href="/library" class="p-4 border rounded-lg hover:bg-gray-50 transition-colors">
            <span class="font-semibold">Digital Library →</span>
          </a>
          <a href="/" class="p-4 border rounded-lg hover:bg-gray-50 transition-colors">
            <span class="font-semibold">Home →</span>
          </a>
        </div>
      </section>
    </div>
  </Container>
</Layout>
