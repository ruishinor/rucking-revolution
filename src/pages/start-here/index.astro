---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site';

// System attributes for the three-column grid
const systemAttributes = [
  {
    title: 'Beginner-Safe',
    description: 'No prior experience needed. Start with any load and build from there.',
    icon: 'shield',
  },
  {
    title: 'Low-Friction',
    description: 'One page, three sessions. No app, no equipment list, no overwhelm.',
    icon: 'feather',
  },
  {
    title: 'Steady Progress',
    description: 'Each ruck builds on the last. Small steps compound into real capability.',
    icon: 'trending',
  },
];

// Structured data for the Start Here page
const startHereStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Start Here - Rucking Revolution",
  "description": "Get the free beginner quick-start guide and take your first three rucks without overcomplicating it.",
  "url": `${site.baseUrl}/start-here`,
  "mainEntity": {
    "@type": "HowTo",
    "name": "Your First 3 Rucks",
    "description": "A one-page quick-start guide to build a consistent rucking habit in three sessions.",
    "step": [
      {
        "@type": "HowToStep",
        "name": "Ruck 1",
        "text": "Choose a manageable load and walk short enough to finish wanting more."
      },
      {
        "@type": "HowToStep",
        "name": "Ruck 2",
        "text": "Repeat the setup with a little more confidence and one small improvement."
      },
      {
        "@type": "HowToStep",
        "name": "Ruck 3",
        "text": "Lock the pattern in and decide whether you are ready for the 30-day plan."
      }
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Rucking Revolution",
    "url": site.baseUrl
  }
};
---

<Layout
  title="Start Here - Rucking Revolution"
  description="Get the free beginner quick-start guide and take your first three rucks without overcomplicating it."
  currentPage="/start-here"
  structuredData={startHereStructuredData}
  canonicalUrl={`${site.baseUrl}/start-here`}
>

  <!-- System Attributes Strip -->
  <section class="bg-secondary py-10" aria-label="Program attributes">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {systemAttributes.map((attr) => (
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/15 flex items-center justify-center" aria-hidden="true">
              {attr.icon === 'shield' && (
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              )}
              {attr.icon === 'feather' && (
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
              )}
              {attr.icon === 'trending' && (
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
              )}
            </div>
            <div>
              <h3 class="text-white font-heading text-sm tracking-wider uppercase">{attr.title}</h3>
              <p class="text-white/70 text-xs leading-relaxed mt-0.5">{attr.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">

        <!-- Value Proposition Module (Left Column) -->
        <div class="soft-panel p-8 sm:p-10">
          <p class="eyebrow">Free Quick-Start</p>
          <h1 class="mt-5 font-heading text-5xl tracking-[-0.055em] text-secondary sm:text-6xl">
            {site.leadMagnet.title}
          </h1>
          <p class="mt-3 label-mono">{site.leadMagnet.subtitle}</p>
          <p class="mt-6 max-w-3xl font-serif text-xl leading-9 text-muted-foreground">
            This is the cleanest way into the brand: one page, three sessions, and a quiet confidence boost before you
            decide whether the full 30-day book is for you.
          </p>

          <!-- Progression Grid -->
          <div class="mt-8 grid gap-4 sm:grid-cols-3" role="list" aria-label="Three-ruck progression">
            <div class="card-border p-5" role="listitem">
              <p class="label-mono">Ruck 1</p>
              <p class="mt-2 text-sm leading-7 text-muted-foreground">Choose a manageable load and walk short enough to finish wanting more.</p>
            </div>
            <div class="card-border p-5" role="listitem">
              <p class="label-mono">Ruck 2</p>
              <p class="mt-2 text-sm leading-7 text-muted-foreground">Repeat the setup with a little more confidence and one small improvement.</p>
            </div>
            <div class="card-border p-5" role="listitem">
              <p class="label-mono">Ruck 3</p>
              <p class="mt-2 text-sm leading-7 text-muted-foreground">Lock the pattern in and decide whether you are ready for the 30-day plan.</p>
            </div>
          </div>

          <!-- Primary CTAs -->
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={site.leadMagnet.download} class="btn btn-primary" aria-label="Open the free quick-start guide">
              Open the guide now
            </a>
            <a href={site.leadBook.link} class="btn btn-secondary" aria-label="View the lead book in the library">
              See the lead book
            </a>
          </div>
        </div>

        <!-- Lead Capture Form (Right Column) -->
        <div class="soft-panel p-8">
          <p class="eyebrow">Optional Capture</p>
          <h2 class="mt-4 font-heading text-4xl tracking-[-0.05em] text-secondary">Use the on-site handoff flow.</h2>
          <p class="mt-4 text-sm leading-7 text-muted-foreground">
            This static build uses a simple lead capture interaction: submit the short form, reveal the guide, and move
            the reader forward immediately.
          </p>

          <form id="newsletter-form" class="mt-6 space-y-4" aria-label="Quick-start guide sign up">
            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-secondary">First name</span>
              <input
                type="text"
                name="name"
                autocomplete="given-name"
                class="w-full px-4 py-3"
                placeholder="Alex"
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-secondary">Email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3"
                placeholder="you@example.com"
                aria-required="true"
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-secondary">What do you want most right now?</span>
              <select name="focus" class="w-full px-4 py-3" autocomplete="off">
                <option>Starting without feeling behind</option>
                <option>Choosing the right beginner weight</option>
                <option>Staying consistent after the first week</option>
              </select>
            </label>

            <button type="submit" class="btn btn-primary w-full">Get the guide</button>
            <p class="text-xs text-muted-foreground">
              This build reveals the guide immediately after submit so the launch path can be tested end to end.
            </p>
          </form>

          <!-- Success State Module -->
          <div id="success-message" class="hidden" role="status" aria-live="polite">
            <div class="mt-6 card-border p-6">
              <p class="eyebrow">Guide unlocked</p>
              <h3 class="mt-4 font-heading text-3xl tracking-[-0.04em] text-secondary">The next step is ready.</h3>
              <p class="mt-3 text-sm leading-7 text-muted-foreground">
                Open the one-page guide, take the first three rucks, then come back for the lead book when you want a fuller plan.
              </p>
              <div class="mt-6 flex flex-col gap-3">
                <a href={site.leadMagnet.download} class="btn btn-primary w-full" aria-label="Open the free quick-start guide">
                  Open the guide
                </a>
                <a href="/articles" class="btn btn-secondary w-full" aria-label="Read the launch articles">
                  Read the articles
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script type="module" src="/scripts/newsletter-signup.js" is:inline></script>
</Layout>
