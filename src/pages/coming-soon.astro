---
import Layout from '../components/Layout.astro';
---

<Layout title="Coming Soon | Rucking Revolution">
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-primary mb-6">
        Coming Soon
      </h1>
      <p class="text-xl text-muted-foreground mb-8">
        We're building something great. This page is currently under development.
      </p>
      <div class="p-6 bg-muted rounded-lg">
        <p class="text-muted">
          The Rucking Revolution website is being refined and expanded. 
          Check back soon for updated content, new features, and improved resources.
        </p>
      </div>
      <p class="mt-8 text-sm text-muted">
        Thank you for your patience.
      </p>
    </div>
  </main>
</Layout>
