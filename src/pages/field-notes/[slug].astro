---
import { site } from '@/data/site';
import { fieldNotes } from '@/data/fieldnotes';
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

export async function getStaticPaths() {
  return fieldNotes.map(note => ({
    params: { slug: note.slug },
    props: { note }
  }));
}

// Get the slug from params
const { slug } = Astro.params;

// Find the field note with matching slug
const note = fieldNotes.find(n => n.slug === slug);

// If field note not found, redirect to 404
if (!note) {
  return Astro.redirect('/404');
}

const pageTitle = `${note.title} - Rucking Revolution`;
const pageDescription = note.observations.join(' ');
---
<Layout 
  title={pageTitle}
  description={pageDescription}
  currentPage={`/field-notes/${note.slug}`}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/field-notes/${note.slug}`,
    image: `${site.baseUrl}${note.heroImage.src}`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6">
        <a href="/field-notes" class="text-sm text-muted-foreground hover:underline">← Back to Field Notes</a>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl font-heading text-secondary mb-4">{note.title.toUpperCase()}</h1>
        <div class="flex flex-wrap gap-4 text-sm font-mono text-muted-foreground">
          <span>DATE: {new Date(note.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          <span>LOC: {note.location}</span>
          <span>DIST: {note.distance} km ({(note.distance * 0.621371).toFixed(1)} mi)</span>
          <span>DUR: {note.duration} min</span>
          <span>LOAD: {note.load} kg ({(note.load * 2.20462).toFixed(1)} lb)</span>
          <span>WX: {note.weather}</span>
          <span>TERRAIN: {note.terrain.map(t => t.charAt(0).toUpperCase() + t.slice(1)).join(', ')}</span>
        </div>
      </header>

      {/* Hero Image */}
      <figure class="mb-8">
        <img
          src={note.heroImage.src}
          alt={note.heroImage.alt}
          class="w-full rounded-lg shadow-lg"
          loading="lazy"
        />
      </figure>

      <article class="prose lg:prose-xl">
        {/* Observations */}
        <section class="mb-8">
          <h2 class="font-heading text-secondary">OBSERVATIONS</h2>
          <ul class="list-disc list-inside space-y-3">
            {note.observations.map((obs, index) => (
              <li key={index}>{obs}</li>
            ))}
          </ul>
        </section>

        {/* Insights */}
        {note.insights.length > 0 && (
          <section class="mb-8">
            <h2 class="font-heading text-secondary">INSIGHTS</h2>
            <ul class="list-disc list-inside space-y-3">
              {note.insights.map((insight, index) => (
                <li key={index}>{insight}</li>
              ))}
            </ul>
          </section>
        )}

        {/* Questions */}
        {note.questions.length > 0 && (
          <section class="mb-8">
            <h2 class="font-heading text-secondary">QUESTIONS FOR FURTHER EXPLORATION</h2>
            <ul class="list-disc list-inside space-y-3">
              {note.questions.map((question, index) => (
                <li key={index}>{question}</li>
              ))}
            </ul>
          </section>
        )}
      </article>
    </div>
  </div>
</Layout>