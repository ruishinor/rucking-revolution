---
import { site } from '@/data/site';
import { fieldNotes } from '@/data/fieldnotes';
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

const pageTitle = 'Field Notes - Rucking Revolution';
const pageDescription = 'Read short essays and observations from real-world rucking experiences.';
---
<Layout 
  title={pageTitle} 
  description={pageDescription}
  currentPage="/field-notes"
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/field-notes`,
    image: `${site.baseUrl}/og-field-notes.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <Container>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-center">Field Notes</h1>
      <p class="text-center text-muted mt-2">
        Read short essays and observations from real-world rucking experiences.
      </p>
    </header>

    {/* Field Notes Grid */}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {fieldNotes.map(note => (
        <article
          key={note.id}
          class="hover:shadow-lg transition-shadow flex flex-col h-full border rounded-lg overflow-hidden"
        >
          {/* Hero Image */}
          <a href={`/field-notes/${note.slug}`} class="mb-0">
            <img
              src={note.heroImage.src}
              alt={note.heroImage.alt}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
          </a>

          {/* Field Note Content */}
          <div class="flex-0 p-4">
            <h2 class="text-xl font-semibold mb-2 line-clamp-2">
              <a href={`/field-notes/${note.slug}`} class="hover:underline">
                {note.title}
              </a>
            </h2>
            <p class="text-muted-foreground mb-2 line-clamp-3">
              {note.observations.slice(0, 2).join(' ')}...
            </p>

            {/* Metadata */}
            <div class="mt-auto space-y-2 text-sm text-muted-foreground">
              <div class="flex flex-wrap gap-4">
                <span>Date: {new Date(note.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span>Location: {note.location}</span>
                <span>Distance: {note.distance} km</span>
              </div>
              <div class="flex flex-wrap gap-4">
                <span>Duration: {note.duration} min</span>
                <span>Load: {note.load} kg</span>
                <span>Weather: {note.weather}</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </Container>
</Layout>