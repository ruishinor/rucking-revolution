---
import { site } from '@/data/site';
import { fieldNotes } from '@/data/fieldnotes';
import Layout from '@/components/Layout.astro';

const pageTitle = 'Field Notes - Rucking Revolution';
const pageDescription = 'Read short essays and observations from real-world rucking experiences.';
---
<Layout 
  title={pageTitle} 
  description={pageDescription}
  currentPage="/field-notes"
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/field-notes`,
    image: `${site.baseUrl}/og-field-notes.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">FIELD NOTES</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Read short essays and observations from real-world rucking experiences.
        </p>
      </div>

      {/* Field Notes Grid */}
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {fieldNotes.map(note => (
          <article
            key={note.id}
            class="card-border flex flex-col h-full border border-border hover:border-primary transition-colors"
          >
            {/* Hero Image */}
            <a href={`/field-notes/${note.slug}`} class="mb-0">
              <img
                src={note.heroImage.src}
                alt={note.heroImage.alt}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            </a>

            {/* Field Note Content */}
            <div class="flex-0 p-4">
              <h2 class="text-xl font-heading text-secondary mb-2 line-clamp-2">
                <a href={`/field-notes/${note.slug}`} class="hover:underline">
                  {note.title}
                </a>
              </h2>
              <p class="text-muted-foreground mb-2 line-clamp-3 text-sm">
                {note.observations.slice(0, 2).join(' ')}...
              </p>

              {/* Metadata */}
              <div class="mt-auto space-y-2 text-sm font-mono text-xs text-muted-foreground">
                <div class="flex flex-wrap gap-4">
                  <span>DATE: {new Date(note.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  <span>LOC: {note.location}</span>
                </div>
                <div class="flex flex-wrap gap-4">
                  <span>DIST: {note.distance} KM</span>
                  <span>DUR: {note.duration} MIN</span>
                  <span>LOAD: {note.load} KG</span>
                  <span>WX: {note.weather}</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
