---
import Layout from '@/components/Layout.astro';
---

<Layout 
  title="Newsletter - Rucking Revolution" 
  description="Subscribe to the Rucking Revolution newsletter for training tips, community updates, and exclusive content"
  currentPage="/newsletter"
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">
      <header class="text-center mb-12">
        <div class="text-5xl mb-4">📰</div>
        <h1 class="text-4xl font-heading text-secondary mb-4">JOIN THE REVOLUTION</h1>
        <p class="text-lg font-serif text-muted-foreground">
          Get weekly training tips, community highlights, and exclusive content delivered to your inbox.
        </p>
      </header>

      <!-- Newsletter Form -->
      <form 
        id="newsletter-form"
        class="p-8 border rounded-lg bg-gray-50"
      >
        <div class="mb-6" style="position:absolute;left:-9999px;" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="mb-6">
          <label for="email" class="block text-sm font-medium mb-2">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-3 border rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
            placeholder="your@email.com"
          />
        </div>

        <div class="mb-6">
          <label for="name" class="block text-sm font-medium mb-2">First Name (optional)</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            class="w-full px-4 py-3 border rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
            placeholder="Your first name"
          />
        </div>

        <div class="mb-6">
          <label class="block text-sm font-medium mb-2">I'm interested in:</label>
          <div class="space-y-2">
            <label class="flex items-center">
              <input type="checkbox" name="interests" value="training" class="mr-2" checked />
              <span>Training Tips & Programming</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="interests" value="community" class="mr-2" checked />
              <span>Community Events & Challenges</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="interests" value="leadership" class="mr-2" />
              <span>Leadership & Crew Development</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="interests" value="products" class="mr-2" />
              <span>New Products & Releases</span>
            </label>
          </div>
        </div>

        <button 
          type="submit" 
          class="w-full px-6 py-3 bg-primary text-white font-medium rounded-md hover:bg-primary/90 transition-colors"
        >
          Subscribe to Newsletter
        </button>
        
        <p class="text-xs text-muted text-center mt-4">
          We respect your privacy. Unsubscribe at any time.
        </p>
      </form>

      <!-- Success Message (hidden by default) -->
      <div id="success-message" class="hidden p-8 border rounded-lg bg-green-50 text-center">
        <div class="text-5xl mb-4">✅</div>
        <h2 class="text-2xl font-bold mb-2">You're Subscribed!</h2>
        <p class="text-muted">
          Check your inbox for a confirmation email. Welcome to the revolution!
        </p>
      </div>

      <!-- What You'll Get -->
      <section class="mt-12">
        <h2 class="text-2xl font-heading text-secondary mb-6 text-center">WHAT YOU'LL GET</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3">💪</div>
            <h3 class="font-heading text-secondary mb-2">TRAINING TIPS</h3>
            <p class="text-sm text-muted-foreground">
              Weekly programming advice, mobility tips, and progressive overload strategies.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3">👥</div>
            <h3 class="font-heading text-secondary mb-2">COMMUNITY UPDATES</h3>
            <p class="text-sm text-muted-foreground">
              News about rucking events, crew challenges, and member successes.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3">📚</div>
            <h3 class="font-heading text-secondary mb-2">EXCLUSIVE CONTENT</h3>
            <p class="text-sm text-muted-foreground">
              Early access to guides, discounts, and member-only resources.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3">🎯</div>
            <h3 class="font-heading text-secondary mb-2">EVENT BRIEFS</h3>
            <p class="text-sm text-muted-foreground">
              Curated insights from field notes and after-action reviews.
            </p>
          </div>
        </div>
      </section>

      <!-- Past Issues Link -->
      <div class="mt-8 text-center">
        <a href="/newsletter/archive" class="text-primary hover:underline">
          View Newsletter Archive →
        </a>
      </div>
    </div>
  </div>

  <script type="module" src="/scripts/newsletter-signup.js" is:inline></script>
</Layout>
