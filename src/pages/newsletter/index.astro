---
import Layout from '@/components/Layout.astro';
---

<Layout 
  title="Newsletter - Rucking Revolution" 
  description="Subscribe to the Rucking Revolution newsletter for training tips, community updates, and exclusive content"
  currentPage="/newsletter"
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">
      <header class="text-center mb-12">
        <div class="text-5xl mb-4" role="img" aria-label="Newspaper">📰</div>
        <h1 class="text-4xl font-heading text-secondary mb-4">JOIN THE MOVEMENT</h1>
        <p class="text-lg font-serif text-muted-foreground">
          Get weekly training tips, community highlights, and exclusive content delivered to your inbox.
        </p>
      </header>

      <!-- Beehiiv Newsletter Embed -->
      <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
      <iframe 
        src="https://subscribe-forms.beehiiv.com/8bd044bf-35a4-4f3a-8da4-cc7808c49496" 
        class="beehiiv-embed" 
        data-test-id="beehiiv-embed" 
        frameborder="0" 
        scrolling="no" 
        style="width: 400px; height: 166px; margin: 0; border-radius: 0px 0px 0px 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>

      <!-- What You'll Get -->
      <section class="mt-12">
        <h2 class="text-2xl font-heading text-secondary mb-6 text-center">WHAT YOU'LL GET</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3" role="img" aria-label="Training">💪</div>
            <h3 class="font-heading text-secondary mb-2">TRAINING TIPS</h3>
            <p class="text-sm text-muted-foreground">
              Programming advice, mobility tips, and progressive overload strategies.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3" role="img" aria-label="Community">👥</div>
            <h3 class="font-heading text-secondary mb-2">COMMUNITY UPDATES</h3>
            <p class="text-sm text-muted-foreground">
              News about rucking events, crew challenges, and member successes.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3" role="img" aria-label="Resources">📚</div>
            <h3 class="font-heading text-secondary mb-2">EXCLUSIVE CONTENT</h3>
            <p class="text-sm text-muted-foreground">
              Early access to guides, discounts, and member-only resources.
            </p>
          </div>
          <div class="p-6 border border-border rounded-lg">
            <div class="text-3xl mb-3" role="img" aria-label="Target">🎯</div>
            <h3 class="font-heading text-secondary mb-2">EVENT BRIEFS</h3>
            <p class="text-sm text-muted-foreground">
              Curated insights from field notes and after-action reviews.
            </p>
          </div>
        </div>
      </section>

      <!-- Past Issues Link -->
      <div class="mt-8 text-center">
        <a href="/newsletter/archive" class="text-primary hover:underline">
          View Newsletter Archive →
        </a>
      </div>
    </div>
  </div>

  </Layout>
