---
export const prerender = false;

import Layout from '@/components/Layout.astro';
import { getAarConfiguration } from '@/lib/aarSubmission';

const aarConfiguration = getAarConfiguration();
const allowPublicSubmissions = aarConfiguration.enabled;

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');
---
<Layout 
  title="Submit AAR | Rucking Revolution"
  description="Submit your After Action Review to contribute to the crew knowledge base."
  noindex={true}
  nofollow={true}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8">
        <a 
          href="/lead/after-action-reviews" 
          class="inline-flex items-center text-primary hover:text-primary/80 font-medium mb-4"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to AAR Overview
        </a>
        <h1 class="text-4xl font-heading text-secondary mb-2">SUBMIT YOUR AAR</h1>
        <p class="text-muted-foreground">
          Document your crew's experience to help others learn from your insights.
        </p>
      </div>

    {allowPublicSubmissions ? (
      <div class="bg-white rounded-lg shadow-md p-6 md:p-8">
        <!-- Success Message (hidden by default) -->
        <div id="success-message" class="hidden mb-8 p-6 bg-green-50 border-l-4 border-green-500 rounded-lg">
          <div class="flex items-center">
            <svg class="w-6 h-6 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-lg font-bold text-green-800">AAR Submitted Successfully!</h3>
              <p class="text-green-700 mt-1">
                Thank you for contributing. Your submission will be reviewed and added to the archive after moderation.
              </p>
            </div>
          </div>
          <button
            id="submit-another-btn"
            type="button"
            class="mt-4 text-sm text-green-700 underline hover:text-green-900"
          >
            Submit another AAR
          </button>
        </div>

        <!-- Error Message (hidden by default) -->
        <div id="error-message" class="hidden mb-8 p-6 bg-red-50 border-l-4 border-red-500 rounded-lg">
          <div class="flex items-center">
            <svg class="w-6 h-6 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-lg font-bold text-red-800">Submission Failed</h3>
              <p id="error-text" class="text-red-700 mt-1">
                There was an error submitting your AAR. Please try again.
              </p>
            </div>
          </div>
        </div>

        <!-- Form -->
        <form 
          id="aar-form" 
          method="POST" 
          action="/api/aar" 
          class="space-y-6"
        >
          <div class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
            <label for="website">Website</label>
            <input
              type="text"
              id="website"
              name="website"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <!-- Event Info -->
          <fieldset class="border border-gray-200 rounded-lg p-6">
            <legend class="text-lg font-bold text-gray-900 px-2">Event Information</legend>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="eventName" class="block text-sm font-medium text-gray-700 mb-2">
                  Event Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="eventName"
                  name="eventName"
                  required
                  placeholder="e.g., Weekend Training Ruck"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
              
              <div>
                <label for="location" class="block text-sm font-medium text-gray-700 mb-2">
                  Location <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="location"
                  name="location"
                  required
                  placeholder="e.g., Blue Ridge Trail, VA"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-3 gap-6 mt-4">
              <div>
                <label for="distance" class="block text-sm font-medium text-gray-700 mb-2">
                  Distance (km) <span class="text-red-500">*</span>
                </label>
                <input
                  type="number"
                  id="distance"
                  name="distance"
                  required
                  min="0.1"
                  step="0.1"
                  placeholder="e.g., 12.5"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
              
              <div>
                <label for="load" class="block text-sm font-medium text-gray-700 mb-2">
                  Load (kg) <span class="text-red-500">*</span>
                </label>
                <input
                  type="number"
                  id="load"
                  name="load"
                  required
                  min="0"
                  step="0.5"
                  placeholder="e.g., 20"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
              
              <div>
                <label for="crewSize" class="block text-sm font-medium text-gray-700 mb-2">
                  Crew Size <span class="text-red-500">*</span>
                </label>
                <input
                  type="number"
                  id="crewSize"
                  name="crewSize"
                  required
                  min="1"
                  placeholder="e.g., 8"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
            </div>

            <div class="mt-4">
              <label for="conditions" class="block text-sm font-medium text-gray-700 mb-2">
                Conditions <span class="text-red-500">*</span>
              </label>
              <textarea
                id="conditions"
                name="conditions"
                rows="2"
                required
                placeholder="e.g., Clear skies, 15°C, dry trails"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
          </fieldset>

          <!-- The AAR Framework -->
          <fieldset class="border border-gray-200 rounded-lg p-6">
            <legend class="text-lg font-bold text-gray-900 px-2">Your Review</legend>
            
            <div class="mb-4">
              <label for="planned" class="block text-sm font-medium text-gray-700 mb-2">
                What was planned? (Objectives) <span class="text-red-500">*</span>
              </label>
              <textarea
                id="planned"
                name="planned"
                rows="3"
                required
                placeholder="List each objective on a new line"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
            
            <div class="mb-4">
              <label for="actual" class="block text-sm font-medium text-gray-700 mb-2">
                What actually happened? <span class="text-red-500">*</span>
              </label>
              <textarea
                id="actual"
                name="actual"
                rows="3"
                required
                placeholder="Describe what really happened, including any deviations from plan"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
            
            <div class="mb-4">
              <label for="whatWentWell" class="block text-sm font-medium text-gray-700 mb-2">
                What went well? <span class="text-red-500">*</span>
              </label>
              <textarea
                id="whatWentWell"
                name="whatWentWell"
                rows="3"
                required
                placeholder="What successes, strengths, or positive outcomes occurred?"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
            
            <div class="mb-4">
              <label for="improvements" class="block text-sm font-medium text-gray-700 mb-2">
                What could be improved? <span class="text-red-500">*</span>
              </label>
              <textarea
                id="improvements"
                name="improvements"
                rows="3"
                required
                placeholder="What gaps, challenges, or areas for development did you notice?"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
            
            <div>
              <label for="lessonsLearned" class="block text-sm font-medium text-gray-700 mb-2">
                Lessons learned <span class="text-red-500">*</span>
              </label>
              <textarea
                id="lessonsLearned"
                name="lessonsLearned"
                rows="3"
                required
                placeholder="What actionable insights can inform future missions?"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              ></textarea>
            </div>
          </fieldset>

          <!-- Author Info -->
          <fieldset class="border border-gray-200 rounded-lg p-6">
            <legend class="text-lg font-bold text-gray-900 px-2">Your Information</legend>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="author" class="block text-sm font-medium text-gray-700 mb-2">
                  Your Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="author"
                  name="author"
                  required
                  placeholder="Your name or crew identifier"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
              
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Email (optional)
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="For follow-up questions"
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
                />
              </div>
            </div>
          </fieldset>

          <fieldset class="border border-gray-200 rounded-lg p-6">
            <legend class="text-lg font-bold text-gray-900 px-2">Verification</legend>
            <p class="text-sm text-gray-600 mb-4">
              Complete the challenge below to keep the archive open to real crews and closed to bots.
            </p>
            <div
              class="cf-turnstile"
              data-sitekey={aarConfiguration.turnstileSiteKey}
              data-action="aar_submission"
            ></div>
          </fieldset>

          <!-- Submit Button -->
          <div class="flex justify-end">
            <button
              type="submit"
              id="submit-btn"
              class="bg-red-800 text-white px-8 py-3 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus:ring-offset-2 transition-colors font-semibold"
            >
              Submit AAR
            </button>
          </div>
        </form>
      </div>
    ) : (
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 text-center">
        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Submissions Currently Disabled</h2>
        <p class="text-gray-600 mb-4">
          Public submissions to the AAR system remain disabled until the moderation webhook and spam controls are configured.
        </p>
        <a 
          href="/lead/after-action-reviews" 
          class="inline-block text-red-800 hover:text-red-900 font-medium"
        >
          Return to AAR Overview
        </a>
      </div>
    )}
  </div>

  {allowPublicSubmissions ? (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  ) : null}
  <script type="module" src="/scripts/aar-submit.js" is:inline></script>
</Layout>
