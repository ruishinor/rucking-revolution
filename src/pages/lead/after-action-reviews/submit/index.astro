---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site';

const allowPublicSubmissions = site.allowPublicSubmissions ?? false;
---
<Layout title="Submit AAR" description="Form to submit after action reviews for community learning">
  {allowPublicSubmissions ? (
    <>
      <h1 class="text-3xl font-bold mb-6">Submit AAR</h1>
      <p>Form to submit after action reviews for community learning</p>
      
      <form method="POST" action="/api/aar" class="space-y-6 max-w-2xl">
        <div>
          <label for="eventName" class="block text-sm font-medium text-gray-700 mb-2">
            Event Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="eventName"
            name="eventName"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>
        
        <div>
          <label for="location" class="block text-sm font-medium text-gray-700 mb-2">
            Location <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="location"
            name="location"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>
        
        <div>
          <label for="distance" class="block text-sm font-medium text-gray-700 mb-2">
            Distance (km) <span class="text-red-500">*</span>
          </label>
          <input
            type="number"
            id="distance"
            name="distance"
            required
            min="0.1"
            step="0.1"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>
        
        <div>
          <label for="conditions" class="block text-sm font-medium text-gray-700 mb-2">
            Conditions <span class="text-red-500">*</span>
          </label>
          <textarea
            id="conditions"
            name="conditions"
            rows="3"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="crewSize" class="block text-sm font-medium text-gray-700 mb-2">
            Crew Size <span class="text-red-500">*</span>
          </label>
          <input
            type="number"
            id="crewSize"
            name="crewSize"
            required
            min="1"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>
        
        <div>
          <label for="planned" class="block text-sm font-medium text-gray-700 mb-2">
            What was planned? (Objectives) <span class="text-red-500">*</span>
          </label>
          <textarea
            id="planned"
            name="planned"
            rows="4"
            required
            placeholder="Enter each objective on a new line"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="actual" class="block text-sm font-medium text-gray-700 mb-2">
            What actually happened? <span class="text-red-500">*</span>
          </label>
          <textarea
            id="actual"
            name="actual"
            rows="4"
            required
            placeholder="Enter what actually happened on a new line"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="whatWentWell" class="block text-sm font-medium text-gray-700 mb-2">
            What went well? <span class="text-red-500">*</span>
          </label>
          <textarea
            id="whatWentWell"
            name="whatWentWell"
            rows="4"
            required
            placeholder="Enter what went well on a new line"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="improvements" class="block text-sm font-medium text-gray-700 mb-2">
            What could be improved? <span class="text-red-500">*</span>
          </label>
          <textarea
            id="improvements"
            name="improvements"
            rows="4"
            required
            placeholder="Enter improvements on a new line"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="lessonsLearned" class="block text-sm font-medium text-gray-700 mb-2">
            Lessons learned <span class="text-red-500">*</span>
          </label>
          <textarea
            id="lessonsLearned"
            name="lessonsLearned"
            rows="4"
            required
            placeholder="Enter lessons learned on a new line"
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          ></textarea>
        </div>
        
        <div>
          <label for="author" class="block text-sm font-medium text-gray-700 mb-2">
            Your Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="author"
            name="author"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>
        
        <div class="flex justify-end">
          <button
            type="submit"
            class="bg-red-800 text-white px-6 py-2 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus:ring-offset-2 transition-colors"
          >
            Submit AAR
          </button>
        </div>
      </form>
    </>
  ) : (
    <p class="text-red-600">Public submissions are currently disabled by the site administrator.</p>
  )}
</Layout>
