---
import Layout from '@/components/Layout.astro';
import { aarEntries } from '@/data/aar';
import { site } from '@/data/site';

const approvedAARs = aarEntries.filter(aar => aar.approved);
---
<Layout title="AAR Archive" description="Searchable archive of community reflections">
  <h1 class="text-3xl font-bold mb-6">AAR Archive</h1>
  <p>Searchable archive of community reflections</p>
  
  {approvedAARs.length > 0 ? (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {approvedAARs.map((aar) => (
        <div key={aar.id} class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-red-800">{aar.title}</h3>
            <p class="text-gray-600 mb-4">{aar.date}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{aar.location || 'Location not specified'}</span>
              <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{aar.distance} km</span>
              <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{aar.load} kg</span>
              <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{aar.participants} people</span>
            </div>
            <p class="text-gray-700 mb-4">{aar.conditions}</p>
            <a 
              href={`/lead/after-action-reviews/${aar.id}`}
              class="block w-full text-center bg-red-800 text-white px-4 py-2 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus-ring-offset-2 transition-colors"
            >
              View Details
            </a>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <p class="text-gray-600">No approved AARs available yet.</p>
  )}
</Layout>
