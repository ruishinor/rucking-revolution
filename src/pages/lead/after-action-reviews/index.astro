---
import Layout from '@/components/Layout.astro';
import { aarEntries } from '@/data/aar';
import { site } from '@/data/site';

const approvedAARs = aarEntries.filter(aar => aar.approved);
const hasAARs = approvedAARs.length > 0;
const allowPublicSubmissions = site.allowPublicSubmissions ?? false;
---
<Layout 
  title="After Action Reviews | Rucking Revolution"
  description="Learn from every mission through structured reflection. The AAR system helps ruck crews improve through systematic analysis of what worked, what didn't, and why."
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">AFTER ACTION REVIEWS</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Learn from every mission through structured reflection. Turn field experience into organizational knowledge.
        </p>
      </div>

    <!-- What is an AAR Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is an After Action Review?</h2>
      <div class="bg-gray-50 rounded-lg p-6 border-l-4 border-red-800">
        <p class="text-gray-700 mb-4">
          An After Action Review (AAR) is a structured debrief process originally developed by the military to capture lessons learned from every operation. It's a candid, blameless examination of what was planned, what actually happened, what went well, what could be improved, and the lessons learned.
        </p>
        <p class="text-gray-700">
          For ruck crews, AARs transform individual experiences into collective wisdom. Every trek, training event, or mission becomes an opportunity for the entire crew to get better.
        </p>
      </div>
    </section>

    <!-- The AAR Framework -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">The AAR Framework</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Step 1 -->
        <div class="bg-white rounded-lg shadow-md p-6 border-t-4 border-red-800">
          <h3 class="text-lg font-bold text-red-800 mb-3">1. What Was Planned</h3>
          <p class="text-gray-600">
            Define the objectives, route, load standards, and expected conditions. What was the mission intended to accomplish?
          </p>
        </div>

        <!-- Step 2 -->
        <div class="bg-white rounded-lg shadow-md p-6 border-t-4 border-red-800">
          <h3 class="text-lg font-bold text-red-800 mb-3">2. What Actually Happened</h3>
          <p class="text-gray-600">
            Document the real events without judgment. Include deviations from plan, unexpected challenges, and surprises—both good and bad.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="bg-white rounded-lg shadow-md p-6 border-t-4 border-red-800">
          <h3 class="text-lg font-bold text-red-800 mb-3">3. What Went Well</h3>
          <p class="text-gray-600">
            Identify successes and strengths. What tactics, equipment, or team behaviors contributed to a successful mission?
          </p>
        </div>

        <!-- Step 4 -->
        <div class="bg-white rounded-lg shadow-md p-6 border-t-4 border-red-800">
          <h3 class="text-lg font-bold text-red-800 mb-3">4. What Could Be Improved</h3>
          <p class="text-gray-600">
            Note areas for development. Be specific about gaps in preparation, equipment, communication, or execution.
          </p>
        </div>
      </div>

      <!-- Step 5 - Full Width -->
      <div class="mt-6 bg-white rounded-lg shadow-md p-6 border-t-4 border-red-800">
        <h3 class="text-lg font-bold text-red-800 mb-3">5. Lessons Learned</h3>
        <p class="text-gray-600">
          Extract actionable insights that can inform future missions. The most valuable lessons often come from challenges and failures—embrace them as growth opportunities.
        </p>
      </div>
    </section>

    <!-- Why Crews Should Do AARs -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Why Your Crew Should Conduct AARs</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Accelerate Learning</h3>
          <p class="text-gray-600 text-sm">Turn individual experience into collective knowledge in weeks instead of years.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Build Team Culture</h3>
          <p class="text-gray-600 text-sm">Create a learning mindset where everyone contributes to collective improvement.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Improve Future Missions</h3>
          <p class="text-gray-600 text-sm">Apply specific insights to prevent repeat mistakes and replicate successes.</p>
        </div>
      </div>
    </section>

    <!-- Reflection Prompts -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Quick Reflection Prompts</h2>
      <div class="bg-gray-50 rounded-lg p-6">
        <p class="text-gray-700 mb-4">After every ruck, ask yourself (or your crew):</p>
        <ul class="grid md:grid-cols-2 gap-4">
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">What was the hardest part of today's ruck?</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">What piece of gear performed best/worst?</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">How did the team communicate under pressure?</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">What would you do differently next time?</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">Did everyone maintain proper load distribution?</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-800 mr-2">•</span>
            <span class="text-gray-700">What condition surprised you most?</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Take Action</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Submit AAR -->
        <div class="bg-red-800 rounded-lg p-6 text-white">
          <h3 class="text-xl font-bold mb-3">Submit Your AAR</h3>
          <p class="text-red-100 mb-4">
            Document your crew's experience and contribute to the collective knowledge base.
          </p>
          {allowPublicSubmissions ? (
            <a 
              href="/lead/after-action-reviews/submit"
              class="inline-block bg-white text-red-800 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors"
            >
              Submit an AAR
            </a>
          ) : (
            <p class="text-red-200 text-sm">Public submissions are currently disabled.</p>
          )}
        </div>

        <!-- Browse Archive -->
        <div class="bg-gray-100 rounded-lg p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Browse the Archive</h3>
          <p class="text-gray-600 mb-4">
            Learn from {approvedAARs.length} approved After Action Reviews from crews across the network.
          </p>
          {hasAARs ? (
            <a 
              href="/lead/after-action-reviews/archive"
              class="inline-block bg-red-800 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-900 transition-colors"
            >
              View Archive ({approvedAARs.length} entries)
            </a>
          ) : (
            <p class="text-gray-500 text-sm">No AARs available yet.</p>
          )}
        </div>
      </div>
    </section>

    <!-- Back to Lead -->
    <nav class="text-center">
      <a 
        href="/lead" 
        class="inline-flex items-center text-red-800 hover:text-red-900 font-medium"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Leadership & Crews
      </a>
    </nav>
    </div>
  </div>
</Layout>
