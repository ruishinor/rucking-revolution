---
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';
---
<Layout title="Lead - Rucking Revolution" description="Movement infrastructure: CrewTactics, Ruck Clubs, After Action Reviews">
  <Container>
    <header class="mb-12 text-center">
      <h1 class="text-4xl font-bold mb-4">Lead</h1>
      <p class="text-xl text-muted">
        Movement infrastructure: CrewTactics, Ruck Clubs, After Action Reviews
      </p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold mb-6">Leadership & Community</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/lead/crew-tactics" class="block p-6 border rounded-lg hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold mb-2">CrewTactics</h3>
          <p class="text-muted">
            Leadership tactic cards and generator for rucks.
          </p>
        </a>
        <a href="/lead/ruck-clubs" class="block p-6 border rounded-lg hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold mb-2">Ruck Clubs</h3>
          <p class="text-muted">
            Resources for starting and running ruck crews.
          </p>
        </a>
        <a href="/lead/after-action-reviews" class="block p-6 border rounded-lg hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold mb-2">After Action Reviews</h3>
          <p class="text-muted">
            Community reflections and lessons learned.
          </p>
        </a>
      </div>
    </section>
  </Container>
</Layout>
