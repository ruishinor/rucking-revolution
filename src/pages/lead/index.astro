---
import Layout from '@/components/Layout.astro';
const SHOW_CREW_TACTICS = import.meta.env.PUBLIC_SHOW_CREW_TACTICS === 'true';
---
<Layout title="Lead - Rucking Revolution" description="Leadership, crew tactics, and community building for rucking." currentPage="/lead">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">LEAD</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Develop leadership skills through rucking, build community and learn to lead crews. Your journey from participant to community asset starts here.
        </p>
      </div>

      <section class="mb-12">
        <h2 class="text-2xl font-heading text-secondary mb-6">LEADERSHIP & COMMUNITY</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <a href="/lead/ruck-clubs" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">RUCK CLUBS</h3>
            <p class="text-muted-foreground text-sm">
              Resources for starting and running ruck crews.
            </p>
          </a>
          {SHOW_CREW_TACTICS && (
            <a href="/lead/crew-tactics" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
              <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">CREW TACTICS</h3>
              <p class="text-muted-foreground text-sm">
                Leadership tactic cards and generator for rucks.
              </p>
            </a>
          )}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-heading text-secondary mb-6">SOCIAL MEDIA</h2>
        <div class="grid gap-6 md:grid-cols-1">
          <a href="/lead/ruck-clubs-on-social-media" class="block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">RUCK CLUBS ON SOCIAL MEDIA</h3>
            <p class="text-muted-foreground text-sm">
              Find ruck clubs and communities on Facebook, Instagram, and other platforms.
            </p>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
