---
import Layout from '@/components/Layout.astro';
import CardGenerator from '@/components/CardGenerator.astro';
---
<Layout title="CrewTactics Generator" description="Interactive generator to draw tactics during rucks">
  <h1 class="text-3xl font-bold mb-6">CrewTactics Generator</h1>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <p class="mb-6 text-lg text-gray-600 dark:text-gray-400">
      Draw tactics to practice during your rucks. Each card presents a leadership or communication exercise with reflection prompts.
    </p>
    <CardGenerator />
  </div>
</Layout>
