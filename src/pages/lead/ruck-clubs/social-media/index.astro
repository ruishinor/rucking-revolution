---
import Layout from '@/components/Layout.astro';
import Pill from '@/components/Pill.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import { site } from '@/data/site';

const socialPlatforms = [
  {
    name: 'Facebook',
    icon: '📘',
    examples: [
      { name: 'Rucking (Facebook Group)', url: 'https://www.facebook.com/groups/rucking' },
      { name: 'GORUCK (Official)', url: 'https://www.facebook.com/goruck' },
      { name: 'Rucking Revolution', url: 'https://www.facebook.com/ruckingrevolution' },
    ]
  },
  {
    name: 'Instagram',
    icon: '📸',
    examples: [
      { name: '@goruckeurope', url: 'https://www.instagram.com/goruckeurope' },
      { name: '@ruckingrevolution', url: 'https://www.instagram.com/ruckingrevolution' },
      { name: '@polarisruckingcrew', url: 'https://www.instagram.com/gorucknation' },
    ]
  },
  {
    name: 'YouTube',
    icon: '▶️',
    examples: [
      { name: 'GORUCK Official', url: 'https://www.youtube.com/user/goruck' },
      { name: 'Rucking Revolution', url: 'https://www.youtube.com/@ruckingrevolution' },
    ]
  },
  {
    name: 'Strava',
    icon: '🏃',
    examples: [
      { name: 'Rucking Club (Search)', url: 'https://www.strava.com/clubs/search?query=rucking' },
    ]
  },
];
---

<Layout title="Ruck Clubs on Social Media" description="Find and connect with ruck clubs and communities on social media platforms" canonicalUrl={`${site.baseUrl}/lead/ruck-clubs/social-media`}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <nav class="mb-6">
      <a href="/lead/ruck-clubs" class="text-primary hover:underline text-sm">← Back to Ruck Clubs</a>
    </nav>

    <div class="mb-8">
      <span class="section-marker">///</span>
      <h1 class="text-3xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded inline-block">Ruck Clubs on Social Media</h1>
      <p class="text-muted-foreground mt-3">Find and connect with active ruck clubs and communities across all major social platforms.</p>
    </div>

    <!-- Platform Pills Navigation -->
    <div class="flex flex-wrap gap-3 mb-8" role="list" aria-label="Social media platforms">
      {socialPlatforms.map((platform) => (
        <div role="listitem">
          <Pill 
            href={`#${platform.name.toLowerCase()}`} 
            label={`${platform.icon} ${platform.name}`} 
            ariaLabel={`Jump to ${platform.name} section`} 
          />
        </div>
      ))}
    </div>

    <!-- Platform Sections -->
    {socialPlatforms.map((platform) => (
      <section id={platform.name.toLowerCase()} class="mb-12">
        <h2 class="text-2xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded mb-6">{platform.icon} {platform.name}</h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {platform.examples.map((example) => (
            <a 
              href={example.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-4 border border-border rounded-lg hover:border-primary hover:shadow-md transition-all flex items-center gap-3 group"
            >
              <span class="text-2xl">{platform.icon}</span>
              <div>
                <span class="text-primary font-medium group-hover:underline">{example.name}</span>
                <p class="text-xs text-muted-foreground mt-1">Visit on {platform.name}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-auto text-muted-foreground group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- Submit Your Club CTA -->
    <div class="bg-[#8a1e1e] text-white rounded-lg p-8 text-center">
      <h2 class="text-2xl font-heading mb-4">Want us to include yours?</h2>
      <p class="mb-6 text-white/90 max-w-2xl mx-auto">
        Run or represent a ruck club on social media? We'd love to add you to our list and help you connect with the rucking community.
      </p>
      <a 
        href="mailto:info@ruckingrevolution.org?subject=Add%20My%20Ruck%20Club%20to%20Social%20Media%20List&body=Hi,%0D%0A%0D%0AI%20run%20or%20represent%20a%20ruck%20club%20on%20social%20media%20and%20would%20like%20to%20be%20included%20on%20your%20list.%0D%0A%0D%0AClub%20Name:%0D%0ASocial%20Media%20Links:%0D%0ALocation:%0D%0AContact%20Info:%0D%0A%0D%0AThanks!"
        class="btn bg-white text-[#8a1e1e] hover:bg-white/90 font-semibold px-6 py-3 rounded-md inline-flex items-center gap-2 transition-colors"
        rel="noopener noreferrer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Tell us about your club
      </a>
    </div>

    <!-- Share Buttons -->
    <div class="mt-8 bg-muted-50 rounded-lg p-6">
      <h2 class="font-heading text-secondary mb-4 bg-[#8a1e1e] text-white px-3 py-2 rounded">Share This Page</h2>
      <ShareButtons url={`${site.baseUrl}/lead/ruck-clubs/social-media`} title="Ruck Clubs on Social Media" />
    </div>
  </div>
</Layout>
