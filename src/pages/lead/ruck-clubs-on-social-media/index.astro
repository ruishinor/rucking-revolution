---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site';
---

<Layout title="Ruck Clubs on Social Media" description="Examples of active ruck clubs and communities on major social platforms" canonicalUrl={`${site.baseUrl}/lead/ruck-clubs-on-social-media`}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-6">
      <span class="section-marker">///</span>
      <h1 class="text-3xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded inline-block">Ruck Clubs on Social Media</h1>
      <p class="text-muted-foreground mt-3">A short list of active communities and examples to follow.</p>
    </div>

    <section class="mb-8">
      <h2 class="text-xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded inline-block mb-3">Facebook</h2>
      <p class="text-sm text-muted-foreground mb-2">Example group:</p>
      <a href="https://www.facebook.com/groups/rucking" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Rucking (Facebook Group)</a>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded inline-block mb-3">Instagram</h2>
      <p class="text-sm text-muted-foreground mb-2">Example account:</p>
      <a href="https://www.instagram.com/goruckeurope" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">@goruckeurope</a>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading text-secondary bg-[#8a1e1e] text-white px-3 py-2 rounded inline-block mb-3">YouTube</h2>
      <p class="text-sm text-muted-foreground mb-2">Example channel:</p>
      <a href="https://www.youtube.com/user/goruck" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GORUCK Official</a>
    </section>

    <div class="mt-8">
      <a href="mailto:info@ruckingrevolution.org?subject=Add%20My%20Ruck%20Club%20to%20Ruck%20Clubs%20List&body=Hi,%0D%0A%0D%0AI%20run%20or%20represent%20a%20ruck%20club%20and%20would%20like%20to%20be%20included%20on%20your%20Ruck%20Clubs%20page.%0D%0A%0D%0AName:%0D%0ALink:%0D%0ALocation:%0D%0AContact%20info:%0D%0A%0D%0AThanks!" class="btn btn-secondary" rel="noopener noreferrer">Want us to include yours? Tell us</a>
    </div>
  </div>
</Layout>
