---
import { site } from '@/data/site';
import { articles } from '@/data/articles';
import Layout from '@/components/Layout.astro';
import Card from '@/components/Card.astro';
import Container from '@/components/Container.astro';
import { existsSync } from 'node:fs';

const publicAssetExists = (assetPath) =>
  existsSync(new URL(`../../../../../public${assetPath}`, import.meta.url));

// Get all unique tags from articles
export const allTags = [...new Set(articles.flatMap(article => article.tags))];

export async function getStaticPaths() {
  return allTags.map(tag => ({
    params: { tag }
  }));
}

// Get the tag from URL params
const { tag } = Astro.params;
const currentTag = tag;

// Validate tag exists
if (!currentTag || !allTags.includes(currentTag)) {
  return Astro.redirect('/articles');
}

// Filter articles by tag
const filteredArticles = articles.filter(article => article.tags.includes(currentTag));

// Sort articles by date (newest first)
const sortedArticles = [...filteredArticles].sort((a, b) => 
  new Date(b.date).getTime() - new Date(a.date).getTime()
);

const pageSize = 6;
const totalPages = Math.max(1, Math.ceil(sortedArticles.length / pageSize));
const currentPage = 1;

const paginatedArticles = sortedArticles.slice(
  (currentPage - 1) * pageSize,
  currentPage * pageSize
);

const articleCards = paginatedArticles.map((article) => ({
  ...article,
  hasHeroImage: publicAssetExists(article.heroImage.src),
}));

// Generate pagination links
const generatePaginationLinks = (basePath) => {
  const links = [];
  if (currentPage > 1) {
    links.push({ label: 'Previous', href: `${basePath}/${currentPage - 1}` });
  }
  for (let i = 1; i <= totalPages; i++) {
    links.push({ 
      label: i.toString(), 
      href: i === 1 ? basePath : `${basePath}/${i}`, 
      active: i === currentPage 
    });
  }
  if (currentPage < totalPages) {
    links.push({ label: 'Next', href: `${basePath}/${currentPage + 1}` });
  }
  return links;
};

const basePath = `/articles/tag/${currentTag}`;

// Format tag for display
const displayTag = currentTag.split('-').map(word => 
  word.charAt(0).toUpperCase() + word.slice(1)
).join(' ');

const pageTitle = `${displayTag} Articles - Rucking Revolution`;
const pageDescription = `Explore our collection of ${displayTag.toLowerCase()} articles on rucking, leadership, and community resilience.`;
---
<Layout 
  title={pageTitle}
  description={pageDescription}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/articles/tag/${currentTag}`,
    image: `${site.baseUrl}/og-articles.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <Container>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-center">{displayTag} Articles</h1>
      <p class="text-center text-muted mt-2">
        Explore our collection of articles tagged with {displayTag.toLowerCase()}.
      </p>
      <p class="text-center text-muted-foreground mt-2">
        {sortedArticles.length} article{sortedArticles.length !== 1 ? 's' : ''} found
      </p>
      <a href="/articles" class="block text-center mt-4 text-primary hover:underline">
        ← Back to All Articles
      </a>
    </header>

    {/* Category Filters */}
    <div class="mb-6 flex flex-wrap gap-2 justify-center">
      <a 
        href="/articles" 
        class={`px-3 py-1 rounded text-sm font-medium 
          ${currentTag === null ? 'bg-primary text-white' : 'bg-muted-200 text-muted-foreground hover:bg-muted-300'}`}
      >
        All
      </a>
      {allTags.map(t => (
        <a 
          key={t}
          href={`/articles/tag/${t}`} 
          class={`px-3 py-1 rounded text-sm font-medium 
            ${currentTag === t ? 'bg-primary text-white' : 'bg-muted-200 text-muted-foreground hover:bg-muted-300'}`}
        >
          {t.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
        </a>
      ))}
    </div>

    {/* Articles Grid */}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articleCards.map(article => (
        <article 
          key={article.id} 
          class="hover:shadow-lg transition-shadow flex flex-col h-full"
        >
          {/* Hero Image - show only if exists */}
          {article.hasHeroImage ? (
            <a href={`/articles/${article.slug}`} class="mb-4">
              <img 
                src={article.heroImage.src} 
                alt={article.heroImage.alt} 
                class="w-full h-48 object-cover rounded-t-lg"
                loading="lazy"
              />
            </a>
          ) : (
            <a href={`/articles/${article.slug}`} class="mb-4 block">
              <div class="w-full h-48 bg-muted-200 rounded-t-lg flex items-center justify-center">
                <span class="text-muted-foreground text-sm">Article image</span>
              </div>
            </a>
          )}
          
          {/* Article Content */}
          <div class="flex-0 p-4">
            <h2 class="text-xl font-semibold mb-2 line-clamp-2">
              <a href={`/articles/${article.slug}`} class="hover:underline">
                {article.title}
              </a>
            </h2>
            <p class="text-muted-foreground mb-2 line-clamp-3">{article.excerpt}</p>
            
            {/* Meta Info */}
            <div class="flex flex-wrap gap-3 text-xs text-muted-foreground mt-auto">
              <span>By {article.author}</span>
              <span>
                <time dateTime={article.date}>
                  {new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </span>
              <span>{article.readingTime} min read</span>
            </div>
          </div>
        </article>
      ))}
      
      {/* Empty State */}
      {paginatedArticles.length === 0 && (
        <div class="col-span-full text-center py-12">
          <p class="text-muted-foreground">No articles found for this category.</p>
          <a href="/articles" class="mt-4 inline-block text-primary hover:underline">
            Browse All Articles
          </a>
        </div>
      )}
    </div>

    {/* Pagination */}
    {totalPages > 1 && (
      <div class="mt-8 flex justify-center gap-2">
        {generatePaginationLinks(basePath).map(link => (
          <a 
            key={link.href} 
            href={link.href} 
            class={`px-4 py-2 rounded 
              ${link.active ? 'bg-primary text-white' : 'bg-muted-200 text-muted-foreground hover:bg-muted-300'}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    )}
  </Container>
</Layout>
