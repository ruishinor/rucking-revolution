---
import { site } from '@/data/site';
import { routes } from '@/data/routes';
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

// Get the slug from params
const { slug } = Astro.params;

// Find the route with matching slug
const route = routes.find((item) => item.slug === slug);

if (!route) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  return routes.map((item) => ({
    params: { slug: item.slug },
    props: { route: item }
  }));
}
---
<Layout>
  <meta name="title" content={`${route.title} - Rucking Revolution`} />
  <meta name="description" content={route.description} />
  <meta property="og:title" content={`${route.title} - Rucking Revolution`} />
  <meta property="og:description" content={route.description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${site.baseUrl}/routes/${route.slug}`} />
  <meta property="og:image" content={`${site.baseUrl}${route.heroImage.src}`} />
  <meta name="twitter:card" content="summary_large_image" />

  <Container>
    <header class="mb-8">
      <div class="flex items-center space-x-4">
        <a href="/routes" class="text-sm text-muted-foreground hover:underline">Back to Routes</a>
        <h1 class="text-3xl font-bold">{route.title}</h1>
      </div>
      <p class="mt-2 text-muted-foreground">{route.description}</p>
    </header>

    <div class="grid gap-8 md:grid-cols-2">
      <div class="overflow-hidden rounded-lg shadow-lg">
        <img
          src={route.heroImage.src}
          alt={route.heroImage.alt}
          class="h-48 w-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="space-y-4">
        <div class="space-y-2">
          <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
            <span>Distance: {route.distance} km</span>
            <span>Estimated Time: {route.estimatedTime}</span>
            <span>
              Difficulty:
              {route.difficulty === 'beginner'
                ? 'Beginner'
                : route.difficulty === 'intermediate'
                  ? 'Intermediate'
                  : 'Advanced'}
            </span>
          </div>
          <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
            <span>Elevation Gain: {route.elevationGain} m</span>
            <span>Load Recommendation: {route.loadRecommendation} kg</span>
            <span>Best Season: {route.bestSeason.map((season) => season.charAt(0).toUpperCase() + season.slice(1)).join(', ')}</span>
          </div>
          <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
            <span>Terrain: {route.terrain.map((terrain) => terrain.charAt(0).toUpperCase() + terrain.slice(1)).join(', ')}</span>
          </div>
        </div>

        {route.notes && (
          <div class="rounded-lg border border-muted-200 bg-muted-50 p-4">
            <h3 class="mb-2 font-semibold">Notes</h3>
            <p class="text-muted-foreground">{route.notes}</p>
          </div>
        )}

        <div>
          <h3 class="mb-2 font-semibold">Waypoints</h3>
          <div class="space-y-3">
            {route.waypoints.map((waypoint, index) => (
              <div key={index} class="border-l-2 border-primary pl-3">
                <h4 class="font-medium">{waypoint.name}</h4>
                <p class="text-sm text-muted-foreground">{waypoint.distanceFromStart} km from start</p>
                <p class="text-muted-foreground">{waypoint.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-2xl font-semibold">Route Map</h2>
      <div class="flex aspect-video items-center justify-center rounded-lg bg-muted-200">
        <span class="italic text-muted-foreground">Map placeholder - Interactive map would be integrated here</span>
      </div>
    </section>
  </Container>
</Layout>
