---
import { site } from '@/data/site';
import { routes } from '@/data/routes';
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

// Get the slug from params
const { slug } = Astro.params;

// Find the route with matching slug
const route = routes.find((item) => item.slug === slug);

if (!route) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  return routes.map((item) => ({
    params: { slug: item.slug },
    props: { route: item }
  }));
}

const pageTitle = `${route.title} - Rucking Revolution`;
---
<Layout 
  title={pageTitle}
  description={route.description}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/routes/${route.slug}`,
    image: `${site.baseUrl}${route.heroImage.src}`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6">
        <a href="/routes" class="text-sm text-muted-foreground hover:underline">← Back to Routes</a>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl font-heading text-secondary mb-4">{route.title.toUpperCase()}</h1>
        <p class="text-lg font-serif text-muted-foreground">{route.description}</p>
      </header>

      <div class="grid gap-8 md:grid-cols-2">
        <figure class="overflow-hidden rounded-lg shadow-lg">
          <img
            src={route.heroImage.src}
            alt={route.heroImage.alt}
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </figure>

        <div class="space-y-4">
          <div class="space-y-2 text-sm font-mono text-muted-foreground">
            <div class="flex flex-wrap gap-4">
              <span>DIST: {route.distance} km ({(route.distance * 0.621371).toFixed(1)} mi)</span>
              <span>TIME: {route.estimatedTime}</span>
              <span>DIFF: {route.difficulty === 'beginner' ? 'BEGINNER' : route.difficulty === 'intermediate' ? 'INTERMEDIATE' : 'ADVANCED'}</span>
            </div>
            <div class="flex flex-wrap gap-4">
              <span>ELEV: {route.elevationGain} m ({(route.elevationGain * 3.28084).toFixed(0)} ft)</span>
              <span>LOAD: {route.loadRecommendation} kg ({(route.loadRecommendation * 2.20462).toFixed(1)} lb)</span>
              <span>SEASON: {route.bestSeason.map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(', ')}</span>
            </div>
            <div class="flex flex-wrap gap-4">
              <span>TERRAIN: {route.terrain.map((t) => t.charAt(0).toUpperCase() + t.slice(1)).join(', ')}</span>
            </div>
          </div>

          {route.notes && (
            <div class="rounded-lg border border-muted-200 bg-muted-50 p-4">
              <h3 class="font-heading text-secondary mb-2">NOTES</h3>
              <p class="text-muted-foreground text-sm">{route.notes}</p>
            </div>
          )}

          <div>
            <h3 class="font-heading text-secondary mb-3">WAYPOINTS</h3>
            <div class="space-y-3">
              {route.waypoints.map((waypoint, index) => (
                <div key={index} class="border-l-2 border-primary pl-3">
                  <h4 class="font-medium">{waypoint.name}</h4>
                  <p class="text-sm font-mono text-muted-foreground">{waypoint.distanceFromStart} km ({(waypoint.distanceFromStart * 0.621371).toFixed(1)} mi) from start</p>
                  <p class="text-sm text-muted-foreground">{waypoint.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <section class="mt-8">
        <h2 class="font-heading text-secondary mb-4">ROUTE MAP</h2>
        <div class="flex aspect-video items-center justify-center rounded-lg bg-muted-200">
          <span class="italic text-muted-foreground">Map placeholder - Interactive map would be integrated here</span>
        </div>
      </section>
    </div>
  </div>
</Layout>
