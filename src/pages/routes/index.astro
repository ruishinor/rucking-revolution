---
import { site } from '@/data/site';
import { routes } from '@/data/routes';
import Layout from '@/components/Layout.astro';

const pageTitle = 'Routes - Rucking Revolution';
const pageDescription = 'Explore our curated rucking routes with detailed metadata.';
---
<Layout 
  title={pageTitle}
  description={pageDescription}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/routes`,
    image: `${site.baseUrl}/og-routes.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">ROUTES</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Explore our curated rucking routes with detailed metadata.
        </p>
      </div>

      {/* Routes Grid */}
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {routes.map(route => (
          <article
            key={route.id}
            class="card-border flex flex-col h-full border border-border hover:border-primary transition-colors"
          >
            {/* Hero Image */}
            <a href={`/routes/${route.slug}`} class="mb-0">
              <img
                src={route.heroImage.src}
                alt={route.heroImage.alt}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            </a>

            {/* Route Content */}
            <div class="flex-0 p-4">
              <h2 class="text-xl font-heading text-secondary mb-2 line-clamp-2">
                <a href={`/routes/${route.slug}`} class="hover:underline">
                  {route.title}
                </a>
              </h2>
              <p class="text-muted-foreground mb-2 line-clamp-3 text-sm">{route.description}</p>

              {/* Metadata */}
              <div class="mt-auto space-y-2 text-sm">
                <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
                  <span>DIST: {route.distance} KM</span>
                  <span>ELEV: {route.elevationGain} M</span>
                </div>
                <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
                  <span>TERRAIN: {route.terrain.map(t => t.charAt(0).toUpperCase() + t.slice(1)).join(', ')}</span>
                </div>
                <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
                  <span>DIFF: {route.difficulty === 'beginner' ? 'BEGINNER' : 
                   route.difficulty === 'intermediate' ? 'INTERMEDIATE' : 'ADVANCED'}</span>
                  <span>TIME: {route.estimatedTime}</span>
                  <span>LOAD: {route.loadRecommendation} KG</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
