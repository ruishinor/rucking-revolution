---
import { site } from '@/data/site';
import { events } from '@/data/events';
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

export async function getStaticPaths() {
  return events.map(event => ({
    params: { slug: event.slug },
    props: { event }
  }));
}

// Get the slug from params
const { slug } = Astro.params;

// Find the event with matching slug
const event = events.find(e => e.slug === slug);

// If event not found, redirect to 404
if (!event) {
  return Astro.redirect('/404');
}

const pageTitle = `${event.title} - Rucking Revolution`;
---
<Layout 
  title={pageTitle}
  description={event.description}
  currentPage={`/events/${event.slug}`}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/events/${event.slug}`,
    image: `${site.baseUrl}${event.heroImage.src}`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6">
        <a href="/events" class="text-sm text-muted-foreground hover:underline">← Back to Events</a>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl font-heading text-secondary mb-4">{event.title.toUpperCase()}</h1>
        <p class="text-lg font-serif text-muted-foreground">{event.description}</p>
      </header>

      <div class="grid gap-8 md:grid-cols-2">
        <figure class="rounded-lg overflow-hidden shadow-lg">
          <img
            src={event.heroImage.src}
            alt={event.heroImage.alt}
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </figure>

        <div class="space-y-4">
          <div class="space-y-2 text-sm font-mono text-muted-foreground">
            <div class="flex flex-wrap gap-4">
              <span>DATE: {new Date(event.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>LOC: {event.location}</span>
              <span>DUR: {event.duration}</span>
            </div>
            <div class="flex flex-wrap gap-4">
              <span>DIST: {event.distance} km ({(event.distance * 0.621371).toFixed(1)} mi)</span>
              <span>LOAD: {event.load} kg ({(event.load * 2.20462).toFixed(1)} lb)</span>
              <span>DIFF: {event.difficulty === 'beginner' ? 'BEGINNER' : event.difficulty === 'intermediate' ? 'INTERMEDIATE' : 'ADVANCED'}</span>
            </div>
            <div class="flex flex-wrap gap-4">
              <span>PRICE: €{event.priceEUR.toFixed(2)}</span>
              <span>MAX: {event.maxParticipants} participants</span>
            </div>
          </div>

          <div>
            <h3 class="font-heading text-secondary mb-2">INCLUDES</h3>
            <ul class="list-disc list-inside space-y-1 text-sm text-muted-foreground">
              {event.includes.map((item, index) => (
                <li key={index}>{item}</li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="font-heading text-secondary mb-2">REQUIREMENTS</h3>
            <ul class="list-disc list-inside space-y-1 text-sm text-muted-foreground">
              {event.requirements.map((req, index) => (
                <li key={index}>{req}</li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="font-heading text-secondary mb-2">AGENDA</h3>
            <div class="space-y-2">
              {event.agenda.map((item, index) => (
                <div key={index} class="border-l-2 border-primary pl-3">
                  <span class="font-medium">{item.time}</span>
                  <span class="ml-2 text-sm text-muted-foreground">{item.activity}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <section class="mt-8">
        <h2 class="font-heading text-secondary mb-4">EVENT PLAN TEMPLATE</h2>
        <p class="text-muted-foreground mb-4">
          Download our comprehensive event plan template to help you organize your own rucking event.
        </p>
        <a
          href="/templates/event-plan-template.pdf"
          class="btn btn-primary"
        >
          DOWNLOAD EVENT PLAN TEMPLATE (PDF)
        </a>
      </section>
    </div>
  </div>
</Layout>