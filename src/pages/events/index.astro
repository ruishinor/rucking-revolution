---
import { site } from '@/data/site';
import { events } from '@/data/events';
import Layout from '@/components/Layout.astro';

const pageTitle = 'Events - Rucking Revolution';
const pageDescription = 'Discover upcoming rucking events and challenges.';
---
<Layout 
  title={pageTitle} 
  description={pageDescription}
  currentPage="/events"
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/events`,
    image: `${site.baseUrl}/og-events.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">EVENTS</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Discover upcoming rucking events and challenges.
        </p>
      </div>

      {/* Events Grid */}
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {events.map(event => (
          <article
            key={event.id}
            class="card-border flex flex-col h-full border border-border hover:border-primary transition-colors"
          >
            {/* Hero Image */}
            <a href={`/events/${event.slug}`} class="mb-0">
              <img
                src={event.heroImage.src}
                alt={event.heroImage.alt}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            </a>

            {/* Event Content */}
            <div class="flex-0 p-4">
              <h2 class="text-xl font-heading text-secondary mb-2 line-clamp-2">
                <a href={`/events/${event.slug}`} class="hover:underline">
                  {event.title}
                </a>
              </h2>
              <p class="text-muted-foreground mb-2 line-clamp-3 text-sm">{event.description}</p>

              {/* Metadata */}
              <div class="mt-auto space-y-2 text-sm">
                <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
                  <span>DATE: {new Date(event.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  <span>LOC: {event.location}</span>
                  <span>DUR: {event.duration}</span>
                </div>
                <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
                  <span>DIST: {event.distance} KM</span>
                  <span>LOAD: {event.load} KG</span>
                  <span>DIFF: {event.difficulty === 'beginner' ? 'BEGINNER' : 
                   event.difficulty === 'intermediate' ? 'INTERMEDIATE' : 'ADVANCED'}</span>
                  <span>PRICE: €{event.priceEUR.toFixed(2)}</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
