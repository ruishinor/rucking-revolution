---
import Layout from '@/components/Layout.astro';
import UnderReviewNotice from '@/components/UnderReviewNotice.astro';
import { events } from '@/data/events';
import { site } from '@/data/site';
import { existsSync } from 'node:fs';
import { featureFlags, getReviewStatusCopy } from '@/lib/featureFlags';

const { showEventsContent: SHOW_EVENTS_CONTENT } = featureFlags;

const publicAssetExists = (assetPath: string) =>
  existsSync(new URL(`../../../public${assetPath}`, import.meta.url));

const eventCards = [...events]
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .map((event) => ({
    ...event,
    hasHeroImage: publicAssetExists(event.heroImage.src),
  }));
---

<Layout
  title="Events - Rucking Revolution"
  description="Discover upcoming rucking events, workshops, and challenge weekends."
  canonicalUrl={`${site.baseUrl}/events`}
  currentPage="/learn"
>
  {!SHOW_EVENTS_CONTENT ? (
    <UnderReviewNotice
      label="Events"
      description={getReviewStatusCopy('Events').description}
      backHref="/learn"
      backLabel="Back to Learn"
    />
  ) : (
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">EVENTS</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Planned workshops, challenge weekends, and community-focused training events built around movement, leadership, and shared standards.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {eventCards.map((event) => (
          <article class="card-border flex flex-col border border-border hover:border-primary transition-colors overflow-hidden">
            <a href={`/events/${event.slug}`} class="block">
              {event.hasHeroImage ? (
                <img
                  src={event.heroImage.src}
                  alt={event.heroImage.alt}
                  class="w-full h-56 object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-56 bg-muted flex items-center justify-center">
                  <span class="text-muted-foreground text-sm font-mono">NO IMAGE</span>
                </div>
              )}
            </a>

            <div class="p-5 flex flex-col gap-3">
              <div>
                <h2 class="text-2xl font-heading text-secondary mb-2">
                  <a href={`/events/${event.slug}`} class="hover:underline">{event.title}</a>
                </h2>
                <p class="text-sm text-muted-foreground">{event.description}</p>
              </div>

              <div class="flex flex-wrap gap-3 text-xs font-mono text-muted-foreground">
                <span>{new Date(event.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span>{event.location}</span>
                <span>{event.distance} KM</span>
                <span>{event.load} KG</span>
              </div>

              <div class="flex flex-wrap gap-2 text-xs">
                <span class="px-2 py-1 bg-primary/10 text-primary rounded">{event.difficulty.toUpperCase()}</span>
                <span class="px-2 py-1 bg-muted rounded text-muted-foreground">{event.duration.toUpperCase()}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
  )}
</Layout>
