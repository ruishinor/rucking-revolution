---
import Layout from '@/components/Layout.astro';
import { comics } from '@/data/comics.ts';
---

<Layout title="Red Rucker" description="Webcomic archive and individual comic pages">
  <h1 class="text-3xl font-bold mb-6">Red Rucker</h1>
  <p class="mb-6">Webcomic archive and individual comic pages</p>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {comics.map((comic) => (
       <a href={`/red-rucker/${comic.episode}`} class="group">
         {typeof comic.image === 'string' ? (
           <img
             src={comic.image}
             alt={comic.title}
             class="w-full h-auto rounded-lg shadow-lg transition-transform duration-300 group-hover:scale-105"
             loading="lazy"
           />
         ) : (
           <img
             src={comic.image.src}
             width={comic.image.width}
             height={comic.image.height}
             alt={comic.title}
             class="w-full h-auto rounded-lg shadow-lg transition-transform duration-300 group-hover:scale-105"
             loading="lazy"
           />
         )}
         <h2 class="mt-4 text-xl font-semibold text-center">{comic.title}</h2>
         <p class="text-center text-sm text-gray-600">Episode {comic.episode}</p>
       </a>
    ))}
  </div>
</Layout>
