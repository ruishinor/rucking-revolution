---
import Layout from '@/components/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import QuoteDisplay from '@/components/QuoteDisplay.astro';
import { site } from '@/data/site.ts';
import { articles } from '@/data/articles.ts';
import { products } from '@/data/products.ts';
import { comics } from '@/data/comics.ts';
import { quotes } from '@/data/quotes.ts';

// Get latest 3 articles sorted by date (newest first)
const latestArticles = [...articles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// Get first article as featured
const featuredArticle = articles[0];

// Get first comic for preview
const featuredComic = comics[0];

// Get lead book product for Product Teaser
const leadBook = products.find(p => p.id === 'your-first-ruck');

// Get published products for Digital Library catalog
const publishedProducts = products.filter(p => p.published !== false && p.id !== 'your-first-ruck' && p.id !== 'coming-soon');

// Homepage structured data - WebSite schema with search action for Google
const homepageStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": site.title,
      "url": site.baseUrl,
      "description": site.description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${site.baseUrl}/learn/articles?search={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Rucking Revolution",
        "url": site.baseUrl
      }
    },
    ...(featuredArticle ? [{
      "@type": "Article",
      "headline": featuredArticle.title,
      "description": featuredArticle.excerpt,
      "url": `${site.baseUrl}/learn/articles/${featuredArticle.slug}`,
      "datePublished": featuredArticle.date,
      "author": {
        "@type": "Person",
        "name": featuredArticle.author
      },
      "publisher": {
        "@type": "Organization",
        "name": "Rucking Revolution"
      },
      "keywords": featuredArticle.tags.join(", ")
    }] : []),
    ...(leadBook ? [{
      "@type": "Product",
      "name": leadBook.title,
      "description": leadBook.description,
      "url": `${site.baseUrl}${leadBook.purchaseLink}`,
      "image": `${site.baseUrl}${leadBook.previewImages[0]?.src}`,
      "offers": {
        "@type": "Offer",
        "price": leadBook.priceEUR,
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": `${site.baseUrl}${leadBook.purchaseLink}`
      },
      "brand": {
        "@type": "Brand",
        "name": "Rucking Revolution"
      }
    }] : [])
  ]
};

const proofPoints = [
  { value: 'Field-Tested', label: 'Methods proven in real life' },
  { value: 'Crew-Built', label: 'By active ruck leaders' },
  { value: 'Beginner to Leader', label: 'Proven pathway' },
];

const pillars = [
  { 
    title: 'LEARN', 
    label: 'Knowledge Base',
    description: 'Field manual, guides, and foundational principles for understanding rucking as a practice.',
    href: '/learn',
  },
  { 
    title: 'TRAIN', 
    label: 'Training',
    description: 'Programming, workouts, and performance kit. Build your fitness.',
    href: '/train',
  },
  { 
    title: 'LEAD', 
    label: 'Leadership',
    description: 'Crew tactics, ruck clubs, and leadership. Learn to lead and organize.',
    href: '/lead',
  },
];

const communityItems = [
  { title: 'Why Rucking', desc: 'The philosophy and practice', href: '/why-rucking', icon: 'question' },
  { title: 'Routes', desc: 'Navigate terrain with verified paths', href: '/routes', icon: 'route' },
  { title: 'Events', desc: 'Join scheduled events', href: '/events', icon: 'calendar' },
  { title: 'Field Notes', desc: 'Real reports from the crew', href: '/field-notes', icon: 'note' },
  { title: 'Crews', desc: 'Find or start your crew', href: '/lead/ruck-clubs', icon: 'users' },
];
---

<Layout title="Home" description={site.description} currentPage="/" structuredData={homepageStructuredData}>
  
  <!-- ==================== HERO SECTION ==================== -->
  <section class="hero-section">
    <div class="hero-bg"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="stamp stamp-primary mb-6">FIELD MANUAL</span>
          <h1 class="hero-title">
            RUCK WITH<br/>
            <span class="text-primary">PURPOSE</span>
          </h1>
          <p class="hero-deck">
            Train for life, stay fit into old age, build your community and join crews worldwide.
          </p>
          <div class="hero-actions">
            <a href="/train" class="btn-military btn-military-primary">
              START TRAINING
            </a>
            <a href="/learn" class="btn-military btn-military-secondary">
              READ THE FIELD GUIDE
            </a>
            <a href="/contact" class="btn-military btn-military-secondary btn-get-in-touch">
              GET IN TOUCH
            </a>
          </div>
        </div>
        <div class="hero-right">
          <QuoteDisplay quotes={quotes} />
        </div>
      </div>
    </div>
    <div class="hero-divider"></div>
  </section>

  <!-- ==================== PROOF STRIP ==================== -->
  <section class="proof-strip">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="proof-grid">
        {proofPoints.map((point) => (
          <div class="proof-item">
            <span class="proof-value">{point.value}</span>
            <span class="proof-label">{point.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PILLAR COMMAND CARDS ==================== -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">SELECT YOUR PATH</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {pillars.map((pillar) => (
          <a href={pillar.href} class="card-military p-8 group">
            <span class="label-mono block mb-2">{pillar.label}</span>
            <h3 class="text-4xl font-heading text-secondary mb-4 group-hover:text-primary transition-colors">{pillar.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{pillar.description}</p>
            <div class="mt-6 text-primary opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-2">
              <span class="text-sm font-heading tracking-wider">ENTER</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED CONTENT & E-COMMERCE MODULE ==================== -->
  <section class="featured-module">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Left Column: Featured Article + Digital Library -->
        <div>
          <!-- Featured Article Card -->
          {featuredArticle && (
            <article class="featured-article-card" aria-labelledby="featured-article-title">
              <div class="flex items-center gap-4 mb-4">
                <time datetime={featuredArticle.date} class="label-mono">
                  {new Date(featuredArticle.date).toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                </time>
              </div>
              <h3 id="featured-article-title" class="text-3xl md:text-4xl font-heading text-secondary mb-4 leading-tight">
                {featuredArticle.title}
              </h3>
              <p class="text-muted-foreground text-lg leading-relaxed font-serif mb-6">
                {featuredArticle.excerpt}
              </p>
              <!-- Taxonomy Tags -->
              <div class="flex flex-wrap gap-2 mb-6" role="list" aria-label="Article topics">
                {featuredArticle.tags.map((tag) => (
                  <span class="stamp stamp-primary text-xs py-1" role="listitem">{tag}</span>
                ))}
              </div>
              <a href={`/learn/articles/${featuredArticle.slug}`} class="btn btn-secondary" aria-label={`Read article: ${featuredArticle.title}`}>
                READ ARTICLE
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </article>
          )}

          <!-- Digital Library (below article, same column) -->
          <div class="mt-10 pt-8 border-t border-border">
            <div class="section-header mb-6">
              <span class="section-marker">///</span>
              <h2 class="text-xl md:text-2xl font-heading text-secondary">DIGITAL LIBRARY</h2>
            </div>
            {publishedProducts.length > 0 ? (
              <div class="grid sm:grid-cols-2 gap-4">
                {publishedProducts.map((product) => (
                  <ProductCard product={product} />
                ))}
              </div>
            ) : (
              <p class="text-muted-foreground text-sm">New resources coming soon.</p>
            )}
            <div class="mt-6">
              <a href="/learn/library" class="btn btn-utility btn-sm">VIEW FULL LIBRARY</a>
            </div>
          </div>
        </div>

        <!-- Right Column: Product Teaser (Lead Book) -->
        {leadBook && (
          <aside class="product-teaser" aria-labelledby="lead-book-title">
            <a href={leadBook.purchaseLink} class="block group" aria-label={`View ${leadBook.title} details`}>
              <!-- Cover Image -->
              <div class="aspect-[3/4] max-w-xs mx-auto bg-panel mb-5 overflow-hidden rounded relative">
                <img 
                  src={leadBook.previewImages[0]?.src} 
                  alt={leadBook.previewImages[0]?.alt || leadBook.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                  loading="lazy"
                  data-image-fallback="next"
                />
                <div class="hidden w-full h-full items-center justify-center text-muted-300">
                  <div class="text-center">
                    <div class="text-4xl mb-2" role="img" aria-label="Books">📚</div>
                    <p class="text-sm">Preview unavailable</p>
                  </div>
                </div>
                <!-- Format Stamp -->
                <span class="absolute top-3 left-3 stamp stamp-secondary text-xs bg-white/90 backdrop-blur-sm">ebook first</span>
                <!-- Price Pill -->
                <span class="absolute top-3 right-3 bg-secondary text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">
                  {leadBook.priceEUR > 0 ? `$${(leadBook.priceEUR * 1.08).toFixed(2)} / EUR ${leadBook.priceEUR.toFixed(2)}` : 'Free'}
                </span>
              </div>
              <!-- Metadata -->
              <span class="label-mono block mb-2">Rucking Revolution release</span>
              <!-- Title -->
              <h3 id="lead-book-title" class="text-2xl font-heading text-secondary mb-3 group-hover:text-primary transition-colors">
                {leadBook.title}
              </h3>
              <!-- Pitch Description -->
              <p class="text-muted-foreground text-sm leading-relaxed mb-4">
                {leadBook.description}
              </p>
            </a>
            <!-- Feature List -->
            {leadBook.whatYouLearn && leadBook.whatYouLearn.length > 0 && (
              <div class="border border-border rounded p-4 mb-5">
                <h4 class="font-heading text-xs text-secondary mb-3 tracking-wider uppercase">Inside</h4>
                <ul class="space-y-2 text-sm text-muted-foreground" aria-label="Product features">
                  {leadBook.whatYouLearn.map((feature) => (
                    <li class="flex items-start gap-2">
                      <span class="text-primary mt-0.5" aria-hidden="true">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            <!-- Purchase Link -->
            <a href={leadBook.purchaseLink} class="text-primary font-bold text-sm hover:underline" aria-label={`View book details for ${leadBook.title}`}>
              View book details →
            </a>
          </aside>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== RED RUCKER ==================== -->
  <section class="py-16 md:py-20 bg-panel">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">LATEST ARTICLES</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {latestArticles.map((article) => (
          <article class="card-border p-6 group">
            <div class="flex items-center gap-3 mb-4">
              <span class="label-mono">{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              <span class="w-px h-3 bg-border"></span>
              <span class="label-mono">{article.readingTime} MIN</span>
            </div>
            <h3 class="text-xl font-heading text-secondary mb-3 group-hover:text-primary transition-colors">
              <a href={`/learn/articles/${article.slug}`}>{article.title}</a>
            </h3>
            <p class="text-muted-foreground text-sm line-clamp-3 mb-4">{article.excerpt}</p>
            <div class="flex flex-wrap gap-2">
              {article.tags.slice(0, 2).map((tag) => (
                <span class="label-mono text-xs">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== RECENT ARTICLES ==================== -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <span class="section-marker block mb-4">///</span>
          <h2 class="text-3xl md:text-4xl font-heading text-secondary mb-4">RED RUCKER</h2>
          <p class="text-muted-foreground text-lg leading-relaxed font-serif mb-6">
            Follow the adventures and lessons of Red Rucker as he navigates the challenges of rucking leadership and community building.
          </p>
          <div class="flex flex-wrap gap-6 mb-6">
            <span class="label-mono">{comics.length} ISSUES</span>
            <span class="label-mono">NEW UPDATES REGULARLY</span>
          </div>
          <a href="/red-rucker" class="btn btn-primary">
            READ COMICS
          </a>
        </div>
        {featuredComic && (
          <a href={`/red-rucker/${featuredComic.episode}`} class="block group">
            <div class="aspect-[4/3] bg-panel mb-4 overflow-hidden">
              <img 
                src={featuredComic.image} 
                alt={`Red Rucker - ${featuredComic.title}`}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-medium text-foreground group-hover:text-primary transition-colors">Episode {featuredComic.episode}: {featuredComic.title}</h3>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== RECRUITMENT FOOTER ==================== -->
  <section class="recruit-section">
    <div class="recruit-bg"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <span class="stamp stamp-primary mb-6">NEWSLETTER</span>
      <h2 class="text-4xl md:text-5xl font-heading text-white mb-6">JOIN THE MOVEMENT</h2>
      <p class="text-muted-200 text-lg font-serif mb-8">
        Training tips, community updates, and exclusive content for those who ruck with purpose.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" id="homepage-newsletter-form" onsubmit="event.preventDefault()">
        <div style="position:absolute;left:-9999px;" aria-hidden="true">
          <label for="homepage-newsletter-honeypot">Website</label>
          <input id="homepage-newsletter-honeypot" type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <label for="homepage-newsletter-email" class="sr-only">Email address</label>
        <input 
          id="homepage-newsletter-email"
          type="email" 
          name="email"
          placeholder="ENTER EMAIL" 
          aria-label="Email address for newsletter"
          required
          style="pointer-events: auto; position: relative;"
          class="flex-1 px-4 py-3 bg-surface border border-muted-300 text-foreground placeholder:text-muted focus:border-primary focus:outline-none"
        />
        <button type="submit" style="pointer-events: auto; position: relative;" class="btn-military btn-military-primary whitespace-nowrap">
          SUBSCRIBE
        </button>
      </form>
      <p class="label-muted text-xs">No spam. Updates at a steady rhythm.</p>
    </div>
  </section>

</Layout>

<script type="module" src="/scripts/homepage-newsletter.js" is:inline></script>

<style>
  /* Hero */
  .hero-section {
    position: relative;
    background: var(--rr-color-background);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 100px,
        rgba(138, 30, 30, 0.02) 100px,
        rgba(138, 30, 30, 0.02) 101px
      );
  }

  .hero-title {
    font-family: var(--rr-font-heading);
    font-size: clamp(3rem, 10vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
    color: var(--rr-color-secondary);
    margin: 0 0 1.5rem 0;
  }

  .hero-deck {
    font-family: var(--rr-font-serif);
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--rr-color-muted-foreground);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-divider {
    height: 4px;
    background: var(--rr-color-primary);
  }

  /* Proof Strip */
  .proof-strip {
    background: var(--rr-color-secondary);
    padding: 2rem 0;
    border-bottom: 4px solid var(--rr-color-primary);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .proof-value {
    display: block;
    font-family: var(--rr-font-heading);
    font-size: 1.75rem;
    color: var(--rr-color-white);
    margin-bottom: 0.25rem;
  }

  .proof-label {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--rr-color-muted-300);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-right {
      border-top: 1px solid var(--rr-color-border);
      padding-top: 2rem;
    }
  }

  /* Section header */
  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Featured Module - Article + Product Teaser */
  .featured-module {
    background: var(--rr-color-muted-50);
    border-top: 1px solid var(--rr-color-border);
    border-bottom: 1px solid var(--rr-color-border);
  }

  .featured-article-card {
    padding: 1.5rem 0;
  }

  .product-teaser {
    padding: 1.5rem 0;
  }

  @media (max-width: 767px) {
    .featured-module .grid {
      gap: 2rem;
    }

    .product-teaser {
      border-top: 1px solid var(--rr-color-border);
      padding-top: 2.5rem;
    }
  }

  /* Recruitment */
  .recruit-section {
    position: relative;
    background: var(--rr-color-secondary);
    overflow: hidden;
    z-index: 1;
  }

  .recruit-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: 
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 50px,
        rgba(138, 30, 30, 0.08) 50px,
        rgba(138, 30, 30, 0.08) 51px
      );
  }

  .label-muted {
    color: var(--rr-color-muted);
  }

  .text-muted-200 {
    color: var(--rr-color-muted-200);
  }
</style>
