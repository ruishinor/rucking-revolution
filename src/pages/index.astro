---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site.ts';
---
<Layout title="Home" description={site.description} currentPage="/">
  <!-- Hero Section -->
   <section class="relative bg-gray-50 overflow-hidden">
     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
       <div class="text-center">
         <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">
           {site.title}
         </h1>
         <p class="mt-6 max-w-2xl mx-auto text-xl text-gray-500">
           {site.description}
         </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/learn" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-primary text-white hover:bg-primary/90">
            Start Learning
          </a>
          <a href="/train" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-white text-primary hover:bg-primary/50">
            Start Training
          </a>
          <a href="/lead" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-white text-primary hover:bg-primary/50">
            Start Leading
          </a>
        </div>
       </div>
     </div>
   </section>

  <!-- Core Pillars -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Core Pillars
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- Training Pillar -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Training</h3>
              <p class="mt-1 text-sm text-gray-500">
                Field-tested methods for rucking strength and mobility
              </p>
            </div>
          </div>
        </div>

        <!-- Leadership Pillar -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v9a2 2 0 002 2h10a2 2 0 002-2V8m0 13a2 2 0 100-4h14a2 2 0 100 4v-1a2 2 0 00-2-2H5a2 2 0 00-2 2z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Leadership</h3>
              <p class="mt-1 text-sm text-gray-500">
                Tools for crew leaders and team development
              </p>
            </div>
          </div>
        </div>

        <!-- Field Lessons Pillar -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h3m8 0h3m-8 5a2 2 0 112.232 3.124a31.213 31.213 0 011.418.448A31.11 31.11 0 0016.75 13.5c-3.036 0-5.888-.75-8.238-1.79a31.114 31.114 0 01-1.418-.448A2.98 2.98 0 017 12V9a2 2 0 012-2h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h2.586a2 2 0 012 2v3.586l-.293.293a2 2 0 01-1.414 1.414A2 2 0 0111 16h-5a2 2 0 01-2-2zm0 0a2 2 0 104 0v-1a2 2 0 00-2-2zm0 0a2 2 0 002 2v1a2 2 0 10-4 0v-1z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Field Lessons</h3>
              <p class="mt-1 text-sm text-gray-500">
                Real experiences documented and shared
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Latest Articles
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Article Card Placeholder -->
        <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-3">
              Why Shared Discomfort Builds Teams
            </h3>
            <p class="mb-4 text-gray-600 line-clamp-3">
              Discover how shared challenges in rucking create unbreakable bonds and forge resilient teams capable of overcoming any obstacle.
            </p>
            <a href="/learn/articles" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-primary hover:bg-primary/50">
              Read Article
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11h10m0 0l3-3m-3 3l3 3" />
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Article Card Placeholder -->
        <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-3">
              The Psychology of Ruck Weight Progression
            </h3>
            <p class="mb-4 text-gray-600 line-clamp-3">
              Understanding the mental barriers and breakthroughs that come with progressively increasing your ruck load over time.
            </p>
            <a href="/learn/articles" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-primary hover:bg-primary/50">
              Read Article
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11h10m0 0l3-3m-3 3l3 3" />
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Article Card Placeholder -->
        <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-3">
              Building Crew Culture Through Shared Suffering
            </h3>
            <p class="mb-4 text-gray-600 line-clamp-3">
              How intentional shared challenges create lasting bonds and transform groups of individuals into cohesive teams.
            </p>
            <a href="/learn/articles" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-primary hover:bg-primary/50">
              Read Article
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11h10m0 0l3-3m-3 3l3 3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Training Resources -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Training Resources
      </h2>
      <div class="grid gap-6 md:grid-cols-4">
        <!-- Resource Card -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Mobility Tutorials
          </h3>
          <p class="text-sm text-gray-500">
            Improve your range of motion and prevent injury with guided mobility routines.
          </p>
        </div>
        
        <!-- Resource Card -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3M6 5.636A11.044 11.044 0 0112 5c5.954 0 10.777 4.31 10.999 9.514-.085 1.79-.288 3.497-.64 5.013A11.022 11.022 0 0116.025 18H7.975a11.022 11.022 0 01-5.639-3.373C5.263 9.133 4.44 7.434 4.44 5.636z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Workout Generator
          </h3>
          <p class="text-sm text-gray-500">
            Create customized rucking workouts based on your goals, experience level, and available time.
          </p>
        </div>
        
        <!-- Resource Card -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293H19a2 2 0 012 2v6a2 2 0 01-2 2h-1" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Crew Leadership Tools
          </h3>
          <p class="text-sm text-gray-500">
            Resources for developing effective leadership skills within your ruck crew.
          </p>
        </div>
        
        <!-- Resource Card -->
        <div class="bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h3m8 0h3m-8 5a2 2 0 112.232 3.124a31.213 31.213 0 011.418.448A31.11 31.11 0 0016.75 13.5c-3.036 0-5.888-.75-8.238-1.79a31.114 31.114 0 01-1.418-.448A2.98 2.98 0 017 12V9a2 2 0 012-2h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h2.586a2 2 0 012 2v3.586l-.293.293a2 2 0 01-1.414 1.414A2 2 0 0111 16h-5a2 2 0 01-2-2zm0 0a2 2 0 104 0v-1a2 2 0 00-2-2zm0 0a2 2 0 002 2v1a2 2 0 10-4 0v-1z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Digital Library
          </h3>
          <p class="text-sm text-gray-500">
            Access our collection of guides, books, card decks, and training materials.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Red Rucker Comic Preview -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-6">
          Red Rucker Comic
        </h2>
        <p class="max-w-xl text-center text-gray-600 mb-8">
          Follow the adventures and lessons of Red Rucker as he navigates the challenges of rucking leadership and community building.
        </p>
        <div class="w-full max-w-2xl rounded-lg overflow-hidden shadow-md">
          <!-- Comic Preview Placeholder -->
          <div class="relative pt-24 bg-gray-200">
            <div class="absolute inset-0 flex items-center justify-center text-gray-500">
              Comic Preview
            </div>
          </div>
          <div class="px-4 py-3 bg-white">
            <div class="flex justify-between items-center">
              <span class="text-sm font-medium text-gray-900">
                Episode 1: The First Step
              </span>
              <a href="/red-rucker" class="text-sm text-primary hover:underline">
                Read the Comic
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>