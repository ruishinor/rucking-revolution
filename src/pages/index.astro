---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site.ts';
import { articles } from '@/data/articles.ts';
import { products } from '@/data/products.ts';
import { comics } from '@/data/comics.ts';

// Get latest 3 articles sorted by date (newest first)
const latestArticles = [...articles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// Get first article as featured
const featuredArticle = articles[0];

// Get first comic for preview
const featuredComic = comics[0];

// Get 4 featured products for Digital Library showcase
const featuredProducts = products.filter(p => p.published !== false).slice(0, 4);

// Homepage structured data - WebSite schema with search action for Google
const homepageStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.title,
  "url": site.baseUrl,
  "description": site.description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${site.baseUrl}/articles?search={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Rucking Revolution"
  }
};

const proofPoints = [
  { value: 'Field-Tested', label: 'Methods proven in real life' },
  { value: 'Crew-Built', label: 'By active ruck leaders' },
  { value: 'Beginner to Leader', label: 'Proven pathway' },
];

const pillars = [
  { 
    title: 'LEARN', 
    label: 'Knowledge Base',
    description: 'Field manual, guides, and foundational principles for understanding rucking as a practice.',
    href: '/learn',
  },
  { 
    title: 'TRAIN', 
    label: 'Training',
    description: 'Programming, workouts, and performance kit. Build your fitness.',
    href: '/train',
  },
  { 
    title: 'LEAD', 
    label: 'Leadership',
    description: 'Crew tactics, ruck clubs, and leadership. Learn to lead and organize.',
    href: '/lead',
  },
];

const communityItems = [
  { title: 'Why Rucking', desc: 'The philosophy and practice', href: '/why-rucking', icon: 'question' },
  { title: 'Routes', desc: 'Navigate terrain with verified paths', href: '/routes', icon: 'route' },
  { title: 'Events', desc: 'Join scheduled events', href: '/events', icon: 'calendar' },
  { title: 'Field Notes', desc: 'Real reports from the crew', href: '/field-notes', icon: 'note' },
  { title: 'Crews', desc: 'Find or start your crew', href: '/lead/ruck-clubs', icon: 'users' },
];
---

<Layout title="Home" description={site.description} currentPage="/" structuredData={homepageStructuredData}>
  
  <!-- ==================== HERO SECTION ==================== -->
  <section class="hero-section">
    <div class="hero-bg"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <span class="stamp stamp-primary mb-6">FIELD MANUAL</span>
        <h1 class="hero-title">
          RUCK WITH<br/>
          <span class="text-primary">PURPOSE</span>
        </h1>
        <p class="hero-deck">
          Train for life, stay fit into old age, build your community and join crews worldwide.
        </p>
        <div class="hero-actions">
          <a href="/train" class="btn-military btn-military-primary">
            START TRAINING
          </a>
          <a href="/learn" class="btn-military btn-military-secondary">
            READ THE FIELD GUIDE
          </a>
        </div>
      </div>
    </div>
    <div class="hero-divider"></div>
  </section>

  <!-- ==================== PROOF STRIP ==================== -->
  <section class="proof-strip">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="proof-grid">
        {proofPoints.map((point) => (
          <div class="proof-item">
            <span class="proof-value">{point.value}</span>
            <span class="proof-label">{point.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PILLAR COMMAND CARDS ==================== -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">SELECT YOUR PATH</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {pillars.map((pillar) => (
          <a href={pillar.href} class="card-military p-8 group">
            <span class="label-mono block mb-2">{pillar.label}</span>
            <h3 class="text-4xl font-heading text-secondary mb-4 group-hover:text-primary transition-colors">{pillar.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{pillar.description}</p>
            <div class="mt-6 text-primary opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-2">
              <span class="text-sm font-heading tracking-wider">ENTER</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED CONTENT ==================== -->
  {featuredArticle && (
    <section class="featured-section">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="featured-image">
            <div class="aspect-[4/3] bg-panel flex items-center justify-center">
              <span class="stamp stamp-secondary">FEATURED</span>
            </div>
          </div>
          <div class="featured-content">
            <div class="flex items-center gap-4 mb-4">
              <span class="label-mono">{new Date(featuredArticle.date).toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
              <span class="stamp stamp-primary text-xs py-1">{featuredArticle.tags[0]}</span>
            </div>
            <h3 class="text-3xl md:text-4xl font-heading text-secondary mb-4 leading-tight">
              {featuredArticle.title}
            </h3>
            <p class="text-muted-foreground text-lg leading-relaxed font-serif mb-6">
              {featuredArticle.excerpt}
            </p>
            <a href={`/articles/${featuredArticle.slug}`} class="btn btn-secondary">
              READ ARTICLE
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ==================== RESOURCES ==================== -->
  <section class="py-16 md:py-20 bg-panel">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">EXPLORE THE PLATFORM</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {communityItems.map((item, index) => (
          <a href={item.href} class={`resource-card resource-card-${index % 2 === 0 ? 'forest' : 'steel'} group`}>
            <div class="resource-card-icon">
              {item.icon === 'route' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
              )}
              {item.icon === 'calendar' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              )}
              {item.icon === 'note' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
              )}
              {item.icon === 'users' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              )}
              {item.icon === 'question' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                  <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
              )}
            </div>
            <h3 class="resource-card-title">{item.title.toUpperCase()}</h3>
            <p class="resource-card-desc">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LIBRARY ==================== -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">DIGITAL LIBRARY</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredProducts.map((product) => (
          <a href={`/library/${product.id}`} class="card-border p-4 group">
            <div class="aspect-[3/4] bg-panel mb-4 flex items-center justify-center">
              <svg class="w-12 h-12 text-muted-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <span class="label-mono block mb-1">{product.type || 'RESOURCE'}</span>
            <h3 class="font-medium text-foreground mb-2 line-clamp-2 group-hover:text-primary transition-colors">{product.title}</h3>
            <span class="text-primary font-bold">€{product.priceEUR.toFixed(2)}</span>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/learn/library" class="btn btn-utility">VIEW FULL LIBRARY</a>
      </div>
    </div>
  </section>

  <!-- ==================== RED RUCKER ==================== -->
  <section class="py-16 md:py-20 bg-panel">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header mb-10">
        <span class="section-marker">///</span>
        <h2 class="text-2xl md:text-3xl font-heading text-secondary">LATEST ARTICLES</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {latestArticles.map((article) => (
          <article class="card-border p-6 group">
            <div class="flex items-center gap-3 mb-4">
              <span class="label-mono">{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              <span class="w-px h-3 bg-border"></span>
              <span class="label-mono">{article.readingTime} MIN</span>
            </div>
            <h3 class="text-xl font-heading text-secondary mb-3 group-hover:text-primary transition-colors">
              <a href={`/articles/${article.slug}`}>{article.title}</a>
            </h3>
            <p class="text-muted-foreground text-sm line-clamp-3 mb-4">{article.excerpt}</p>
            <div class="flex flex-wrap gap-2">
              {article.tags.slice(0, 2).map((tag) => (
                <span class="label-mono text-xs">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== RECENT ARTICLES ==================== -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <span class="section-marker block mb-4">///</span>
          <h2 class="text-3xl md:text-4xl font-heading text-secondary mb-4">RED RUCKER</h2>
          <p class="text-muted-foreground text-lg leading-relaxed font-serif mb-6">
            Follow the adventures and lessons of Red Rucker as he navigates the challenges of rucking leadership and community building.
          </p>
          <div class="flex flex-wrap gap-6 mb-6">
            <span class="label-mono">{comics.length} ISSUES</span>
            <span class="label-mono">NEW UPDATES REGULARLY</span>
          </div>
          <a href="/red-rucker" class="btn btn-primary">
            READ COMICS
          </a>
        </div>
        {featuredComic && (
          <a href={`/red-rucker/${featuredComic.episode}`} class="block group">
            <div class="aspect-[4/3] bg-panel mb-4 overflow-hidden">
              <img 
                src={featuredComic.image} 
                alt={`Red Rucker - ${featuredComic.title}`}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-medium text-foreground group-hover:text-primary transition-colors">Episode {featuredComic.episode}: {featuredComic.title}</h3>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- ==================== RECRUITMENT FOOTER ==================== -->
  <section class="recruit-section">
    <div class="recruit-bg"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <span class="stamp stamp-primary mb-6">RECRUITMENT</span>
      <h2 class="text-4xl md:text-5xl font-heading text-white mb-6">JOIN THE MOVEMENT</h2>
      <p class="text-muted-200 text-lg font-serif mb-8">
        Not a newsletter. Intelligence briefings for operators who ruck with purpose.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4">
        <input 
          type="email" 
          placeholder="ENTER EMAIL" 
          class="flex-1 px-4 py-3 bg-surface border border-muted-300 text-foreground placeholder:text-muted focus:border-primary focus:outline-none"
        />
        <button type="submit" class="btn-military btn-military-primary whitespace-nowrap">
          ENLIST
        </button>
      </form>
      <p class="label-muted text-xs">No spam. Operational frequency only.</p>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero-section {
    position: relative;
    background: var(--rr-color-background);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 100px,
        rgba(138, 30, 30, 0.02) 100px,
        rgba(138, 30, 30, 0.02) 101px
      );
  }

  .hero-title {
    font-family: var(--rr-font-heading);
    font-size: clamp(3rem, 10vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
    color: var(--rr-color-secondary);
    margin: 0 0 1.5rem 0;
  }

  .hero-deck {
    font-family: var(--rr-font-serif);
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--rr-color-muted-foreground);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-divider {
    height: 4px;
    background: var(--rr-color-primary);
  }

  /* Proof Strip */
  .proof-strip {
    background: var(--rr-color-secondary);
    padding: 2rem 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .proof-value {
    display: block;
    font-family: var(--rr-font-heading);
    font-size: 1.75rem;
    color: var(--rr-color-white);
    margin-bottom: 0.25rem;
  }

  .proof-label {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--rr-color-muted-300);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* Section header */
  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Featured Section */
  .featured-section {
    background: var(--rr-color-muted-50);
    border-top: 1px solid var(--rr-color-border);
    border-bottom: 1px solid var(--rr-color-border);
  }

  /* Recruitment */
  .recruit-section {
    position: relative;
    background: var(--rr-color-secondary);
    overflow: hidden;
  }

  .recruit-bg {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 50px,
        rgba(138, 30, 30, 0.08) 50px,
        rgba(138, 30, 30, 0.08) 51px
      );
  }

  .label-muted {
    color: var(--rr-color-muted);
  }

  .text-muted-200 {
    color: var(--rr-color-muted-200);
  }
</style>
