---
import Layout from '@/components/Layout.astro';
import { site } from '@/data/site.ts';
import { articles } from '@/data/articles.ts';
import { products } from '@/data/products.ts';
import { comics } from '@/data/comics.ts';

// Get latest 3 articles sorted by date (newest first)
const latestArticles = [...articles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// Get first comic for preview
const featuredComic = comics[0];

// Get 4 featured products for Digital Library showcase
const featuredProducts = products.slice(0, 4);

// Homepage structured data - WebSite schema with search action for Google
const homepageStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.title,
  "url": site.baseUrl,
  "description": site.description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${site.baseUrl}/articles?search={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Rucking Revolution"
  }
};
---

<Layout title="Home" description={site.description} currentPage="/" structuredData={homepageStructuredData}>
  <!-- Hero Section -->
  <section class="relative bg-gray-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">
          {site.title}
        </h1>
        <p class="mt-6 max-w-2xl mx-auto text-xl text-gray-500">
          {site.description}
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/learn" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-primary text-white hover:bg-primary/90">
            Start Learning
          </a>
          <a href="/train" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-white text-primary border-primary hover:bg-primary/10">
            Start Training
          </a>
          <a href="/lead" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-white text-primary border-primary hover:bg-primary/10">
            Start Leading
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Pillars -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Core Pillars
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- Training Pillar -->
        <a href="/train" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Training</h3>
              <p class="mt-1 text-sm text-gray-500">
                Field-tested methods for rucking strength and mobility
              </p>
            </div>
          </div>
        </a>

        <!-- Leadership Pillar -->
        <a href="/lead" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v9a2 2 0 002 2h10a2 2 0 002-2V8m0 13a2 2 0 100-4h14a2 2 0 100 4v-1a2 2 0 00-2-2H5a2 2 0 00-2 2z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Leadership</h3>
              <p class="mt-1 text-sm text-gray-500">
                Tools for crew leaders and team development
              </p>
            </div>
          </div>
        </a>

        <!-- Field Lessons Pillar -->
        <a href="/field-notes" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h3m8 0h3m-8 5a2 2 0 112.232 3.124a31.213 31.213 0 011.418.448A31.11 31.11 0 0016.75 13.5c-3.036 0-5.888-.75-8.238-1.79a31.114 31.114 0 01-1.418-.448A2.98 2.98 0 017 12V9a2 2 0 012-2h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h2.586a2 2 0 012 2v3.586l-.293.293a2 2 0 01-1.414 1.414A2 2 0 0111 16h-5a2 2 0 01-2-2zm0 0a2 2 0 104 0v-1a2 2 0 00-2-2zm0 0a2 2 0 002 2v1a2 2 0 10-4 0v-1z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900">Field Lessons</h3>
              <p class="mt-1 text-sm text-gray-500">
                Real experiences documented and shared
              </p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">
          Latest Articles
        </h2>
        <a href="/learn/articles" class="text-primary hover:underline font-medium">
          View All Articles →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {latestArticles.map((article) => (
          <article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
            <div class="p-6">
              <div class="flex items-center text-sm text-gray-500 mb-3">
                <span class="mr-4">{article.author}</span>
                <span class="mr-4">{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span>{article.readingTime} min read</span>
              </div>
              <h3 class="text-lg font-medium text-gray-900 mb-3">
                <a href={`/articles/${article.slug}`} class="hover:text-primary transition-colors">
                  {article.title}
                </a>
              </h3>
              <p class="mb-4 text-gray-600 line-clamp-3">
                {article.excerpt}
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                {article.tags.slice(0, 3).map((tag) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    {tag}
                  </span>
                ))}
              </div>
              <a href={`/articles/${article.slug}`} class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-primary hover:bg-primary/10 transition-colors">
                Read Article
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11h10m0 0l3-3m-3 3l3 3" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Training Resources -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">
          Training Resources
        </h2>
        <a href="/train" class="text-primary hover:underline font-medium">
          View All Training →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-4">
        <!-- Mobility Tutorials -->
        <a href="/train/performance-kit/mobility-band/lower-body" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 014.438 0" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Mobility Tutorials
          </h3>
          <p class="text-sm text-gray-500">
            Improve your range of motion and prevent injury with guided mobility routines.
          </p>
        </a>
        
        <!-- Workout Generator -->
        <a href="/train/workouts" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3M6 5.636A11.044 11.044 0 0112 5c5.954 0 10.777 4.31 10.999 9.514-.085 1.79-.288 3.497-.64 5.013A11.022 11.022 0 0116.025 18H7.975a11.022 11.022 0 01-5.639-3.373C5.263 9.133 4.44 7.434 4.44 5.636z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Workout Generator
          </h3>
          <p class="text-sm text-gray-500">
            Create customized rucking workouts based on your goals, experience level, and available time.
          </p>
        </a>
        
        <!-- Crew Leadership Tools -->
        <a href="/lead/crew-tactics" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293H19a2 2 0 012 2v6a2 2 0 01-2 2h-1" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Crew Leadership Tools
          </h3>
          <p class="text-sm text-gray-500">
            Resources for developing effective leadership skills within your ruck crew.
          </p>
        </a>
        
        <!-- Digital Library -->
        <a href="/learn/library" class="block bg-gray-50 p-6 rounded-lg hover:bg-gray-100 transition-colors duration-200 text-center">
          <div class="flex-shrink-0 h-12 w-12 mx-auto mb-4">
            <svg class="h-6 w-6 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h3m8 0h3m-8 5a2 2 0 112.232 3.124a31.213 31.213 0 011.418.448A31.11 31.11 0 0016.75 13.5c-3.036 0-5.888-.75-8.238-1.79a31.114 31.114 0 01-1.418-.448A2.98 2.98 0 017 12V9a2 2 0 012-2h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h2.586a2 2 0 012 2v3.586l-.293.293a2 2 0 01-1.414 1.414A2 2 0 0111 16h-5a2 2 0 01-2-2zm0 0a2 2 0 104 0v-1a2 2 0 00-2-2zm0 0a2 2 0 002 2v1a2 2 0 10-4 0v-1z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-3">
            Digital Library
          </h3>
          <p class="text-sm text-gray-500">
            Access our collection of guides, books, card decks, and training materials.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Digital Library Showcase -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">
          Digital Library
        </h2>
        <a href="/learn/library" class="text-primary hover:underline font-medium">
          Browse Full Library →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-4">
        {featuredProducts.map((product) => (
          <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
            <div class="aspect-[3/4] bg-gray-200 relative">
              <div class="absolute inset-0 flex items-center justify-center text-gray-400">
                <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-medium text-gray-900 mb-1 line-clamp-2">
                {product.title}
              </h3>
              <p class="text-lg font-bold text-primary">
                €{product.priceEUR.toFixed(2)}
              </p>
              <a href={`/library/${product.id}`} class="mt-3 block w-full text-center px-3 py-2 border border-primary text-sm font-medium rounded-md text-primary hover:bg-primary/10 transition-colors">
                View Details
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Red Rucker Comic Preview -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Red Rucker Comics
          </h2>
          <p class="text-gray-600 mb-6">
            Follow the adventures and lessons of Red Rucker as he navigates the challenges of rucking leadership and community building. Each episode delivers valuable insights through engaging storytelling.
          </p>
          <div class="flex items-center gap-4 mb-6">
            <span class="text-sm text-gray-500">{comics.length} Episodes Available</span>
            <span class="text-sm text-gray-500">•</span>
            <span class="text-sm text-gray-500">New episodes regularly</span>
          </div>
          <a href="/red-rucker" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm bg-primary text-white hover:bg-primary/90">
            Read the Comics
          </a>
        </div>
        <div class="flex-1 w-full max-w-md">
          <div class="rounded-lg overflow-hidden shadow-md bg-gray-100">
            <img 
              src={featuredComic.image} 
              alt={`Red Rucker - ${featuredComic.title}`}
              class="w-full aspect-[4/3] object-cover"
            />
            <div class="px-4 py-3 bg-white">
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-gray-900">
                  Episode {featuredComic.episode}: {featuredComic.title}
                </span>
                <a href="/red-rucker" class="text-sm text-primary hover:underline">
                  Read More
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Quick Links -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Explore the Platform
      </h2>
      <div class="grid gap-6 md:grid-cols-4">
        <a href="/why-rucking" class="block bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 text-center">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Why Rucking</h3>
          <p class="text-sm text-gray-500">Discover the discipline and its benefits</p>
        </a>
        <a href="/routes" class="block bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 text-center">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Routes</h3>
          <p class="text-sm text-gray-500">Discover rucking routes for all levels</p>
        </a>
        <a href="/events" class="block bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 text-center">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Events</h3>
          <p class="text-sm text-gray-500">Join community rucking events</p>
        </a>
        <a href="/field-notes" class="block bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 text-center">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Field Notes</h3>
          <p class="text-sm text-gray-500">Real-world rucking experiences</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
