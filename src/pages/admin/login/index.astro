---
import Layout from '@/components/Layout.astro';
import Container from '@/components/Container.astro';

let error = '';
let password = '';
let twoFactorCode = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    password = data.get('password')?.toString() || '';
    twoFactorCode = data.get('twoFactorCode')?.toString() || '';

    // In production, these should be environment variables
    // For demo purposes - CHANGE THESE!
    const ADMIN_PASSWORD = 'rucking2024';
    const ADMIN_2FA_CODE = '123456';

    if (password === ADMIN_PASSWORD && twoFactorCode === ADMIN_2FA_CODE) {
      // Return JavaScript to set sessionStorage (client-side)
      // We'll handle this with client-side redirect
      return new Response(`
        <!DOCTYPE html>
        <html>
          <head>
            <script>
              sessionStorage.setItem('admin_auth', 'true');
              window.location.href = '/admin';
            </script>
          </head>
        </html>
      `, {
        status: 200,
        headers: { 'Content-Type': 'text/html' }
      });
    } else {
      error = 'Invalid password or 2FA code';
    }
  } catch (e) {
    error = 'Login failed. Please try again.';
  }
}
---

<Layout 
  title="Admin Login - Rucking Revolution" 
  description="Admin login page"
>
  <Container>
    <div class="max-w-md mx-auto py-12">
      <div class="bg-white p-8 rounded-lg shadow-md border">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold mb-2">Admin Login</h1>
          <p class="text-muted">Enter your credentials to access the admin dashboard</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-md">
            <p class="text-red-600 text-sm">{error}</p>
          </div>
        )}

        <form method="POST" class="space-y-6">
          <div>
            <label for="password" class="block text-sm font-medium mb-2">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full px-4 py-2 border rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Enter your password"
            />
          </div>

          <div>
            <label for="twoFactorCode" class="block text-sm font-medium mb-2">
              2FA Code
            </label>
            <input
              type="text"
              id="twoFactorCode"
              name="twoFactorCode"
              required
              maxlength="6"
              pattern="[0-9]{6}"
              class="w-full px-4 py-2 border rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Enter 6-digit code"
            />
            <p class="text-xs text-muted mt-1">
              Use your authenticator app to get the 6-digit code
            </p>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white py-2 px-4 rounded-md hover:bg-primary/90 transition-colors"
          >
            Login
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href="/" class="text-sm text-primary hover:underline">
            ← Back to Home
          </a>
        </div>

        <div class="mt-8 p-4 bg-yellow-50 border border-yellow-200 rounded-md">
          <p class="text-yellow-800 text-xs">
            <strong>Demo Credentials:</strong><br/>
            Password: rucking2024<br/>
            2FA Code: 123456<br/><br/>
            <em>Change these in the code for production use!</em>
          </p>
        </div>
      </div>
    </div>
  </Container>

  <script is:inline>
    // Check if already logged in
    if (sessionStorage.getItem('admin_auth')) {
      window.location.href = '/admin';
    }
  </script>
</Layout>
