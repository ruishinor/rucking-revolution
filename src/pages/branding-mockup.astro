---
export const prerender = false;

// Branding Mockup - Field Manual Design Direction
// This file demonstrates the new homepage design based on the brand guidelines:
// - Manual-first clarity, manifesto-level conviction
// - Field manual aesthetic: issued handbook, not glossy fitness brand
// - Typography: Archivo (heading), IBM Plex Sans (UI), Source Serif 4 (editorial), IBM Plex Mono (metadata)
// - Colors: warm paper canvas, deep red authority, charcoal structure, orange activation, forest/steel modules
import Layout from '@/components/Layout.astro';
import { articles } from '@/data/articles.ts';

const brandingMockupEnabled =
  !import.meta.env.PROD || process.env.BRANDING_MOCKUP_ENABLED === 'true';

if (!brandingMockupEnabled) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found',
  });
}

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');

// Mock data for the mockup
const proofPoints = [
  { value: 'FIELD-TESTED', label: 'Methods proven in real life' },
  { value: 'CREW-BUILT', label: 'By active ruck leaders' },
  { value: 'INDIVIDUAL → COMMUNITY', label: 'Proven pathway' },
];

const commandCards = [
  { 
    title: 'LEARN', 
    label: 'Knowledge Base',
    description: 'Field manual, guides, and foundational principles',
    href: '/learn',
    icon: 'book'
  },
  { 
    title: 'TRAIN', 
    label: 'Operations',
    description: 'Programming, workouts, and performance kit',
    href: '/train',
    icon: 'activity'
  },
  { 
    title: 'LEAD', 
    label: 'Command',
    description: 'Crew tactics, ruck clubs, and leadership',
    href: '/lead',
    icon: 'users'
  },
];

// Get featured article
const featuredArticle = articles[0];
---

<Layout
  title="Branding Mockup - Field Manual"
  description="New homepage design mockup"
  currentPage="/"
  noindex={true}
  nofollow={true}
>
  
  <!-- ==================== HERO SECTION ==================== -->
  <section class="hero-section">
    <div class="hero-bg-pattern"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative">
      <div class="max-w-3xl">
        <div class="hero-stamp">FIELD MANUAL</div>
        <h1 class="hero-title">
          RUCK WITH<br/>
          <span class="hero-title-highlight">PURPOSE</span>
        </h1>
        <p class="hero-deck">
          Training, leadership, and field-tested knowledge for people who want more than steps and sweat.
        </p>
        <div class="hero-actions">
          <a href="/train" class="btn-military btn-primary-military">
            START TRAINING
          </a>
          <a href="/learn" class="btn-military btn-secondary-military">
            READ THE FIELD GUIDE
          </a>
        </div>
      </div>
    </div>
    <div class="hero-divider"></div>
  </section>

  <!-- ==================== PROOF STRIP ==================== -->
  <section class="proof-strip">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="proof-grid">
        {proofPoints.map((point) => (
          <div class="proof-item">
            <span class="proof-value">{point.value}</span>
            <span class="proof-label">{point.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== COMMAND CARDS ==================== -->
  <section class="command-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="section-header">
        <span class="section-marker">///</span>
        <h2 class="section-title">SELECT YOUR PATH</h2>
      </div>
      <div class="command-grid">
        {commandCards.map((card) => (
          <a href={card.href} class="command-card">
            <div class="command-card-inner">
              <span class="command-label">{card.label}</span>
              <h3 class="command-title">{card.title}</h3>
              <p class="command-description">{card.description}</p>
              <div class="command-arrow">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED DISPATCH ==================== -->
  <section class="dispatch-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="dispatch-grid">
        <div class="dispatch-image">
          <div class="dispatch-image-inner">
            <span class="dispatch-image-label">DISPATCH</span>
          </div>
        </div>
        <div class="dispatch-content">
          <div class="dispatch-meta">
            <span class="dispatch-date">2024.03.15</span>
            <span class="dispatch-tag">LEADERSHIP</span>
          </div>
          <h3 class="dispatch-title">The Art of the After Action Review</h3>
          <p class="dispatch-excerpt">
            Every ruck can be a data point. Every crew is a learning space. Here's how to extract the lessons that matter and build a culture of continuous improvement.
          </p>
          <a href={`/learn/articles/${featuredArticle?.slug || 'sample'}`} class="dispatch-link">
            READ DISPATCH →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== COMMUNITY BLOCK ==================== -->
  <section class="community-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="section-header">
        <span class="section-marker">///</span>
        <h2 class="section-title">FIELD OPERATIONS</h2>
      </div>
      <div class="community-grid">
        <a href="/routes" class="community-card community-card-forest">
          <div class="community-card-inner">
            <span class="community-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </span>
            <h3 class="community-title">ROUTES</h3>
            <p class="community-desc">Navigate terrain with our field-verified routes</p>
          </div>
        </a>
        <a href="/events" class="community-card community-card-steel">
          <div class="community-card-inner">
            <span class="community-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <h3 class="community-title">EVENTS</h3>
            <p class="community-desc">Join scheduled events and activities</p>
          </div>
        </a>
        <a href="/field-notes" class="community-card community-card-forest">
          <div class="community-card-inner">
            <span class="community-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </span>
            <h3 class="community-title">FIELD NOTES</h3>
            <p class="community-desc">Real-world reports from the crew</p>
          </div>
        </a>
        <a href="/lead/ruck-clubs" class="community-card community-card-steel">
          <div class="community-card-inner">
            <span class="community-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <h3 class="community-title">CREWS</h3>
            <p class="community-desc">Find or start your local unit</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== LIBRARY & RED RUCKER ==================== -->
  <section class="culture-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="culture-grid">
        <!-- Digital Library -->
        <a href="/learn/library" class="culture-card culture-card-library">
          <div class="culture-card-inner">
            <div class="culture-header">
              <span class="culture-marker">///</span>
              <span class="culture-label">DIGITAL LIBRARY</span>
            </div>
            <h3 class="culture-title">Knowledge<br/>Reference</h3>
            <p class="culture-desc">Guides, card decks, and training materials for your operational readiness.</p>
            <span class="culture-cta">ACCESS LIBRARY →</span>
          </div>
        </a>
        <!-- Red Rucker -->
        <a href="/red-rucker" class="culture-card culture-card-red">
          <div class="culture-card-inner">
            <div class="culture-header">
              <span class="culture-marker">///</span>
              <span class="culture-label">RED RUCKER</span>
            </div>
            <h3 class="culture-title">Comic<br/>Operations</h3>
            <p class="culture-desc">Field tales and lessons learned through the eyes of experience.</p>
            <span class="culture-cta">READ ISSUES →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== RECRUIT BLOCK ==================== -->
  <section class="recruit-section">
    <div class="recruit-bg-pattern"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="recruit-content">
        <div class="recruit-stamp">RECRUITMENT</div>
        <h2 class="recruit-title">JOIN THE MOVEMENT</h2>
        <p class="recruit-desc">
          Not a newsletter. Intelligence briefings for operators who ruck with purpose.
        </p>
        <form class="recruit-form">
          <input 
            type="email" 
            placeholder="ENTER EMAIL" 
            class="recruit-input"
          />
          <button type="submit" class="recruit-button">
            ENLIST
          </button>
        </form>
        <p class="recruit-note">No spam. Operational frequency only.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ==================== HERO SECTION ==================== */
  .hero-section {
    position: relative;
    background: var(--rr-color-background);
    overflow: hidden;
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 80px,
        rgba(139, 0, 0, 0.03) 80px,
        rgba(139, 0, 0, 0.03) 81px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 80px,
        rgba(139, 0, 0, 0.03) 80px,
        rgba(139, 0, 0, 0.03) 81px
      );
    opacity: 0.5;
  }

  .hero-stamp {
    display: inline-block;
    font-family: var(--rr-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--rr-color-primary);
    border: 1px solid var(--rr-color-primary);
    padding: 0.35rem 0.75rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--rr-font-heading);
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.055em;
    color: var(--rr-color-secondary);
    margin: 0 0 1.5rem 0;
  }

  .hero-title-highlight {
    color: var(--rr-color-primary);
  }

  .hero-deck {
    font-family: var(--rr-font-serif);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--rr-color-muted-foreground);
    max-width: 540px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-military {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    font-family: var(--rr-font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.2s ease;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  }

  .btn-primary-military {
    background: var(--rr-color-primary);
    color: var(--rr-color-white);
    border: none;
  }

  .btn-primary-military:hover {
    background: var(--rr-color-primary-dark);
    transform: translateY(-2px);
  }

  .btn-secondary-military {
    background: transparent;
    color: var(--rr-color-secondary);
    border: 2px solid var(--rr-color-secondary);
  }

  .btn-secondary-military:hover {
    background: var(--rr-color-secondary);
    color: var(--rr-color-white);
  }

  .hero-divider {
    height: 4px;
    background: var(--rr-color-primary);
    margin: 0;
  }

  /* ==================== PROOF STRIP ==================== */
  .proof-strip {
    background: var(--rr-color-secondary);
    padding: 2rem 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .proof-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .proof-value {
    font-family: var(--rr-font-heading);
    font-size: 1.75rem;
    letter-spacing: 0.05em;
    color: var(--rr-color-white);
  }

  .proof-label {
    font-family: var(--rr-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--rr-color-muted-300);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* ==================== COMMAND SECTION ==================== */
  .command-section {
    background: var(--rr-color-background);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .section-marker {
    font-family: var(--rr-font-mono);
    font-size: 0.875rem;
    color: var(--rr-color-primary);
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: var(--rr-font-heading);
    font-size: 2rem;
    color: var(--rr-color-secondary);
    margin: 0;
  }

  .command-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .command-card {
    display: block;
    background: var(--rr-color-surface);
    border: 1px solid var(--rr-color-border);
    text-decoration: none;
    transition: all 0.25s ease;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }

  .command-card:hover {
    border-color: var(--rr-color-primary);
    transform: translateY(-4px);
    box-shadow: 8px 8px 0 rgba(139, 0, 0, 0.15);
  }

  .command-card-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .command-label {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--rr-color-primary);
    text-transform: uppercase;
  }

  .command-title {
    font-family: var(--rr-font-heading);
    font-size: 2.5rem;
    color: var(--rr-color-secondary);
    margin: 0;
    line-height: 1;
  }

  .command-description {
    font-family: var(--rr-font-body);
    font-size: 0.95rem;
    color: var(--rr-color-muted-foreground);
    margin: 0;
    line-height: 1.5;
  }

  .command-arrow {
    margin-top: auto;
    padding-top: 1rem;
    color: var(--rr-color-primary);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.25s ease;
  }

  .command-card:hover .command-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 900px) {
    .command-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ==================== DISPATCH SECTION ==================== */
  .dispatch-section {
    background: var(--rr-color-muted-50);
    border-top: 2px solid var(--rr-color-border);
    border-bottom: 2px solid var(--rr-color-border);
  }

  .dispatch-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .dispatch-image {
    aspect-ratio: 16/10;
    background: var(--rr-color-secondary);
    position: relative;
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 24px 100%, 0 calc(100% - 24px));
  }

  .dispatch-image-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--rr-color-secondary) 0%, #2a2a2a 100%);
  }

  .dispatch-image-label {
    font-family: var(--rr-font-heading);
    font-size: 2rem;
    color: var(--rr-color-primary);
    letter-spacing: 0.2em;
  }

  .dispatch-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .dispatch-meta {
    display: flex;
    gap: 1rem;
    font-family: var(--rr-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .dispatch-date {
    color: var(--rr-color-muted);
  }

  .dispatch-tag {
    color: var(--rr-color-primary);
    font-weight: 600;
  }

  .dispatch-title {
    font-family: var(--rr-font-heading);
    font-size: 2.25rem;
    color: var(--rr-color-secondary);
    margin: 0;
    line-height: 1.1;
  }

  .dispatch-excerpt {
    font-family: var(--rr-font-serif);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--rr-color-muted-foreground);
    margin: 0;
  }

  .dispatch-link {
    font-family: var(--rr-font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--rr-color-primary);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.2s ease;
  }

  .dispatch-link:hover {
    color: var(--rr-color-primary-dark);
  }

  @media (max-width: 768px) {
    .dispatch-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ==================== COMMUNITY SECTION ==================== */
  .community-section {
    background: var(--rr-color-background);
  }

  .community-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .community-card {
    display: block;
    text-decoration: none;
    transition: transform 0.25s ease;
  }

  .community-card:hover {
    transform: translateY(-4px);
  }

  .community-card-inner {
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .community-card-forest {
    background: var(--rr-color-forest);
    color: var(--rr-color-white);
  }

  .community-card-steel {
    background: var(--rr-color-steel);
    color: var(--rr-color-white);
  }

  .community-icon {
    opacity: 0.8;
  }

  .community-title {
    font-family: var(--rr-font-heading);
    font-size: 1.5rem;
    margin: 0;
    letter-spacing: 0.1em;
  }

  .community-desc {
    font-family: var(--rr-font-body);
    font-size: 0.875rem;
    opacity: 0.85;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .community-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .community-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ==================== CULTURE SECTION ==================== */
  .culture-section {
    background: var(--rr-color-background);
  }

  .culture-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .culture-card {
    display: block;
    text-decoration: none;
    transition: transform 0.25s ease;
  }

  .culture-card:hover {
    transform: translateY(-4px);
  }

  .culture-card-inner {
    padding: 2.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--rr-color-surface);
    border: 1px solid var(--rr-color-border);
  }

  .culture-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .culture-marker {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    color: var(--rr-color-primary);
    letter-spacing: 0.1em;
  }

  .culture-label {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--rr-color-muted);
    text-transform: uppercase;
  }

  .culture-title {
    font-family: var(--rr-font-heading);
    font-size: 2rem;
    color: var(--rr-color-secondary);
    margin: 0;
    line-height: 1.1;
  }

  .culture-desc {
    font-family: var(--rr-font-body);
    font-size: 0.95rem;
    color: var(--rr-color-muted-foreground);
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }

  .culture-cta {
    font-family: var(--rr-font-heading);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    color: var(--rr-color-primary);
    padding-top: 1rem;
    border-top: 1px solid var(--rr-color-border);
  }

  @media (max-width: 640px) {
    .culture-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ==================== RECRUIT SECTION ==================== */
  .recruit-section {
    position: relative;
    background: var(--rr-color-secondary);
    overflow: hidden;
  }

  .recruit-bg-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(139, 0, 0, 0.1) 40px,
        rgba(139, 0, 0, 0.1) 41px
      );
  }

  .recruit-content {
    position: relative;
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .recruit-stamp {
    display: inline-block;
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--rr-color-primary);
