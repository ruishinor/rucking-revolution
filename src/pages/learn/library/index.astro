---
import Layout from '@/components/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { products } from '@/data/products';

// Get published products only
const publishedProducts = products.filter(p => p.published !== false);

// Get featured products (limit to 6)
const featuredProducts = publishedProducts.slice(0, 6);
---

<Layout title="Digital Library - Rucking Revolution" description="Expertly crafted guides, books, and training materials">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">DIGITAL LIBRARY</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Expertly crafted guides, books, and training materials to elevate your rucking practice
        </p>
      </div>

      {featuredProducts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {featuredProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-muted-foreground">
          <p>No products available at this time.</p>
        </div>
      )}

      <div class="mt-12 text-center">
        <a href="/library" class="btn btn-primary">
          VIEW FULL LIBRARY
        </a>
      </div>
    </div>
  </div>
</Layout>
