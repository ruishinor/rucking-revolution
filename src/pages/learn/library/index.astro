---
import Layout from '@/components/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { products } from '@/data/products';

// Get published products only
const publishedProducts = products.filter(p => p.published !== false);

// Get lead book and coming soon products
const leadBook = publishedProducts.find(p => p.id === 'your-first-ruck');
const comingSoonProducts = publishedProducts.filter(p => p.id === 'coming-soon');
const otherProducts = publishedProducts.filter(p => p.id !== 'your-first-ruck' && p.id !== 'coming-soon');
---

<Layout title="Digital Library - Rucking Revolution" description="Expertly crafted guides, books, and training materials">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">DIGITAL LIBRARY</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Expertly crafted guides, books, and training materials to elevate your rucking practice
        </p>
      </div>

      <!-- E-Commerce Teaser: Featured Product -->
      {leadBook && (
        <section class="mb-12 border border-border rounded-lg p-6 bg-white" aria-labelledby="featured-product-heading">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <!-- Product Image -->
            <div class="aspect-[4/5] bg-panel overflow-hidden rounded">
              <img 
                src={leadBook.previewImages[0]?.src}
                alt={leadBook.previewImages[0]?.alt || leadBook.title}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <!-- Product Details -->
            <div>
              <span class="label-mono block mb-2">Quiet Momentum release</span>
              <h2 id="featured-product-heading" class="text-3xl font-heading text-secondary mb-3">
                {leadBook.title}
              </h2>
              <p class="text-muted-foreground text-base leading-relaxed mb-6">
                {leadBook.description}
              </p>
              <!-- Status and Pricing -->
              <div class="flex items-center gap-6 mb-6">
                <div>
                  <span class="label-mono block mb-1">Status</span>
                  <span class="text-sm font-bold text-green-700 bg-green-100 px-3 py-1 rounded-full">Available Now</span>
                </div>
                <div>
                  <span class="label-mono block mb-1">Price</span>
                  <span class="text-2xl font-bold text-secondary">€{leadBook.priceEUR.toFixed(2)}</span>
                </div>
              </div>
              <!-- Feature List -->
              {leadBook.whatYouLearn && leadBook.whatYouLearn.length > 0 && (
                <div class="border border-border rounded p-4 mb-6">
                  <h3 class="font-heading text-xs text-secondary mb-3 tracking-wider uppercase">Inside</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground" aria-label="Product features">
                    {leadBook.whatYouLearn.map((feature) => (
                      <li class="flex items-start gap-2">
                        <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                          </svg>
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              <!-- Purchase Link -->
              <a href={leadBook.purchaseLink} class="btn btn-primary" aria-label={`View details for ${leadBook.title}`}>
                View Book Details
              </a>
            </div>
          </div>
        </section>
      )}

      <!-- Product Grid -->
      {otherProducts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
          {otherProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <!-- E-Commerce Teaser: Coming Soon placeholder -->
        <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
          {comingSoonProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      )}

      <!-- VIEW FULL LIBRARY -->
      <div class="mt-12 text-center">
        <a href="/library" class="btn btn-primary" aria-label="View all products in the library">
          VIEW FULL LIBRARY
        </a>
      </div>
    </div>
  </div>
</Layout>
