---
import Layout from '@/components/Layout.astro';
---
<Layout title="Learn - Rucking Revolution" description="Knowledge base for rucking discipline, leadership, and field-tested methods." currentPage="/learn">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">LEARN</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Build your knowledge base with field-tested methods, leadership principles, and practical guides for rucking as a discipline and lifestyle.
        </p>
      </div>

       <section class="mb-12">
         <h2 class="text-2xl font-heading text-white bg-[#8a1e1e] px-3 py-2 rounded mb-6">KNOWLEDGE BASE</h2>
         <div class="grid gap-6 md:grid-cols-3">
           <a href="/learn/articles" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
             <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">ARTICLES</h3>
             <p class="text-muted-foreground text-sm">
               In-depth articles covering rucking discipline, leadership, and field activities.
             </p>
           </a>
           <a href="/learn/library" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
             <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">DIGITAL LIBRARY</h3>
             <p class="text-muted-foreground text-sm">
               Expertly crafted guides, books, and training materials.
             </p>
           </a>
           <a href="/learn/after-action-reviews" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
             <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">AFTER ACTION REVIEWS</h3>
             <p class="text-muted-foreground text-sm">
               Community reflections and lessons learned from ruck events.
             </p>
           </a>
         </div>
       </section>

       <section class="mb-12">
         <h2 class="text-2xl font-heading text-white bg-[#8a1e1e] px-3 py-2 rounded mb-6">RESOURCES</h2>
         <div class="grid gap-6 md:grid-cols-2">
           <a href="/learn/knowledgebase/recommended-reading" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
             <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">RECOMMENDED READING</h3>
             <p class="text-muted-foreground text-sm">
               Curated book recommendations with affiliate links to Amazon.
             </p>
           </a>
           <a href="/learn/knowledgebase/international-events" class="group block p-6 border border-border card-border hover:border-primary hover:text-primary transition-colors">
             <h3 class="text-xl font-heading text-secondary mb-2 group-hover:text-primary">INTERNATIONAL EVENTS</h3>
             <p class="text-muted-foreground text-sm">
               Overview of recurring rucking and walking events worldwide.
             </p>
           </a>
         </div>
       </section>

       <section>
         <h2 class="text-2xl font-heading text-white bg-[#8a1e1e] px-3 py-2 rounded mb-6">SUPPORTING RESOURCES</h2>
         <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
           <a href="/why-rucking" class="group block p-4 border border-border card-border hover:border-primary transition-colors text-center">
             <span class="font-heading text-secondary group-hover:text-primary">WHY RUCKING</span>
           </a>
           <a href="/routes" class="group block p-4 border border-border card-border hover:border-primary transition-colors text-center">
             <span class="font-heading text-secondary group-hover:text-primary">ROUTES</span>
           </a>
           <a href="/events" class="group block p-4 border border-border card-border hover:border-primary transition-colors text-center">
             <span class="font-heading text-secondary group-hover:text-primary">EVENTS</span>
           </a>
           <a href="/field-notes" class="group block p-4 border border-border card-border hover:border-primary transition-colors text-center">
             <span class="font-heading text-secondary group-hover:text-primary">FIELD NOTES</span>
           </a>
         </div>
       </section>
    </div>
  </div>
</Layout>
