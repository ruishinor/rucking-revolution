---
import Layout from '@/components/Layout.astro';
---
<Layout title="Learn - Rucking Revolution" description="Knowledge base for rucking discipline, leadership, and field-tested methods.">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">LEARN</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Build your knowledge base with field-tested methods, leadership principles, and practical guides for rucking as a discipline and lifestyle.
        </p>
      </div>

      <section class="mb-12">
        <h2 class="text-2xl font-heading text-secondary mb-6">KNOWLEDGE BASE</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <a href="/learn/articles" class="block p-6 border border-border card-border hover:border-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2">ARTICLES</h3>
            <p class="text-muted-foreground text-sm">
              In-depth articles covering rucking discipline, leadership, and field activities.
            </p>
          </a>
          <a href="/learn/library" class="block p-6 border border-border card-border hover:border-primary transition-colors">
            <h3 class="text-xl font-heading text-secondary mb-2">DIGITAL LIBRARY</h3>
            <p class="text-muted-foreground text-sm">
              Expertly crafted guides, books, and training materials.
            </p>
          </a>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-heading text-secondary mb-6">SUPPORTING RESOURCES</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a href="/why-rucking" class="block p-4 border border-border card-border hover:border-primary transition-colors text-center">
            <span class="font-heading text-secondary">WHY RUCKING</span>
          </a>
          <a href="/routes" class="block p-4 border border-border card-border hover:border-primary transition-colors text-center">
            <span class="font-heading text-secondary">ROUTES</span>
          </a>
          <a href="/events" class="block p-4 border border-border card-border hover:border-primary transition-colors text-center">
            <span class="font-heading text-secondary">EVENTS</span>
          </a>
          <a href="/field-notes" class="block p-4 border border-border card-border hover:border-primary transition-colors text-center">
            <span class="font-heading text-secondary">FIELD NOTES</span>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
