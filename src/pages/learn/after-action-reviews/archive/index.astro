---
import Layout from '@/components/Layout.astro';
import { aarEntries } from '@/data/aar';

const approvedAARs = aarEntries.filter(aar => aar.approved);

approvedAARs.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const groupedByYear = approvedAARs.reduce((acc, aar) => {
  const year = new Date(aar.date).getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(aar);
  return acc;
}, {} as Record<string, typeof approvedAARs>);

const years = Object.keys(groupedByYear).sort((a, b) => parseInt(b) - parseInt(a));

function formatWeight(weight?: number, unit?: 'kg' | 'lbs', legacyLoad?: number): string {
  const w = weight ?? legacyLoad;
  if (w === undefined) return 'N/A';
  return `${w} ${unit || 'kg'}`;
}

function getParticipantsCount(aar: typeof approvedAARs[0]): string {
  const started = aar.participantsStarted;
  const completed = aar.participantsCompleted;
  const legacy = aar.participants;
  
  if (started !== undefined && completed !== undefined) {
    return `${completed}/${started}`;
  }
  if (completed !== undefined) return String(completed);
  if (started !== undefined) return String(started);
  if (legacy !== undefined) return String(legacy);
  return 'N/A';
}
---
<Layout 
  title="AAR Archive | Rucking Revolution"
  description="Browse the archive of After Action Reviews from ruck crews across the network."
>
  <div class="bg-surface py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-12">
        <a 
          href="/learn/after-action-reviews" 
          class="inline-flex items-center text-primary hover:text-primary-dark font-medium mb-4"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to AAR Overview
        </a>
        <div class="text-center mb-8">
          <h1 class="text-4xl font-heading text-secondary mb-4">AAR ARCHIVE</h1>
          <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
            Browse {approvedAARs.length} After Action Reviews from crews across the network. Learn from real experiences.
          </p>
        </div>
      </header>

      {approvedAARs.length > 0 ? (
        <div class="space-y-12">
          {years.map((year) => (
            <section>
              <h2 class="text-2xl font-heading text-secondary mb-6 flex items-center">
                <span class="bg-primary/10 text-primary border border-primary/20 px-3 py-1 rounded mr-3 font-heading">{year}</span>
                <span class="text-muted text-lg">{groupedByYear[year].length} {groupedByYear[year].length === 1 ? 'entry' : 'entries'}</span>
              </h2>
              
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {groupedByYear[year].map((aar) => (
                  <article class="bg-background rounded-lg shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-border">
                    <!-- Card Header -->
                    <div class="bg-primary/5 border-b border-border px-6 py-4">
                      <p class="text-muted text-xs uppercase tracking-wider">
                        {new Date(aar.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}
                      </p>
                      <h3 class="text-lg font-heading text-secondary line-clamp-2">{aar.title}</h3>
                    </div>
                    
                    <!-- Card Body -->
                    <div class="p-6">
                      <p class="text-muted-foreground text-sm mb-4 line-clamp-3">
                        {aar.conditions}
                      </p>
                      
                      <!-- Stats - Only show if available -->
                      {(aar.distance !== undefined || aar.individualWeight !== undefined || aar.load !== undefined || aar.participantsStarted !== undefined || aar.participantsCompleted !== undefined || aar.participants !== undefined) && (
                        <div class="flex flex-wrap gap-2 mb-4">
                          {aar.distance !== undefined && (
                            <span class="inline-flex items-center bg-panel text-muted-foreground text-xs px-2 py-1 rounded">
                              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 7m0 13V7" />
                              </svg>
                              {aar.distance} km
                            </span>
                          )}
                          {(aar.individualWeight !== undefined || aar.load !== undefined) && (
                            <span class="inline-flex items-center bg-panel text-muted-foreground text-xs px-2 py-1 rounded">
                              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1" />
                              </svg>
                              {formatWeight(aar.individualWeight, aar.individualWeightUnit, aar.load)}
                            </span>
                          )}
                          {(aar.participantsStarted !== undefined || aar.participantsCompleted !== undefined || aar.participants !== undefined) && (
                            <span class="inline-flex items-center bg-panel text-muted-foreground text-xs px-2 py-1 rounded">
                              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                              </svg>
                              {getParticipantsCount(aar)}
                            </span>
                          )}
                        </div>
                      )}
                      
                      <!-- Author -->
                      <p class="text-muted text-xs mb-4">
                        By {aar.author}
                      </p>
                      
                      <!-- View Button -->
                      <a 
                        href={`/learn/after-action-reviews/${aar.id}`}
                        class="block w-full text-center bg-primary text-white px-4 py-2 rounded hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-sm font-medium"
                      >
                        View Full AAR
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="bg-background border border-border rounded-lg p-8 text-center">
          <svg class="w-16 h-16 text-muted-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h2 class="text-xl font-heading text-secondary mb-2">NO AARS AVAILABLE YET</h2>
          <p class="text-muted-foreground mb-4">
            The archive is empty. Be the first to submit an After Action Review!
          </p>
          <a 
            href="/learn/after-action-reviews/submit" 
            class="inline-block bg-primary text-white px-6 py-2 rounded hover:bg-primary-dark transition-colors font-medium"
          >
            Submit an AAR
          </a>
        </div>
      )}

      <!-- Footer Navigation -->
      <nav class="mt-12 pt-8 border-t border-border">
        <div class="flex flex-wrap justify-center gap-4">
          <a 
            href="/learn/after-action-reviews" 
            class="text-primary hover:text-primary-dark font-medium"
          >
            &larr; AAR Overview
          </a>
          <span class="text-border">|</span>
          <a 
            href="/learn/after-action-reviews/submit" 
            class="text-primary hover:text-primary-dark font-medium"
          >
            Submit an AAR
          </a>
          <span class="text-border">|</span>
          <a 
            href="/learn" 
            class="text-primary hover:text-primary-dark font-medium"
          >
            Back to Learn
          </a>
        </div>
      </nav>
    </div>
  </div>
</Layout>
