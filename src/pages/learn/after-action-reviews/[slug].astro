---
import Layout from '@/components/Layout.astro';
import { aarEntries } from '@/data/aar';

const { slug } = Astro.params;

const aar = aarEntries.find((entry) => entry.id === slug);

if (!aar) {
  return Astro.redirect('/learn/after-action-reviews/archive');
}

export async function getStaticPaths() {
  return aarEntries.map(aar => ({
    params: { slug: aar.id },
    props: { aar }
  }));
}

function formatDuration(minutes?: number): string {
  if (minutes === undefined) return 'N/A';
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  return hours > 0 ? `${hours}h ${mins}m` : `${mins}m`;
}

function formatWeight(weight?: number, unit?: 'kg' | 'lbs'): string {
  if (weight === undefined) return 'N/A';
  return `${weight} ${unit || 'kg'}`;
}

function getParticipantsCount(): string {
  const started = aar.participantsStarted;
  const completed = aar.participantsCompleted;
  const legacy = aar.participants;
  
  if (started !== undefined && completed !== undefined) {
    return `${completed}/${started}`;
  }
  if (completed !== undefined) {
    return String(completed);
  }
  if (started !== undefined) {
    return String(started);
  }
  if (legacy !== undefined) {
    return String(legacy);
  }
  return 'N/A';
}
---
<Layout 
  title={`${aar.title} | After Action Review`}
  description={`After Action Review: ${aar.title} - ${aar.conditions}`}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Back Navigation -->
    <nav class="mb-8">
      <a 
        href="/learn/after-action-reviews/archive" 
        class="inline-flex items-center text-red-800 hover:text-red-900 font-medium"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Archive
      </a>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-red-800 text-white text-sm font-medium px-3 py-1 rounded">
          {new Date(aar.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{aar.title}</h1>
      <p class="text-lg text-gray-600">
        By <span class="font-medium text-red-800">{aar.author}</span>
      </p>
    </header>

    <!-- Quick Stats - Optional Fields Grid -->
    {(aar.distance !== undefined || aar.duration !== undefined || aar.individualWeight !== undefined || aar.load !== undefined || aar.participantsStarted !== undefined || aar.participantsCompleted !== undefined || aar.participants !== undefined || aar.classNumber !== undefined || aar.originalText !== undefined) && (
      <div class="bg-gray-50 rounded-lg p-6 mb-8">
        {aar.originalText && (
          <div class="mb-4 pb-4 border-b border-gray-200">
            <p class="text-sm text-gray-500 mb-1">Original Notes</p>
            <p class="text-gray-700 whitespace-pre-wrap">{aar.originalText}</p>
          </div>
        )}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {aar.classNumber && (
            <div class="text-center">
              <p class="text-sm text-gray-500 mb-1">Class</p>
              <p class="text-lg font-bold text-red-800">{aar.classNumber}</p>
            </div>
          )}
          {aar.participantsStarted !== undefined || aar.participantsCompleted !== undefined || aar.participants !== undefined ? (
            <div class="text-center">
              <p class="text-sm text-gray-500 mb-1">Participants</p>
              <p class="text-2xl font-bold text-red-800">{getParticipantsCount()}</p>
            </div>
          ) : null}
          {aar.distance !== undefined && (
            <div class="text-center">
              <p class="text-sm text-gray-500 mb-1">Distance</p>
              <p class="text-2xl font-bold text-red-800">{aar.distance}<span class="text-base font-normal text-gray-600"> km</span></p>
            </div>
          )}
          {(aar.individualWeight !== undefined || aar.load !== undefined) && (
            <div class="text-center">
              <p class="text-sm text-gray-500 mb-1">Weight</p>
              <p class="text-2xl font-bold text-red-800">{formatWeight(aar.individualWeight || aar.load, aar.individualWeightUnit)}</p>
            </div>
          )}
          {aar.duration !== undefined && (
            <div class="text-center">
              <p class="text-sm text-gray-500 mb-1">Duration</p>
              <p class="text-2xl font-bold text-red-800">{formatDuration(aar.duration)}</p>
            </div>
          )}
        </div>
        <div class="mt-4 pt-4 border-t border-gray-200">
          <p class="text-gray-700">
            <span class="font-medium">Conditions:</span> {aar.conditions}
          </p>
        </div>
      </div>
    )}

    <!-- AAR Framework Sections - Updated Grid Layout -->
    <article class="space-y-8">
      <!-- What Was Planned -->
      <section>
        <h2 class="text-2xl font-bold text-red-800 mb-4 flex items-center">
          <span class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center text-red-800 text-sm mr-3">1</span>
          What Was Planned
        </h2>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <ul class="space-y-3">
            {aar.planned.map((item, index) => (
              <li class="flex items-start">
                <span class="text-red-800 font-medium mr-3">{index + 1}.</span>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
      
      <!-- What Actually Happened -->
      <section>
        <h2 class="text-2xl font-bold text-red-800 mb-4 flex items-center">
          <span class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center text-red-800 text-sm mr-3">2</span>
          What Actually Happened
        </h2>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <ul class="space-y-3">
            {aar.actual.map((item, index) => (
              <li class="flex items-start">
                <span class="text-red-800 font-medium mr-3">{index + 1}.</span>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
      
      <!-- What Went Well -->
      <section>
        <h2 class="text-2xl font-bold text-green-700 mb-4 flex items-center">
          <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-700 text-sm mr-3">3</span>
          What Went Well
        </h2>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <ul class="space-y-3">
            {aar.whatWentWell.map((item, index) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-600 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
      
      <!-- What Could Be Improved -->
      <section>
        <h2 class="text-2xl font-bold text-amber-700 mb-4 flex items-center">
          <span class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center text-amber-700 text-sm mr-3">4</span>
          What Could Be Improved
        </h2>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <ul class="space-y-3">
            {aar.improvements.map((item, index) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 text-amber-600 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
      
      <!-- Lessons Learned -->
      <section>
        <h2 class="text-2xl font-bold text-primary mb-4 flex items-center">
          <span class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center text-primary text-sm mr-3">5</span>
          Lessons Learned
        </h2>
        <div class="bg-primary/5 border border-primary/10 rounded-lg p-6">
          <ul class="space-y-3">
            {aar.lessonsLearned.map((item, index) => (
              <li class="flex items-start">
                <span class="w-6 h-6 bg-primary/10 rounded-full flex items-center justify-center text-primary text-xs font-bold mr-3 flex-shrink-0">
                  {index + 1}
                </span>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </article>

    <!-- Footer Navigation -->
    <nav class="mt-12 pt-8 border-t border-gray-200">
      <div class="flex flex-wrap justify-center gap-4">
        <a 
          href="/learn/after-action-reviews/archive" 
          class="inline-flex items-center text-red-800 hover:text-red-900 font-medium"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Archive
        </a>
        <span class="text-gray-300">|</span>
        <a 
          href="/learn/after-action-reviews/submit" 
          class="text-red-800 hover:text-red-900 font-medium"
        >
          Submit Your AAR
        </a>
        <span class="text-gray-300">|</span>
        <a 
          href="/learn/after-action-reviews" 
          class="text-red-800 hover:text-red-900 font-medium"
        >
          AAR Overview
        </a>
      </div>
    </nav>
  </div>
</Layout>