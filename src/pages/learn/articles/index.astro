---
import Layout from '@/components/Layout.astro';
import { articles } from '@/data/articles';
import { existsSync } from 'node:fs';

const publicAssetExists = (assetPath) =>
  existsSync(new URL(`../../../public${assetPath}`, import.meta.url));

// Get featured/recent articles (limit to 6)
const featuredArticles = articles.slice(0, 6).map(article => ({
  ...article,
  hasHeroImage: publicAssetExists(article.heroImage.src),
}));
---

<Layout title="Articles - Rucking Revolution" description="In-depth articles covering rucking discipline, leadership, and field activities">
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">ARTICLES</h1>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          In-depth articles covering rucking discipline, leadership, and field activities
        </p>
      </div>

      {featuredArticles.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {featuredArticles.map(article => (
            <article class="card-border flex flex-col h-full border border-border hover:border-primary transition-colors">
              {/* Hero Image */}
              {article.hasHeroImage ? (
                <a href={`/articles/${article.slug}`} class="mb-0">
                  <img 
                    src={article.heroImage.src} 
                    alt={article.heroImage.alt} 
                    class="w-full h-48 object-cover"
                    loading="lazy"
                  />
                </a>
              ) : (
                <a href={`/articles/${article.slug}`} class="mb-0 block">
                  <div class="w-full h-48 bg-muted flex items-center justify-center">
                    <span class="text-muted-foreground text-sm font-mono">NO IMAGE</span>
                  </div>
                </a>
              )}
              
              {/* Article Content */}
              <div class="flex-1 p-4">
                <h2 class="text-xl font-heading text-secondary mb-2 line-clamp-2">
                  <a href={`/articles/${article.slug}`} class="hover:underline">
                    {article.title}
                  </a>
                </h2>
                <p class="text-muted-foreground mb-3 line-clamp-3 text-sm">{article.excerpt}</p>
                
                {/* Meta Info */}
                <div class="flex flex-wrap gap-3 text-xs font-mono text-muted-foreground mt-auto">
                  <span>BY {article.author.toUpperCase()}</span>
                  <span>
                    <time dateTime={article.date}>
                      {new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </time>
                  </span>
                  <span>{article.readingTime} MIN READ</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-muted-foreground">
          <p>No articles available at this time.</p>
        </div>
      )}

      <div class="mt-12 text-center">
        <a href="/articles" class="btn btn-primary">
          VIEW ALL ARTICLES
        </a>
      </div>
    </div>
  </div>
</Layout>
