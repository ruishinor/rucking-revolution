---
import { site } from '@/data/site';
import { articles } from '@/data/articles';
import Layout from '@/components/Layout.astro';
import { existsSync } from 'node:fs';

const publicAssetExists = (assetPath) =>
  existsSync(new URL(`../../../../../public${assetPath}`, import.meta.url));

const allTags = [...new Set(articles.flatMap(article => article.tags))];

export async function getStaticPaths() {
  const tags = [...new Set(articles.flatMap(article => article.tags))];
  return tags.map(tag => ({
    params: { tag }
  }));
}

const { tag } = Astro.params;
const currentTag = tag;

if (!currentTag || !allTags.includes(currentTag)) {
  return Astro.redirect('/learn/articles');
}

const filteredArticles = articles.filter(article => article.tags.includes(currentTag));
const sortedArticles = [...filteredArticles].sort((a, b) => 
  new Date(b.date).getTime() - new Date(a.date).getTime()
);

const pageSize = 6;
const totalPages = Math.max(1, Math.ceil(sortedArticles.length / pageSize));
const currentPage = 1;

const paginatedArticles = sortedArticles.slice(0, pageSize);

const articleCards = paginatedArticles.map((article) => ({
  ...article,
  hasHeroImage: publicAssetExists(article.heroImage.src),
}));

const displayTag = currentTag.split('-').map(word => 
  word.charAt(0).toUpperCase() + word.slice(1)
).join(' ');

const pageTitle = `${displayTag} Articles - Rucking Revolution`;
const pageDescription = `Explore our collection of ${displayTag.toLowerCase()} articles on rucking, leadership, and community resilience.`;
---
<Layout 
  title={pageTitle}
  description={pageDescription}
  openGraph={{
    type: 'website',
    url: `${site.baseUrl}/learn/articles/tag/${currentTag}`,
    image: `${site.baseUrl}/og-articles.jpg`
  }}
  twitter={{ card: 'summary_large_image' }}
>
  <div class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-heading text-secondary mb-4">{displayTag.toUpperCase()} ARTICLES</h1>
        <p class="text-sm font-mono text-muted-foreground mb-2">
          {sortedArticles.length} article{sortedArticles.length !== 1 ? 's' : ''} found
        </p>
        <p class="text-lg font-serif text-muted-foreground max-w-3xl mx-auto">
          Explore our collection of articles tagged with {displayTag.toLowerCase()}.
        </p>
      </div>

      <div class="mb-6 flex flex-wrap gap-2 justify-center">
        <a 
          href="/learn/articles" 
          class="px-4 py-2 text-sm font-medium border transition-colors card-border bg-surface text-muted-foreground border-border hover:border-primary hover:text-primary"
        >
          ALL
        </a>
        {allTags.map(t => (
          <a 
            href={`/learn/articles/tag/${t}`} 
            class={`px-4 py-2 text-sm font-medium border transition-colors card-border
              ${currentTag === t ? 'bg-primary text-white border-primary' : 'bg-surface text-muted-foreground border-border hover:border-primary hover:text-primary'}`}
          >
            {t.toUpperCase()}
          </a>
        ))}
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articleCards.map(article => (
          <article class="card-border flex flex-col h-full border border-border hover:border-primary transition-colors">
            {article.hasHeroImage ? (
              <a href={`/learn/articles/${article.slug}`} class="mb-0">
                <img 
                  src={article.heroImage.src} 
                  alt={article.heroImage.alt} 
                  class="w-full h-48 object-cover"
                  loading="lazy"
                />
              </a>
            ) : (
              <a href={`/learn/articles/${article.slug}`} class="mb-0 block">
                <div class="w-full h-48 bg-muted flex items-center justify-center">
                  <span class="text-muted-foreground text-sm font-mono">NO IMAGE</span>
                </div>
              </a>
            )}
            <div class="flex-0 p-4">
              <h2 class="text-xl font-heading text-secondary mb-2 line-clamp-2">
                <a href={`/learn/articles/${article.slug}`} class="hover:underline">{article.title}</a>
              </h2>
              <p class="text-muted-foreground mb-2 line-clamp-3 text-sm">{article.excerpt}</p>
              <div class="flex flex-wrap gap-3 text-xs font-mono text-muted-foreground mt-auto">
                <span>BY {article.author.toUpperCase()}</span>
                <time dateTime={article.date}>
                  {new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span>{article.readingTime} MIN READ</span>
              </div>
            </div>
          </article>
        ))}

        {paginatedArticles.length === 0 && (
          <div class="col-span-full text-center py-12">
            <p class="text-muted-foreground">No articles found for this category.</p>
            <a href="/learn/articles" class="mt-4 inline-block text-primary hover:underline">Browse All Articles</a>
          </div>
        )}
      </div>

      {totalPages > 1 && (
        <div class="mt-8 flex justify-center gap-2">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
            <a 
              href={page === 1 ? `/learn/articles/tag/${currentTag}` : `/learn/articles/tag/${currentTag}/${page}`} 
              class={`px-4 py-2 text-sm font-medium border transition-colors card-border
                ${page === currentPage ? 'bg-primary text-white border-primary' : 'bg-surface text-muted-foreground border-border hover:border-primary hover:text-primary'}`}
            >
              {page}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>
