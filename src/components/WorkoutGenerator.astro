---
import { workouts } from '@/data/workouts.ts';
---

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="bg-white rounded-lg shadow-md p-6">
    <h1 class="text-2xl font-bold text-center mb-6 text-red-800">Workout Generator</h1>
    
    <div id="workout-generator-error" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6" role="alert"></div>
    
    <form id="workout-form" class="space-y-6">
      <div>
        <label for="mode" class="block text-sm font-medium text-gray-700 mb-2">
          Workout Type
        </label>
        <select 
          id="mode"
          name="mode"
          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        >
          <option value="generated">Generate New Workout</option>
          <option value="predefined">Choose from Database</option>
        </select>
      </div>
      
      <div>
        <label for="difficulty" class="block text-sm font-medium text-gray-700 mb-2">
          Difficulty Level
        </label>
        <select 
          id="difficulty"
          name="difficulty"
          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        >
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </div>
      
      <div id="timePreferenceContainer">
        <label for="timePreference" class="block text-sm font-medium text-gray-700 mb-2">
          Preferred Total Time (minutes) - Optional
        </label>
        <input
          id="timePreference"
          name="timePreference"
          type="number"
          min="30"
          max="180"
          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
          placeholder="Leave blank for random duration"
        />
        <p class="mt-1 text-xs text-gray-500">
          Specify your preferred workout duration (30-180 minutes). The generator will adjust section times accordingly.
        </p>
      </div>
      
      <div class="flex justify-end">
        <button 
          type="submit"
          class="bg-red-800 text-white px-6 py-2 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus:ring-offset-2 transition-colors"
        >
          Generate Workout
        </button>
      </div>
    </form>
    
    <div id="generated-workout" class="hidden">
      <h2 id="workout-title" class="text-xl font-bold mb-4"></h2>
      <p id="workout-description" class="text-gray-600 mb-4"></p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-50 p-3 rounded">
          <h3 class="text-sm font-medium text-gray-700">Duration</h3>
          <p id="workout-duration" class="text-gray-900"></p>
        </div>
        <div class="bg-gray-50 p-3 rounded">
          <h3 class="text-sm font-medium text-gray-700">Distance</h3>
          <p id="workout-distance" class="text-gray-900"></p>
        </div>
        <div class="bg-gray-50 p-3 rounded">
          <h3 class="text-sm font-medium text-gray-700">Load</h3>
          <p id="workout-load" class="text-gray-900"></p>
        </div>
        <div class="bg-gray-50 p-3 rounded">
          <h3 class="text-sm font-medium text-gray-700">Difficulty</h3>
          <p id="workout-difficulty" class="text-gray-900 capitalize"></p>
        </div>
        <div class="bg-gray-50 p-3 rounded">
          <h3 class="text-sm font-medium text-gray-700">Terrain</h3>
          <p id="workout-terrain" class="text-gray-900"></p>
        </div>
      </div>
      
      <div class="mb-6">
        <h3 class="text-lg font-medium mb-2 bg-[#8a1e1e] text-white px-3 py-2 rounded">Objectives</h3>
        <ul id="workout-objectives" class="list-disc list-inside space-y-1 text-gray-700 mt-2"></ul>
      </div>
      
      <div class="mb-6">
        <h3 class="text-lg font-medium mb-2 bg-[#8a1e1e] text-white px-3 py-2 rounded">Equipment</h3>
        <p id="workout-equipment" class="text-gray-700 mt-2"></p>
      </div>
      
      <div class="mb-6">
        <h3 class="text-lg font-medium mb-2 bg-[#8a1e1e] text-white px-3 py-2 rounded">Workout Sections</h3>
        <div id="workout-sections" class="mt-2"></div>
      </div>
      
      <div id="workout-notes" class="hidden bg-blue-50 p-4 rounded mb-6">
        <h3 class="text-lg font-medium mb-2 bg-[#8a1e1e] text-white px-3 py-2 rounded">Notes</h3>
        <p id="workout-notes-text" class="text-gray-800 mt-2"></p>
      </div>
      
      <div class="flex justify-end">
        <button 
          type="button"
          data-print-trigger="true"
          class="bg-gray-800 text-white px-4 py-2 rounded-md hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-800 focus:ring-offset-2 transition-colors"
        >
          Print Workout
        </button>
      </div>
    </div>
    
    {/* Sample Workouts Section */}
    <div class="mt-12 pt-8 border-t">
      <h2 class="text-2xl font-bold text-center mb-6 text-red-800">Sample Workouts</h2>
      <p class="text-center text-gray-600 mb-8">
        Browse our collection of {workouts.length} pre-designed workouts for different goals and experience levels.
      </p>
      
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {workouts.slice(0, 6).map((workout) => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 class="text-xl font-bold mb-2">{workout.title}</h3>
              <p class="text-gray-600 mb-4">{workout.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">{workout.difficulty}</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.duration} min</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.load}kg</span>
                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">{workout.distance}km</span>
              </div>
              <a 
                href={`/train/workouts/${workout.slug}`}
                class="block w-full text-center bg-red-800 text-white px-4 py-2 rounded-md hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-800 focus:ring-offset-2 transition-colors"
              >
                View Details
              </a>
            </div>
          </div>
        ))}
      </div>
      
      <div class="mt-6 text-center">
        <a 
          href="/train/workouts/all"
          class="text-red-800 hover:text-red-900 font-medium"
        >
          View All Workouts →
        </a>
      </div>
    </div>
  </div>
</div>

<script type="module" src="/scripts/workout-generator.js" is:inline></script>

<style>
  /* Print styles */
  @media print {
    .no-print {
      display: none !important;
    }
    
    body * {
      visibility: hidden;
    }
    
    .print-section, .print-section * {
      visibility: visible;
    }
    
    .print-section {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }
  }
</style>
