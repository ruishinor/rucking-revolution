---
const { crewTactic } = Astro.props;
---
<div class="m-4 flex h-full flex-col rounded-[1.25rem] border border-muted-200 bg-white/95 p-6 shadow-[0_18px_36px_rgba(28,28,28,0.08)]">
  <h2 class="mb-4 text-2xl font-bold capitalize text-foreground">
    {crewTactic.category}
  </h2>
  <p class="flex-grow text-xl leading-relaxed text-foreground">
    {crewTactic.text}
  </p>
  {crewTactic.prompts.length > 0 && (
    <div class="mt-4 space-y-2 text-base text-muted-foreground">
      <h3 class="mb-1 font-semibold text-foreground">Prompts:</h3>
      <ul class="list-disc list-inside text-left space-y-1">
        {crewTactic.prompts.map((prompt, index) => (
          <li key={index} class="pl-2">{prompt}</li>
        ))}
      </ul>
    </div>
  )}
  <div class="mt-4 text-sm font-medium text-muted">
    Difficulty: {crewTactic.difficulty} &bull; Duration: {crewTactic.duration}s
  </div>
</div>
