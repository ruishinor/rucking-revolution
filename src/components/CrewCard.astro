---
const { crewTactic } = Astro.props;
---
<div class="bg-white dark:bg-gray-900 border-2 border-gray-200 dark:border-gray-700 rounded-lg shadow-lg p-6 m-4 flex flex-col h-full">
  <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100 capitalize">
    {crewTactic.category}
  </h2>
  <p class="text-xl text-gray-800 dark:text-gray-200 flex-grow leading-relaxed">
    {crewTactic.text}
  </p>
  {crewTactic.prompts.length > 0 && (
    <div class="mt-4 text-base text-gray-700 dark:text-gray-300 space-y-2">
      <h3 class="font-semibold mb-1 text-gray-900 dark:text-gray-100">Prompts:</h3>
      <ul class="list-disc list-inside text-left space-y-1">
        {crewTactic.prompts.map((prompt, index) => (
          <li key={index} class="pl-2">{prompt}</li>
        ))}
      </ul>
    </div>
  )}
  <div class="mt-4 text-sm text-gray-600 dark:text-gray-400 font-medium">
    Difficulty: {crewTactic.difficulty} &bull; Duration: {crewTactic.duration}s
  </div>
</div>