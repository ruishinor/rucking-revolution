---
interface Props {
  alt: string;
  aspectRatio?: string;
}

const { alt, aspectRatio = 'pb-[56.25%]' } = Astro.props;
---

<div class={`relative w-full h-0 ${aspectRatio} bg-gray-200 rounded-lg`}>
  <div class="absolute inset-0 flex items-center justify-center bg-gray-100 text-gray-500">
    <div class="text-center p-4">
      <svg class="w-16 h-16 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <p class="text-sm">{alt}</p>
    </div>
  </div>
</div>
