---
import CrewCard from '@/components/CrewCard.astro';
import { crewTactics } from '../../data/crewTactics';

let { category = 'all' } = Astro.props;
---

<div class="space-y-6">
  <!-- Controls -->
  <div class="flex flex-wrap items-center gap-4">
    <button 
      id="drawOneBtn"
      class="btn btn-primary btn-md"
      aria-label="Draw one card"
    >
      Draw 1 Card
    </button>
    <button 
      id="drawThreeBtn"
      class="btn btn-secondary btn-md"
      aria-label="Draw three cards"
    >
      Draw 3 Cards
    </button>
    <select 
      id="categoryFilter"
      class="rounded-border border border-muted-200 bg-white px-3 py-2 text-foreground focus:outline-none focus:ring-2 focus:ring-accent"
      aria-label="Filter by category"
    >
      <option value="all" {category === 'all' && 'selected'}>All Categories</option>
      <option value="Leadership" {category === 'Leadership' && 'selected'}>Leadership</option>
      <option value="Communication" {category === 'Communication' && 'selected'}>Communication</option>
      <option value="Decision Making" {category === 'Decision Making' && 'selected'}>Decision Making</option>
      <option value="Adaptability" {category === 'Adaptability' && 'selected'}>Adaptability</option>
    </select>
    <button 
      id="shuffleBtn"
      class="btn btn-utility btn-md"
      aria-label="Shuffle deck"
    >
      Shuffle Deck
    </button>
  </div>

  <!-- Cards Container -->
  <div id="cardsContainer" class="grid gap-6 swipe-area" data-swipe-enabled="true" role="region" aria-label="Drawn tactic cards">
    <!-- Cards will be populated by client-side JavaScript -->
  </div>

  <!-- Status -->
  <div id="status" class="text-center text-muted" aria-live="polite">
    <span class="sr-only">Loading cards</span>
  </div>
</div>

<!-- Client-side script for interactivity -->
<script client:idle>
  // We'll define the CardGenerator class here since we can't import TS files directly in client-side script
  class CardGenerator {
    constructor(allTactics) {
      this.originalTactics = allTactics;
      this.allTactics = [...allTactics];
      this.deck = [...allTactics];
      this.lastDrawn = null;
      this.shuffleDeck();
    }

    shuffleDeck() {
      for (let i = this.deck.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [this.deck[i], this.deck[j]] = [this.deck[j], this.deck[i]];
      }
    }

    reset() {
      this.allTactics = [...this.originalTactics];
      this.deck = [...this.allTactics];
      this.lastDrawn = null;
      this.shuffleDeck();
    }

    setCategory(category) {
      if (category === 'all' || !category) {
        this.allTactics = [...this.originalTactics];
      } else {
        this.allTactics = this.originalTactics.filter(tactic => tactic.category === category);
      }
      this.deck = [...this.allTactics];
      this.lastDrawn = null;
      this.shuffleDeck();
    }

    draw(n = 1) {
      if (this.deck.length === 0) {
        this.reset();
      }

      // Create available deck without the last drawn card
      let available = this.deck.filter(card => card.id !== this.lastDrawn?.id);
      if (available.length === 0) {
        available = [...this.deck]; // fallback to full deck if we have no other option
      }

      // Shuffle the available deck
      this.shuffleArray(available);

      // Draw min(n, available.length) cards
      const toDraw = Math.min(n, available.length);
      const drawn = available.slice(0, toDraw);

      // Remove the drawn cards from the main deck
      this.deck = this.deck.filter(card => !drawn.some(d => d.id === card.id));

      // Update lastDrawn
      if (drawn.length > 0) {
        this.lastDrawn = drawn[drawn.length - 1];
      }

      return drawn;
    }

    shuffleArray(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
    }
  }

  // Initialize generator with crewTactics data
  const crewTacticsData = JSON.parse('${JSON.stringify(crewTactics)}');
  let generator = new CardGenerator(crewTacticsData);
  const categoryFilter = document.getElementById('categoryFilter');
  if (categoryFilter.value !== 'all') {
    generator.setCategory(categoryFilter.value);
  }

  // DOM elements
  const drawOneBtn = document.getElementById('drawOneBtn');
  const drawThreeBtn = document.getElementById('drawThreeBtn');
  const shuffleBtn = document.getElementById('shuffleBtn');
  const cardsContainer = document.getElementById('cardsContainer');
  const statusEl = document.getElementById('status');

  // Update status function
  function updateStatus() {
    const drawnCount = cardsContainer.children.length;
    if (drawnCount === 0) {
      statusEl.textContent = 'Click a button above to draw cards';
    } else {
      statusEl.textContent = `Showing ${drawnCount} card${drawnCount !== 1 ? 's' : ''} from ${generator.allTactics.length} total tactics`;
    }
  }

  // Draw cards function
  function drawCards(count) {
    // Clear current cards
    cardsContainer.innerHTML = '';

    // Draw new cards
    const cards = generator.draw(count);

    // Create and append card elements
    cards.forEach(card => {
      const cardDiv = document.createElement('div');
      cardDiv.className = 'bg-white/95 border border-muted-200 rounded-[1.25rem] shadow-[0_18px_36px_rgba(28,28,28,0.08)] p-6 m-4 flex flex-col h-full swipe-card';
      cardDiv.innerHTML = `
        <h2 class="text-2xl font-bold mb-4 text-foreground capitalize">
          ${card.category}
        </h2>
        <p class="text-xl text-foreground flex-grow leading-relaxed">
          ${card.text}
        </p>
        ${card.prompts.length > 0 ? `
          <div class="mt-4 text-base text-muted-foreground space-y-2">
            <h3 class="font-semibold mb-1 text-foreground">Prompts:</h3>
            <ul class="list-disc list-inside text-left space-y-1">
              ${card.prompts.map(p => `<li class="pl-2">${p}</li>`).join('')}
            </ul>
          </div>
        ` : ''}
        <div class="mt-4 text-sm text-muted font-medium">
          Difficulty: ${card.difficulty} &bull; Duration: ${card.duration}s
        </div>
      `;
      cardsContainer.appendChild(cardDiv);
    });

    // Update status
    updateStatus();
  }

  // Event listeners
  drawOneBtn.addEventListener('click', () => drawCards(1));
  drawThreeBtn.addEventListener('click', () => drawCards(3));
  shuffleBtn.addEventListener('click', () => {
    generator.reset();
    if (categoryFilter.value !== 'all') {
      generator.setCategory(categoryFilter.value);
    }
    drawCards(3); // Redraw after shuffle
  });

  categoryFilter.addEventListener('change', (e) => {
    generator.setCategory(e.target.value);
    drawCards(3); // Redraw with new filter
  });

  // Keyboard accessibility
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (drawOneBtn.contains(document.activeElement) || drawThreeBtn.contains(document.activeElement))) {
      e.preventDefault();
      if (drawOneBtn.contains(document.activeElement)) drawCards(1);
      if (drawThreeBtn.contains(document.activeElement)) drawCards(3);
    }
    
    if (e.key === ' ' && shuffleBtn.contains(document.activeElement)) {
      e.preventDefault();
      generator.reset();
      if (categoryFilter.value !== 'all') {
        generator.setCategory(categoryFilter.value);
      }
      drawCards(3);
    }
  });

  // Swipe navigation for mobile
  let touchStartX = 0;
  let touchEndX = 0;
  
  // Check if swipe area exists
  if (cardsContainer) {
    cardsContainer.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    cardsContainer.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });
    
    function handleSwipe() {
      const swipeThreshold = 50; // minimum distance for a swipe
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          // Swipe left - draw next card
          drawCards(1);
        } else {
          // Swipe right - draw previous card (or just draw a new one for simplicity)
          drawCards(1);
        }
      }
    }
  }

  // Initial draw - show cards immediately
  drawCards(3);
</script>
