---
// Button Props
// variant: 'primary' | 'secondary' | 'utility'
// size: 'sm' | 'md' | 'lg'
const { variant = 'primary', size = 'md', class: className = '' } = Astro.props;

// Variant classes
const variantClasses = {
  primary: 'btn btn-primary',
  secondary: 'btn btn-secondary',
  utility: 'btn btn-utility'
};

// Size classes
const sizeClasses = {
  sm: 'btn-sm',
  md: 'btn-md',
  lg: 'btn-lg'
};
---
<button class={`${variantClasses[variant]} ${sizeClasses[size]} ${className}`}>
  <slot />
</button>
