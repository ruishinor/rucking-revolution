---
import type { Quote } from '@/data/quotes';

interface Props {
  quotes: Quote[];
}

const { quotes } = Astro.props;
const defaultQuote = quotes[Math.floor(Math.random() * quotes.length)];
---

<div class="quote-display" aria-label="Inspirational quote" data-quotes={JSON.stringify(quotes)}>
  <div class="quote-border-accent"></div>
  <blockquote class="quote-content">
    <p class="quote-text" id="quote-text">{defaultQuote.text}</p>
    <footer class="quote-source" id="quote-source">— {defaultQuote.source}</footer>
  </blockquote>
</div>

<script>
  function setRandomQuote() {
    const quoteDisplay = document.querySelector('.quote-display');
    if (!quoteDisplay) return;
    
    try {
      const quotes = JSON.parse(((quoteDisplay as HTMLElement).dataset?.quotes) || '[]');
      if (quotes.length === 0) return;
      
      // Get random index, ensure it's different from current if possible
      const currentText = document.getElementById('quote-text')?.textContent;
      let randomIndex;
      let attempts = 0;
      
      do {
        randomIndex = Math.floor(Math.random() * quotes.length);
        attempts++;
      } while (quotes[randomIndex].text === currentText && attempts < 10 && quotes.length > 1);
      
      const selectedQuote = quotes[randomIndex];
      
      const quoteText = document.getElementById('quote-text');
      const quoteSource = document.getElementById('quote-source');
      
      if (quoteText) quoteText.textContent = selectedQuote.text;
      if (quoteSource) quoteSource.textContent = `— ${selectedQuote.source}`;
    } catch (e) {
      // Fail silently - default quote will remain visible
      console.debug('Quote randomization failed:', e);
    }
  }

  // Run on initial page load
  document.addEventListener('DOMContentLoaded', setRandomQuote);
  
  // Run on Astro view transitions (client-side navigation)
  document.addEventListener('astro:page-load', setRandomQuote);
</script>

<style>
  .quote-display {
    position: relative;
    padding: 2rem 0 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    min-height: 180px;
  }

  .quote-border-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--rr-color-primary);
  }

  .quote-content {
    max-width: 420px;
  }

  .quote-text {
    font-family: var(--rr-font-serif);
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--rr-color-secondary);
    margin: 0 0 1rem 0;
    font-style: italic;
  }

  .quote-source {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rr-color-muted);
  }

  @media (max-width: 767px) {
    .quote-display {
      padding: 2rem 0 0 0;
      border-top: 1px solid var(--rr-color-border);
      margin-top: 2rem;
      min-height: auto;
    }

    .quote-border-accent {
      top: 0;
      left: 0;
      right: 0;
      bottom: auto;
      width: auto;
      height: 4px;
    }
  }
</style>
