---
import type { Quote } from '@/data/quotes';

interface Props {
  quotes: Quote[];
}

const { quotes } = Astro.props;
const defaultQuote = quotes[0];
const quotesJson = JSON.stringify(quotes);
---

<div class="quote-display" aria-label="Inspirational quote">
  <div class="quote-border-accent"></div>
  <blockquote class="quote-content">
    <p class="quote-text" id="quote-text" aria-live="polite">{defaultQuote.text}</p>
    <footer class="quote-source" id="quote-source">— {defaultQuote.source}</footer>
  </blockquote>
  <button class="quote-refresh" id="quote-refresh" aria-label="Get new quote">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="23 4 23 10 17 10"></polyline>
      <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
    </svg>
  </button>
</div>

<script define:vars={{ quotes: quotesJson }}>
  const parsedQuotes = JSON.parse(quotesJson);
  const quoteText = document.getElementById('quote-text');
  const quoteSource = document.getElementById('quote-source');
  const refreshBtn = document.getElementById('quote-refresh');
  let lastIndex = -1;

  function getRandomQuote() {
    if (parsedQuotes.length === 0) return null;
    let randomIndex;
    do {
      randomIndex = Math.floor(Math.random() * parsedQuotes.length);
    } while (randomIndex === lastIndex && parsedQuotes.length > 1);
    lastIndex = randomIndex;
    return parsedQuotes[randomIndex];
  }

  function updateQuote() {
    const quote = getRandomQuote();
    if (!quote) return;
    quoteText.textContent = quote.text;
    quoteSource.textContent = '— ' + quote.source;
  }

  if (quoteText && quoteSource && parsedQuotes.length > 0) {
    updateQuote();
    setInterval(updateQuote, 30000);
  }

  if (refreshBtn) {
    refreshBtn.addEventListener('click', updateQuote);
  }
</script>

<style>
  .quote-display {
    position: relative;
    padding: 2rem 0 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    min-height: 180px;
  }

  .quote-border-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--rr-color-primary);
  }

  .quote-content {
    max-width: 420px;
  }

  .quote-text {
    font-family: var(--rr-font-serif);
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--rr-color-secondary);
    margin: 0 0 1rem 0;
    font-style: italic;
  }

  .quote-source {
    font-family: var(--rr-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rr-color-muted);
  }

  .quote-refresh {
    margin-top: 0.75rem;
    background: transparent;
    border: 1px solid var(--rr-color-border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    cursor: pointer;
    color: var(--rr-color-muted);
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quote-refresh:hover {
    color: var(--rr-color-primary);
    border-color: var(--rr-color-primary);
  }

  .quote-refresh {
    margin-top: 0.75rem;
    background: transparent;
    border: 1px solid var(--rr-color-border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    cursor: pointer;
    color: var(--rr-color-muted);
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quote-refresh:hover {
    color: var(--rr-color-primary);
    border-color: var(--rr-color-primary);
  }

  @media (max-width: 767px) {
    .quote-display {
      padding: 2rem 0 0 0;
      border-top: 1px solid var(--rr-color-border);
      margin-top: 2rem;
      min-height: auto;
    }

    .quote-border-accent {
      top: 0;
      left: 0;
      right: 0;
      bottom: auto;
      width: auto;
      height: 4px;
    }
  }
</style>
