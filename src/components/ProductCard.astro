---
// ProductCard Props
// product: Product (required)
const { product } = Astro.props;

// Category labels
const categoryLabels: Record<string, string> = {
  'books': 'Book',
  'guides': 'Guide',
  'card-decks': 'Card Deck',
  'training-materials': 'Training Material',
  'workout-packs': 'Workout Pack',
};

// Handle missing image - use a placeholder
const hasImage = product.previewImages && product.previewImages.length > 0 && product.previewImages[0]?.src;
---

<a 
  href={`/library/${product.id}`}
  class="block group"
>
  <div class="border border-gray-200 rounded-lg bg-white shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden h-full flex flex-col">
    <!-- Product Image -->
    <div class="relative h-48 bg-gray-100 overflow-hidden">
      {hasImage ? (
        <img 
          src={product.previewImages[0].src} 
          alt={product.previewImages[0].alt || product.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
          loading="lazy"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
      ) : null}
      <!-- Fallback placeholder when image fails or is missing -->
      <div 
        class:list={[
          "w-full h-full items-center justify-center text-gray-400",
          hasImage ? "hidden" : "flex"
        ]}
      >
        <div class="text-center">
          <div class="text-4xl mb-2">📚</div>
          <div class="text-sm">No preview available</div>
        </div>
      </div>
      
      <!-- Category Badge -->
      <div class="absolute top-2 left-2">
        <span class="bg-blue-600 text-white text-xs font-medium px-2 py-1 rounded-full">
          {categoryLabels[product.category] || product.category}
        </span>
      </div>

      <!-- Price Badge -->
      <div class="absolute top-2 right-2">
        <span class="bg-white text-gray-900 text-sm font-bold px-2 py-1 rounded-full shadow-sm">
          €{product.priceEUR.toFixed(2)}
        </span>
      </div>
    </div>
  
    <!-- Product Info -->
    <div class="flex-1 px-4 py-4 flex flex-col">
      <h3 class="text-lg font-semibold mb-2 text-gray-900 group-hover:text-blue-600 transition-colors">
        {product.title}
      </h3>
      <p class="text-gray-600 mb-3 line-clamp-2 text-sm flex-1">
        {product.description}
      </p>
      
      <!-- What You Will Learn - Show first 2 items -->
      {product.whatYouLearn && product.whatYouLearn.length > 0 && (
        <div class="mt-auto pt-3 border-t border-gray-100">
          <h4 class="font-medium text-gray-800 text-xs uppercase tracking-wide mb-2">
            What You'll Learn:
          </h4>
          <ul class="list-disc pl-4 text-xs text-gray-600 space-y-1">
            {product.whatYouLearn.slice(0, 2).map((learn: string, index: number) => (
              <li key={index} class="line-clamp-1">{learn}</li>
            ))}
            {product.whatYouLearn.length > 2 && (
              <li class="text-blue-600">+{product.whatYouLearn.length - 2} more...</li>
            )}
          </ul>
        </div>
      )}
    </div>
  </div>
</a>
