---
import type { Product } from '@/data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;

// Check if this is the "Coming Soon" placeholder
const isComingSoon = product.id === 'coming-soon' || product.title === 'Coming Soon!';

// Category labels for format stamp
const categoryLabels: Record<string, string> = {
  'books': 'Book',
  'guides': 'Guide',
  'card-decks': 'Card Deck',
  'training-materials': 'Training Material',
  'workout-packs': 'Workout Pack',
};

// Handle missing image - use a placeholder
const hasImage = product.previewImages && product.previewImages.length > 0 && product.previewImages[0]?.src;

// Format price for display (USD and EUR)
const priceUSD = (product.priceEUR * 1.08).toFixed(2);
const priceEUR = product.priceEUR.toFixed(2);
const formattedPrice = product.priceEUR > 0 ? `$${priceUSD} / EUR ${priceEUR}` : 'Free';
---

{isComingSoon ? (
  <div class="border-2 border-dashed border-gray-300 rounded-lg bg-gray-50 overflow-hidden h-full flex flex-col" role="article" aria-label="Coming soon product placeholder">
    <!-- Coming Soon Image Placeholder -->
    <div class="relative aspect-[4/5] bg-gradient-to-br from-gray-200 to-gray-300 overflow-hidden flex items-center justify-center">
      {hasImage ? (
        <img 
          src={product.previewImages[0].src} 
          alt={product.previewImages[0].alt || product.title}
          class="w-full h-full object-cover"
          loading="lazy"
          data-hide-on-error="true"
        />
      ) : (
        <div class="text-center text-gray-500">
          <div class="text-5xl mb-2" aria-hidden="true">📦</div>
          <div class="text-lg font-medium">Coming Soon</div>
        </div>
      )}
      
      <!-- Coming Soon Badge -->
      <div class="absolute top-2 left-2">
        <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse">
          COMING SOON
        </span>
      </div>
    </div>
  
    <!-- Product Info -->
    <div class="flex-1 px-4 py-4 flex flex-col">
      <h3 class="text-lg font-semibold mb-2 text-gray-700">
        {product.title}
      </h3>
      <p class="text-gray-500 mb-3 text-sm flex-1">
        {product.description}
      </p>
      
      <!-- Notify Me Button -->
      <div class="mt-auto pt-3">
        <a 
          href="mailto:info@ruckingrevolution.org?subject=Product%20Updates%20Interest&body=Hi,%0D%0A%0D%0AI'm%20interested%20in%20being%20notified%20when%20new%20products%20are%20available%20in%20the%20Digital%20Library.%0D%0A%0D%0APlease%20add%20me%20to%20the%20notification%20list.%0D%0A%0D%0AThanks!"
          class="block w-full text-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors"
          aria-label="Get notified when new products are available"
        >
          Notify Me When Available
        </a>
      </div>
    </div>
  </div>
) : (
  <a 
    href={product.purchaseLink}
    class="block group h-full"
    aria-label={`View details for ${product.title}`}
  >
    <article class="border border-gray-200 rounded-lg bg-white shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden h-full flex flex-col">
      <!-- Hero Image Area: 4/5 aspect ratio -->
      <div class="relative aspect-[4/5] bg-gray-100 overflow-hidden">
        {hasImage ? (
          <img 
            src={product.previewImages[0].src} 
            alt={product.previewImages[0].alt || product.title}
            class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
            loading="lazy"
            data-image-fallback="next"
          />
        ) : null}
        
        <!-- Hidden fallback state div -->
        <div 
          class:list={[
            "w-full h-full items-center justify-center text-gray-400",
            hasImage ? "hidden" : "flex"
          ]}
        >
          <div class="text-center">
            <div class="text-4xl mb-2" aria-hidden="true">📚</div>
            <div class="text-sm">No preview available</div>
          </div>
        </div>
        
        <!-- Format Stamp (absolute positioned) -->
        <div class="absolute top-3 left-3">
          <span class="stamp stamp-secondary text-xs bg-white/90 backdrop-blur-sm">
            {categoryLabels[product.category] || product.category}
          </span>
        </div>

        <!-- Price Pill (absolute positioned) -->
        <div class="absolute top-3 right-3">
          <span class="bg-secondary text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">
            {formattedPrice}
          </span>
        </div>
      </div>
    
      <!-- Product Info -->
      <div class="flex-1 px-4 py-4 flex flex-col">
        <!-- Metadata Field -->
        <span class="label-mono block mb-2">Rucking Revolution release</span>
        
        <!-- Title Field -->
        <h3 class="text-lg font-heading text-secondary mb-2 group-hover:text-primary transition-colors">
          {product.title}
        </h3>
        
        <!-- Excerpt Field -->
        <p class="text-gray-600 mb-4 text-sm line-clamp-3 flex-1 leading-relaxed">
          {product.description}
        </p>
        
        <!-- Feature List: Bordered section with two-item bulleted list -->
        {product.whatYouLearn && product.whatYouLearn.length > 0 && (
          <div class="border border-gray-100 rounded p-3 mb-4">
            <h4 class="font-heading text-xs text-secondary mb-2 tracking-wider uppercase">
              Inside
            </h4>
            <ul class="space-y-1.5 text-xs text-gray-600" aria-label="Product highlights">
              {product.whatYouLearn.slice(0, 2).map((feature: string) => (
                <li class:list={["flex items-start gap-1.5"]}>
                  <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span class="line-clamp-1">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        <!-- CTA Link -->
        <div class="mt-auto pt-2 border-t border-gray-50">
          <span class="text-primary text-sm font-bold group-hover:underline">
            View book details →
          </span>
        </div>
      </div>
    </article>
  </a>
)}
