---
interface Props {
  href?: string;
  label: string;
  icon?: string; // optional emoji or small svg string
  active?: boolean;
  ariaLabel?: string;
}
const { href, label, icon, active = false, ariaLabel } = Astro.props;

const base = "px-4 py-2 rounded text-sm font-medium transition-all duration-150 border border-border focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary inline-flex items-center gap-2";
const activeClasses = active ? "bg-primary text-white border-primary" : "bg-surface text-muted-foreground hover:border-primary hover:text-primary";
---
{href ? (
  <a href={href} class={`${base} ${activeClasses}`} aria-label={ariaLabel || label}>
    {icon && <span aria-hidden="true">{icon}</span>}
    <span>{label}</span>
  </a>
) : (
  <button class={`${base} ${activeClasses}`} aria-label={ariaLabel || label}>
    {icon && <span aria-hidden="true">{icon}</span>}
    <span>{label}</span>
  </button>
)}
