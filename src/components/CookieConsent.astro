---
// CookieConsent Component
// GDPR-compliant cookie consent banner
---
<div id="cookie-consent" class="fixed bottom-0 left-0 right-0 bg-gray-900 text-white p-4 shadow-lg z-50 hidden">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex-1">
      <h3 class="font-semibold mb-2">Cookie Policy</h3>
      <p class="text-sm text-gray-300">
        We use cookies to enhance your browsing experience. Under GDPR and Norwegian law, we need your consent for non-essential cookies. 
        <a href="/privacy" class="underline hover:text-white">Learn more</a>
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-2">
      <button 
        id="cookie-reject" 
        class="px-4 py-2 border border-gray-500 rounded hover:bg-gray-800 transition-colors text-sm"
      >
        Reject Non-Essential
      </button>
      <button 
        id="cookie-accept" 
        class="px-4 py-2 bg-accent text-white rounded hover:bg-accent/90 transition-colors text-sm"
      >
        Accept All
      </button>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'cookie_consent';
  const CONSENT_EXPIRY = 365; // days

  function getCookieConsent(): string | null {
    return localStorage.getItem(CONSENT_KEY);
  }

  function setCookieConsent(value: string): void {
    localStorage.setItem(CONSENT_KEY, value);
    const date = new Date();
    date.setTime(date.getTime() + (CONSENT_EXPIRY * 24 * 60 * 60 * 1000));
    localStorage.setItem(`${CONSENT_KEY}_expiry`, date.toISOString());
  }

  function hideBanner(): void {
    const banner = document.getElementById('cookie-consent');
    if (banner) {
      banner.classList.add('hidden');
    }
  }

  function showBanner(): void {
    const banner = document.getElementById('cookie-consent');
    if (banner) {
      banner.classList.remove('hidden');
    }
  }

  // Expose showBanner globally for footer button
  (window as unknown as { showCookieBanner: () => void }).showCookieBanner = showBanner;

  function isConsentExpired(): boolean {
    const expiry = localStorage.getItem(`${CONSENT_KEY}_expiry`);
    if (!expiry) return true;
    return new Date(expiry) < new Date();
  }

  // Check consent on page load
  document.addEventListener('DOMContentLoaded', () => {
    const consent = getCookieConsent();
    
    // Show banner if no consent or consent expired
    if (!consent || isConsentExpired()) {
      showBanner();
    } else if (consent === 'accepted') {
      // Initialize analytics if accepted
      initializeAnalytics();
    }

    // Listen for showCookieBanner event from footer button
    window.addEventListener('showCookieBanner', () => {
      showBanner();
    });
  });

  // Accept all cookies
  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    setCookieConsent('accepted');
    hideBanner();
    initializeAnalytics();
  });

  // Reject non-essential cookies
  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    setCookieConsent('rejected');
    hideBanner();
    // Don't initialize analytics
  });

  function initializeAnalytics(): void {
    // Placeholder for analytics initialization
    // Add your analytics code here (Google Analytics, etc.)
    console.log('Analytics initialized - consent given');
  }
</script>
