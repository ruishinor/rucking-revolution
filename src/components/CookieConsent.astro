---
// CookieConsent Component
// GDPR-compliant cookie consent banner
---
<div id="cookie-consent" class="fixed bottom-0 left-0 right-0 bg-gray-900 text-white p-4 shadow-lg z-50 hidden">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex-1">
      <h3 class="font-semibold mb-2">Cookie Policy</h3>
      <p class="text-sm text-gray-300">
        We use cookies to enhance your browsing experience. Under GDPR and Norwegian law, we need your consent for non-essential cookies. 
        <a href="/privacy" class="underline hover:text-white">Learn more</a>
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-2">
      <button 
        id="cookie-reject" 
        class="px-4 py-2 border border-gray-500 rounded hover:bg-gray-800 transition-colors text-sm"
      >
        Reject Non-Essential
      </button>
      <button 
        id="cookie-accept" 
        class="px-4 py-2 bg-accent text-white rounded hover:bg-accent/90 transition-colors text-sm"
      >
        Accept All
      </button>
    </div>
  </div>
</div>

<script type="module" src="/scripts/cookie-consent.js" is:inline></script>
