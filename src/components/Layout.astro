---
  import { site } from '@/data/site.ts';
  import '@/styles/global.css';
  import SEO from '@/components/SEO.astro';
  import Header from '@/components/Header.astro';
  import CookieConsent from '@/components/CookieConsent.astro';

  const { 
    title: layoutTitle = site.title,
    description: layoutDescription = site.description,
    currentPage,
    openGraph = {},
    twitter = {},
    structuredData = null,
    canonicalUrl = `${site.baseUrl}`,
    noindex = false,
    nofollow = false
  } = Astro.props;
  const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700;800&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
    <SEO 
      title={layoutTitle}
      description={layoutDescription}
      openGraph={openGraph}
      twitter={twitter}
      structuredData={structuredData}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
      nofollow={nofollow}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground antialiased">
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:m-2 focus:z-50">
      Skip to main content
    </a>

    <!-- Accessible Header -->
    <header class="z-50 border-b border-white/10 bg-secondary text-white shadow-md">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between py-4">
          <!-- Site Logo/Brand -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="font-heading text-3xl tracking-wider uppercase whitespace-nowrap">
              {site.title}
            </a>
          </div>

          <!-- Navigation Menu -->
          <div class="hidden md:block md:ml-10">
            <nav aria-label="Primary" class="flex space-x-6">
              {site.primaryNav.map(({ name, link }) => (
                <a
                  href={link}
                  class={`rounded-md px-3 py-2 text-sm font-semibold uppercase tracking-wide transition-colors duration-200 hover:text-accent ${currentPage === link ? 'border-b-2 border-accent text-white' : 'text-white/80'}`}
                  key={link}
                >
                  {name}
                </a>
              ))}
            </nav>
          </div>

          <!-- Mobile Menu Button -->
          <div class="-mr-2 flex items-center md:hidden">
            <button id="mobile-menu-button"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    class="inline-flex items-center justify-center rounded-md p-2 text-white/80 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-secondary">
              <span class="sr-only">Open main menu</span>
              <!-- Icon: hamburger -->
              <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden space-y-1 px-2 pt-2 pb-3">
        {site.primaryNav.map(({ name, link }) => (
          <a
            href={link}
            class={`block rounded-md px-3 py-2 text-base font-semibold uppercase tracking-wide hover:bg-accent hover:text-secondary ${currentPage === link ? 'bg-accent text-secondary' : 'text-white/80'}`}
            key={link}
          >
            {name}
          </a>
        ))}
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-secondary py-8 text-gray-200">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 sm:grid-cols-4 sm:px-6 lg:px-8">
        <!-- About Section -->
        <section>
          <h3 class="text-white font-semibold mb-4">About</h3>
          <ul class="space-y-2 text-sm">
            {site.secondaryNav.map(({ name, link }) => (
              <li key={link}>
                <a href={link} class="hover:text-white transition-colors duration-200">
                  {name}
                </a>
              </li>
            ))}
          </ul>
        </section>

        <!-- Social Links -->
        <section>
          <h3 class="text-white font-semibold mb-4">Connect</h3>
          <ul class="space-y-2 text-sm">
            <li>
            <a href="https://facebook.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Facebook</a>
            </li>
            <li>
            <a href="https://instagram.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Instagram</a>
            </li>
            <li>
            <a href="https://twitter.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Twitter</a>
            </li>
            <li>
            <a href="https://youtube.com/@ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">YouTube</a>
            </li>
          </ul>
        </section>

        <!-- Newsletter -->
        <section>
          <h3 class="text-white font-semibold mb-4">Newsletter</h3>
          <p class="text-sm mb-4">Get updates on new articles, workouts, and community events.</p>
          <form class="space-y-2">
            <input type="email" placeholder="Enter your email" required class="w-full rounded-border border border-gray-600 bg-gray-700 px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-accent" />
            <button type="submit" class="w-full rounded-md bg-accent px-4 py-2 font-medium text-secondary transition-colors duration-200 hover:bg-accent/90">
              Subscribe
            </button>
          </form>
        </section>

        <!-- Legal -->
        <section>
          <h3 class="text-white font-semibold mb-4">Legal</h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
            </li>
            <li>
              <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
            </li>
            <li>
              <button id="cookie-prefs-btn" type="button" class="hover:text-white transition-colors duration-200 text-left bg-transparent border-none p-0 cursor-pointer">
                Cookie Preferences
              </button>
            </li>
          </ul>
          <p class="text-xs text-gray-400 mt-4">&copy; {new Date().getFullYear()} Rucking Revolution. All rights reserved.</p>
        </section>
      </div>
    </footer>

     <!-- Mobile Menu Script -->
     <script client:idle>
       document.addEventListener('DOMContentLoaded', () => {
         const button = document.getElementById('mobile-menu-button');
         const menu = document.getElementById('mobile-menu');
         
         button.addEventListener('click', () => {
           const expanded = button.getAttribute('aria-expanded') === 'true' || false;
           button.setAttribute('aria-expanded', !expanded);
           menu.classList.toggle('hidden');
         });
         
         // Close mobile menu when clicking outside
         document.addEventListener('click', (event) => {
           if (!button.contains(event.target) && !menu.contains(event.target)) {
             button.setAttribute('aria-expanded', 'false');
             menu.classList.add('hidden');
           }
         });
         
         // Handle escape key
         document.addEventListener('keydown', (event) => {
           if (event.key === 'Escape' && !menu.classList.contains('hidden')) {
             button.setAttribute('aria-expanded', 'false');
             menu.classList.add('hidden');
           }
         });
       });
     </script>
    <CookieConsent />
    <script>
      // Cookie preferences button in footer
      document.getElementById('cookie-prefs-btn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('showCookieBanner'));
      });
    </script>
  </body>
</html>
