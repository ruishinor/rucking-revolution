---
  import { site } from '@/data/site.ts';
  import '@/styles/global.css';
  import SEO from '@/components/SEO.astro';
  import CookieConsent from '@/components/CookieConsent.astro';

  const { 
    title: layoutTitle = site.title,
    description: layoutDescription = site.description,
    currentPage,
    openGraph = {},
    twitter = {},
    structuredData = null,
    canonicalUrl = `${site.baseUrl}${Astro.url.pathname}`,
    noindex = false,
    nofollow = false
  } = Astro.props;
  const year = new Date().getFullYear();

  const defaultOrganizationData = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Rucking Revolution",
    "url": site.baseUrl,
    "logo": `${site.baseUrl}/images/logo.png`,
    "sameAs": [
      "https://facebook.com/ruckingrevolution",
      "https://instagram.com/ruckingrevolution",
      "https://twitter.com/ruckingrevolution",
      "https://youtube.com/@ruckingrevolution"
    ]
  };
---
<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet" />
    <SEO 
      title={layoutTitle}
      description={layoutDescription}
      openGraph={openGraph}
      twitter={twitter}
      structuredData={structuredData}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
      nofollow={nofollow}
    />
    {!structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(defaultOrganizationData)}></script>}
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground antialiased">
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:m-2 focus:z-50">
      Skip to main content
    </a>

    <!-- Accessible Header -->
    <header class="z-50 border-b border-white/10 bg-secondary text-white shadow-md">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between py-4">
          <!-- Site Logo/Brand -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="font-heading text-3xl tracking-wider uppercase whitespace-nowrap">
              {site.title}
            </a>
          </div>

          <!-- Navigation Menu -->
          <div class="hidden md:block md:ml-10">
            <nav aria-label="Primary" class="flex space-x-6">
              {site.primaryNav.map(({ name, link }) => (
                <a
                  href={link}
                  class={`rounded-md px-3 py-2 text-sm font-semibold uppercase tracking-wide transition-colors duration-200 hover:text-accent ${currentPage === link ? 'border-b-2 border-accent text-white' : 'text-white/80'}`}
                >
                  {name}
                </a>
              ))}
            </nav>
          </div>

          <!-- Mobile Menu Button -->
          <div class="flex items-center md:hidden">
            <button id="mobile-menu-button"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    class="inline-flex items-center justify-center rounded-md p-3 min-h-[44px] min-w-[44px] text-white/80 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-secondary">
              <span class="sr-only">Open main menu</span>
              <!-- Icon: hamburger -->
              <svg class="icon-hamburger h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <!-- Icon: close -->
              <svg class="icon-close h-6 w-6 hidden" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden space-y-1 px-2 pt-2 pb-3">
        {site.primaryNav.map(({ name, link }) => (
          <a
            href={link}
            class={`block rounded-md px-3 py-2 text-base font-semibold uppercase tracking-wide hover:bg-accent hover:text-secondary ${currentPage === link ? 'bg-accent text-secondary' : 'text-white/80'}`}
          >
            {name}
          </a>
        ))}
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-secondary py-8 text-gray-200">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
        <!-- About Section -->
        <section>
          <h3 class="text-white font-semibold mb-4">About</h3>
          <ul class="space-y-2 text-sm">
            {site.secondaryNav.map(({ name, link }) => (
              <li>
                <a href={link} class="hover:text-white transition-colors duration-200">
                  {name}
                </a>
              </li>
            ))}
          </ul>
        </section>

        <!-- Social Links -->
        <section>
          <h3 class="text-white font-semibold mb-4">Connect</h3>
          <ul class="space-y-2 text-sm">
            <li>
            <a href="https://facebook.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Facebook</a>
            </li>
            <li>
            <a href="https://instagram.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Instagram</a>
            </li>
            <li>
            <a href="https://twitter.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Twitter</a>
            </li>
            <li>
            <a href="https://youtube.com/@ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">YouTube</a>
            </li>
          </ul>
        </section>

        <!-- Legal -->
        <section>
          <h3 class="text-white font-semibold mb-4">Legal</h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
            </li>
            <li>
              <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
            </li>
            <li>
              <button id="cookie-prefs-btn" type="button" class="hover:text-white transition-colors duration-200 text-left bg-transparent border-none p-0 cursor-pointer text-sm" aria-label="Open cookie preferences">
                Cookie Preferences
              </button>
            </li>
          </ul>
          <p class="text-xs text-gray-400 mt-4">&copy; {year} Rucking Revolution. All rights reserved.</p>
        </section>
      </div>
    </footer>

    <CookieConsent />
    <script type="module" src="/scripts/layout.js" is:inline></script>
    
     <script is:inline>
       function updateThemeIcons() {
         const theme = document.documentElement.getAttribute('data-theme');
         const isDark = theme === 'dark';
         document.querySelectorAll('.icon-sun').forEach(el => el.classList.toggle('hidden', !isDark));
         document.querySelectorAll('.icon-moon').forEach(el => el.classList.toggle('hidden', isDark));
       }
       
       function setTheme(theme) {
         document.documentElement.setAttribute('data-theme', theme);
         localStorage.setItem('theme', theme);
         updateThemeIcons();
       }
       
       function toggleTheme() {
         const current = document.documentElement.getAttribute('data-theme');
         setTheme(current === 'dark' ? 'light' : 'dark');
       }
       
       document.addEventListener('DOMContentLoaded', function() {
         updateThemeIcons();
         
         const toggleDesktop = document.getElementById('theme-toggle');
         const toggleMobile = document.getElementById('theme-toggle-mobile');
         
         if (toggleDesktop) {
           toggleDesktop.addEventListener('click', toggleTheme);
         }
         if (toggleMobile) {
           toggleMobile.addEventListener('click', toggleTheme);
         }
       });

       // Prevent browser scroll restoration, force scroll to top on all loads/reloads
       if (history.scrollRestoration) {
         history.scrollRestoration = 'manual';
       }

       function scrollToTop() {
         window.scrollTo({ top: 0, behavior: 'instant' });
       }

       // Scroll to top on initial load and client-side navigation
       document.addEventListener('astro:page-load', scrollToTop);
       // Fallback for full page reloads
       window.addEventListener('load', scrollToTop);

       // Capitalize first letter after colons across the site (human indicator)
       function capitalizeAfterColons() {
         if (typeof window === 'undefined') return;
         const treeWalker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
         let node;
         while (node = treeWalker.nextNode()) {
           // Skip script, style, and input elements
           const parent = node.parentNode;
           if (parent.tagName === 'SCRIPT' || parent.tagName === 'STYLE' || parent.tagName === 'INPUT' || parent.tagName === 'TEXTAREA') {
             continue;
           }
           const original = node.nodeValue;
           if (original.includes(':')) {
             const updated = original.replace(/(:\s*)(\w)/g, (_match, p1, p2) => p1 + p2.toUpperCase());
             if (updated !== original) {
               node.nodeValue = updated;
             }
           }
         }
       }

       document.addEventListener('astro:page-load', capitalizeAfterColons);
       document.addEventListener('DOMContentLoaded', capitalizeAfterColons);
     </script>
  </body>
</html>
