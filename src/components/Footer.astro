---
// Footer Props
// class: string (optional)
const { class: className = '' } = Astro.props;
---
<footer class="bg-gray-800 text-gray-200 py-8 {{ className }}">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 gap-8 sm:grid-cols-4">
    <!-- About Section -->
    <section>
      <h3 class="text-white font-semibold mb-4">About</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Our Story</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Meet the Team</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Blog</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Contact</a>
        </li>
      </ul>
    </section>

    <!-- Social Links -->
    <section>
      <h3 class="text-white font-semibold mb-4">Connect</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Facebook</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Instagram</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">Twitter</a>
        </li>
        <li>
          <a href="#" class="hover:text-white transition-colors duration-200">YouTube</a>
        </li>
      </ul>
    </section>

    <!-- Newsletter -->
    <section>
      <h3 class="text-white font-semibold mb-4">Newsletter</h3>
      <p class="text-sm mb-4">Get updates on new articles, workouts, and community events.</p>
      <form class="space-y-2">
        <input type="email" placeholder="Enter your email" required class="w-full px-3 py-2 rounded-border border-gray-600 bg-gray-700 text-white focus:outline-none focus:ring-2 focus:ring-accent" />
        <button type="submit" class="w-full bg-accent text-white px-4 py-2 rounded-md hover:bg-accent/80 transition-colors duration-200 font-medium">
          Subscribe
        </button>
      </form>
    </section>

    <!-- Legal -->
    <section class="text-xs text-gray-400 border-t pt-4">
      <p>&copy; <span id="year"></span> Rucking Revolution. All rights reserved.</p>
    </section>
  </div>
</footer>

<script client:idle>
  document.getElementById('year').textContent = new Date().getFullYear();
</script>