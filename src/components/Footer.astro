---
// Footer Props
// class: string (optional)
const { class: className = '' } = Astro.props;
const year = new Date().getFullYear();
---
<footer class={`bg-gray-800 py-8 text-gray-200 ${className}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 gap-8 sm:grid-cols-4">
    <!-- About Section -->
    <section>
      <h3 class="text-white font-semibold mb-4">About</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="/about" class="hover:text-white transition-colors duration-200">Our Story</a>
        </li>
        <li>
          <a href="/about" class="hover:text-white transition-colors duration-200">Meet the Team</a>
        </li>
        <li>
          <a href="/articles" class="hover:text-white transition-colors duration-200">Articles</a>
        </li>
        <li>
          <a href="/contact" class="hover:text-white transition-colors duration-200">Contact</a>
        </li>
      </ul>
    </section>

    <!-- Social Links -->
    <section>
      <h3 class="text-white font-semibold mb-4">Connect</h3>
      <ul class="space-y-2 text-sm">
        <li>
        <a href="https://facebook.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Facebook</a>
        </li>
        <li>
        <a href="https://instagram.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Instagram</a>
        </li>
        <li>
        <a href="https://twitter.com/ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">Twitter</a>
        </li>
        <li>
        <a href="https://youtube.com/@ruckingrevolution" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200">YouTube</a>
        </li>
      </ul>
    </section>

    <!-- Newsletter -->
    <section>
      <h3 class="text-white font-semibold mb-4">Newsletter</h3>
      <p class="text-sm mb-4">Get updates on new articles, workouts, and community events.</p>
      <a href="/newsletter" class="inline-block w-full text-center rounded-md bg-accent px-4 py-2 font-medium text-secondary transition-colors duration-200 hover:bg-accent/90">
        Subscribe
      </a>
    </section>

    <!-- Legal -->
    <section>
      <h3 class="text-white font-semibold mb-4">Legal</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
        </li>
        <li>
          <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
        </li>
        <li>
          <button id="cookie-prefs-btn" type="button" class="hover:text-white transition-colors duration-200 text-left bg-transparent border-none p-0 cursor-pointer">
            Cookie Preferences
          </button>
        </li>
      </ul>
    </section>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 pt-4 border-t border-gray-700">
    <section class="text-xs text-gray-400">
      <p>&copy; {year} Rucking Revolution. All rights reserved.</p>
    </section>
  </div>
</footer>
