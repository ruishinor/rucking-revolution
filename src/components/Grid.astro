---
// Grid Props
// columns: number (default 1)
// gap: number (default 4)
// class: string (optional)
const { columns = 1, gap = 4, class: className = '' } = Astro.props;

const columnClasses = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  5: 'grid-cols-5',
  6: 'grid-cols-6'
};

const gapClasses = {
  0: 'gap-0',
  1: 'gap-1',
  2: 'gap-2',
  3: 'gap-3',
  4: 'gap-4',
  5: 'gap-5',
  6: 'gap-6',
  8: 'gap-8',
  10: 'gap-10',
  12: 'gap-12'
};

const resolvedColumns = columnClasses[columns] ?? 'grid-cols-1';
const resolvedGap = gapClasses[gap] ?? 'gap-4';
---
<div class={`grid ${resolvedColumns} ${resolvedGap} ${className}`}>
  <slot />
</div>
