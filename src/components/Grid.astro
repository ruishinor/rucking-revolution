---
interface Props {
  columns?: number;
  gap?: number;
  class?: string;
}

const props = Astro.props as Props;
const columns = props.columns ?? 1;
const gap = props.gap ?? 4;
const className = props.class ?? '';

const columnClasses: Record<number, string> = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  5: 'grid-cols-5',
  6: 'grid-cols-6'
};

const gapClasses: Record<number, string> = {
  0: 'gap-0',
  1: 'gap-1',
  2: 'gap-2',
  3: 'gap-3',
  4: 'gap-4',
  5: 'gap-5',
  6: 'gap-6',
  8: 'gap-8',
  10: 'gap-10',
  12: 'gap-12'
};

const resolvedColumns = columnClasses[columns as keyof typeof columnClasses] ?? 'grid-cols-1';
const resolvedGap = gapClasses[gap as keyof typeof gapClasses] ?? 'gap-4';
---
<div class={`grid ${resolvedColumns} ${resolvedGap} ${className}`}>
  <slot />
</div>
