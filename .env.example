# ==========================================
# Rucking Revolution - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ==========================================

# --- API Keys & Secrets ---

# API key for headless CMS (if used, e.g. Ghost)
CMS_API_KEY=

# Secret for the health check endpoint (used by monitoring services)
HEALTH_CHECK_SECRET=

# --- Newsletter Integration ---

# Webhook URL for newsletter subscriptions (must be HTTPS)
NEWSLETTER_WEBHOOK_URL=

# Cloudflare Turnstile site key for newsletter form
NEWSLETTER_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key for newsletter verification
NEWSLETTER_TURNSTILE_SECRET_KEY=

# --- AAR (After Action Review) Submissions ---

# Master switch for public AAR submissions (set to 'true' to enable)
AAR_PUBLIC_SUBMISSIONS_ENABLED=

# Webhook URL for AAR submission moderation/ingestion (must be HTTPS)
AAR_SUBMISSIONS_WEBHOOK_URL=

# Cloudflare Turnstile site key for AAR form
AAR_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key for AAR verification
AAR_TURNSTILE_SECRET_KEY=

# --- Feature Flags ---

# Enables /backstage route when 'true'
BACKSTAGE_ENABLED=

# Enables /style-guide route when 'true'
STYLE_GUIDE_ENABLED=

# Enables /branding-mockup route when 'true'
BRANDING_MOCKUP_ENABLED=
