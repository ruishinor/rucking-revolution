# ==========================================
# Rucking Revolution - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ==========================================

# --- API Keys & Secrets ---

# API key for headless CMS (if used, e.g. Ghost)
CMS_API_KEY=

# Secret for the health check endpoint (used by monitoring services)
HEALTH_CHECK_SECRET=

# --- Newsletter Integration ---

# Webhook URL for newsletter subscriptions (must be HTTPS)
NEWSLETTER_WEBHOOK_URL=

# Cloudflare Turnstile site key for newsletter form
NEWSLETTER_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key for newsletter verification
NEWSLETTER_TURNSTILE_SECRET_KEY=

# --- AAR (After Action Review) Submissions ---

# Master switch for public AAR submissions (set to 'true' to enable)
AAR_PUBLIC_SUBMISSIONS_ENABLED=

# Webhook URL for AAR submission moderation/ingestion (must be HTTPS)
AAR_SUBMISSIONS_WEBHOOK_URL=

# Cloudflare Turnstile site key for AAR form
AAR_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key for AAR verification
AAR_TURNSTILE_SECRET_KEY=

# --- Feature Flags ---

# Enables /backstage route when 'true'
BACKSTAGE_ENABLED=

# Enables /style-guide route when 'true'
STYLE_GUIDE_ENABLED=

# Enables /branding-mockup route when 'true'
BRANDING_MOCKUP_ENABLED=

# Toggle to show/hide the public comics archive and links (set to 'true' to enable)
PUBLIC_SHOW_COMICS=true

# Toggle to show/hide featured book on landing page and digital library (set to 'true' to enable)
PUBLIC_SHOW_FEATURED_BOOK=false

# Toggle to show/hide Crew Tactics Generator (set to 'true' to enable)
PUBLIC_SHOW_CREW_TACTICS=false

# Toggle to enable/disable /routes reviewed content (accepts 'true'/'false' or 'show'/'hide')
PUBLIC_ROUTES_ENABLED=false

# Toggle to enable/disable /events reviewed content (accepts 'true'/'false' or 'show'/'hide')
PUBLIC_EVENTS_ENABLED=false

# Toggle to enable/disable /field-notes reviewed content (accepts 'true'/'false' or 'show'/'hide')
PUBLIC_FIELD_NOTES_ENABLED=false

# --- Upstash Redis (optional) ---
# If you provision Upstash (serverless Redis) for centralized rate-limiting
# set these in your hosting provider (Vercel/GitHub Actions) or local .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
